<% var card_title = '' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Mikoa',
    page_title : 'Orodha ya Mikoa',
    card_title : 'Mikoa iliyopo',
    breadcrumb_main : 'Mipangilio',
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>
<div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-3">
            <div class="col-sm-auto">
                <div>
                    <div id="firstbtn">
                        <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn"><i class="ri-add-line align-bottom me-1"></i> Vuta Mikoa</button>
                    </div>
                    <div id="pakiabtn" style="display: none;">
                        <button type="button" class="btn btn-success btn-load">
                            <span class="d-flex align-items-center">
                                <span class="spinner-border flex-shrink-0" role="status">
                                    <span class="visually-hidden">Inapakia...</span>
                                </span>
                                <span class="flex-grow-1 ms-2">
                                    Inapakia...
                                </span>
                            </span>
                        </button>
                    </div>
                    <!-- <button class="btn btn-soft-danger" onClick="deleteMultiple()"><i class="ri-delete-bin-2-line"></i></button> -->
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <div class="table-responsive table-card mt-3 mb-1">
            <table class="table align-middle table-nowrap table-striped" id="datatable">
                <thead class="table-light">
                    <tr>
                        <th width="5%">Na.</th>
                        <th >Jina la Mkoa</th>
                        <th >Kodi ya Mkoa</th>
                        <th >Anuani Mkoa</th>
                        <th >Kanda</th>
                        <th >Ofisi ya Kanda</th>
                        <th >Imeingizwa</th>
                        <th >Imesasishwa</th>
                        <th class=" text-center" width="5%">Action</th>
                    </tr>
                </thead>
                <tbody class="list form-check-all">
                </tbody>
            </table>
           </div>
            <div class="noresult" style="display: none">
                <div class="text-center">
                    <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                    <h5 class="mt-2">Sorry! No Result Found</h5>
                    <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
                </div>
            </div>
        </div>
        <!-- <%-include('paginations/ajax_pagination.ejs')%> -->
    </div>
</div><!-- end card -->
 <div class="modal fade" id="showModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title" id="exampleModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
            </div>
            <form>
                <div class="modal-body">

                    <div class="mb-3" id="modal-id">
                        <label for="id-field" class="form-label">Kodi ya Mkoa</label>
                        <input type="text" id="id-field" class="form-control" placeholder="ID" />
                    </div>

                    <div class="mb-3">
                        <label for="customername-field" class="form-label">Jina la Mkoa</label>
                        <input type="text" id="customername-field" class="form-control" placeholder="Enter Name" required />
                    </div>

                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-success" id="add-btn">Add Customer</button>
                        <button type="button" class="btn btn-success" id="edit-btn">Update</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="showModalZone" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title" id="exampleModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
            </div>
            <form>
                <div class="modal-body">
                <input type="hidden" id="regionId" name="regionId"/>
                <div class="mb-3">
                    <label for="status-field" class="form-label">Chagua Kanda/Zoni</label>
                    <select class="form-control" data-trigger name="zone-field" id="zone-field">
                        <option value=""> Chagua </option>
                        <% for(var i = 0; i < zones.length; i++){ %>
                            <option value="<%= zones[i].id %>"><%= zones[i].zone_name %></option>
                        <% } %>
                    </select>
                </div>
                <div class="mb-3">
                <label for="box-field" class="form-label">Anuani ya Mkoa (S.L.P)</label>
                    <input type="number" class="form-control" placeholder="Anuani ya Mkoa" data-trigger name="box-field" id="box-field">
                </div>
                <div class=" form-check">
                    <label for="sqa-zone-field" class="form-check-label">
                    <input type="checkbox" name="sqa_zone" class="form-check-input" id="sqa-zone-field"> Kuna Ofisi ya Kanda?
                    </label>
                </div>
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" onclick="updateRegion()" class="btn btn-success" id="add-btn">Update</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade zoomIn" id="deleteRecordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="btn-close"></button>
            </div>
            <div class="modal-body">
                <div class="mt-2 text-center">
                    <lord-icon src="https://cdn.lordicon.com/gsqxdxog.json" trigger="loop" colors="primary:#f7b84b,secondary:#f06548" style="width:100px;height:100px"></lord-icon>
                    <div class="mt-4 pt-2 fs-15 mx-4 mx-sm-5">
                        <h4>Are you Sure ?</h4>
                        <p class="text-muted mx-4 mb-0">Are you Sure You want to Remove this Record ?</p>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-center mt-4 mb-2">
                    <button type="button" class="btn w-sm btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn w-sm btn-danger " id="delete-record">Yes, Delete It!</button>
                </div>
            </div>
        </div>
    </div>
</div>
<!--end modal -->
<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/mikoa_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    $(document).ready(function() {
        tableData('datatable' ,'/MikoaList' , 'POST',
            [
                    { data: null, render : (data , type , row , meta) => {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    } },
                    { data: "regionName", name: "regionName" },
                    { data: "regionCode", name: "regionCode" },
                    { data: "box", name: "box"  , render : (data , type , row) => {
                        return data == 0 || data == null ? '' : ('S.L.P '+ data)
                    }},
                    { data: "zoneName", name: "zoneName" },
                    { data: "sqa_zone", name: "sqa_zone" ,  render: (data , type , row) => {
                        return data ? `<span class="ri-building-2-line text-primary ri-2x" title="Zone Office" data-bs-toggle='tooltip'></span>` : ''
                        },
                        class : 'text-center'
                    },
                    {
                      data: "createdAt", name: "createdAt",
                            render: (data, type, row) => {
                                return changeDateFormat(data);
                            },
                    },
                    {
                    data: "updatedAt", name: "updatedAt",
                            render: (data, type, row) => {
                                return changeDateFormat(data);
                            },
                    },
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                            const elements = [
                                            {
                                                show : true,
                                                type : 'link',
                                                class : 'btn btn-sm btn-outline-primary me-1',
                                                icon : 'bx bx-pencil me-1',
                                                function : 'editRegion',
                                                btnText : 'Edit'
                                            },
                                        ]
                        return actionButtons(row , elements);
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    },
            ]
        );
    });
</script>
<!-- <script type="text/javascript" src="design/layouts/scripts/mikoa_scripts.js"></script> -->
</body>
</html>