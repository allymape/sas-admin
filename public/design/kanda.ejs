<% var card_title = '' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Kanda',
    page_title : 'Orodha ya Kanda',
    card_title : 'Kanda zilizopo',
    breadcrumb_main : 'Mipangilio' 
}) %>
  <div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-3">
            <div class="col-sm-auto">
                <div>
                    <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn"><i class="ri-add-line align-bottom me-1"></i> Sajili</button>
                    <!-- <button class="btn btn-soft-danger" onClick="deleteMultiple()"><i class="ri-delete-bin-2-line"></i></button> -->
                </div>
            </div>
            <div class="col-sm">
                <div class="d-flex justify-content-sm-end">
                    <div class="search-box ms-2">
                        <input type="text" class="form-control search" placeholder="Tafuta...">
                        <i class="ri-search-line search-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive table-card mt-3 mb-1">
            <table class="table align-middle table-nowrap" id="kandaTable">
                <thead class="table-light">
                    <tr>
                        <th scope="col" width="5%">
                            Na.
                        </th>
                        <th class="sort" data-sort="customer_name">Jina la Kanda</th>
                        <th class="sort" data-sort="email">Kodi ya Kanda</th>
                        <th class="sort" data-sort="email">Anuani</th>
                        <th class="sort" data-sort="email">Hali</th>
                        <th class="sort text-center" width="10%"  data-sort="action">Action</th>
                    </tr>
                </thead>
                <tbody class="list form-check-all">
                </tbody>
            </table>
            <div class="noresult" style="display: none">
                <div class="text-center">
                    <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                    <h5 class="mt-2">Sorry! No Result Found</h5>
                    <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
                </div>
            </div>
        </div>
        <%- include('paginations/ajax_pagination.ejs') %>
    </div>
    </div><!-- end card -->

                    <div class="modal fade" id="showModal-create" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                     <div class="modal-header bg-light p-3">
                                            <h5 class="modal-title" id="exampleModalLabel">Tengeneza</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                                      </div>
                                    <form>
                                    <div class="alert alert-success shadow" role="alert" id="alertsuccess" style="display: none;">
                                        <strong> Hongera! </strong> Kanda <b>iimesajiliwa</b> kikamilifu!
                                    </div>
                                    <div class="alert alert-danger shadow mb-xl-0" role="alert" id="alertexist" style="display: none;">
                                        <strong> Imeshindwa Kusajili! </strong> Kanda <b>kilishasajiliwa</b> kwenye mfumo tayari!
                                     </div>
                                     <div class="alert alert-warning shadow shadow" role="alert" id="alertmtandao" style="display: none;">
                                        <strong> Uh oh, kuna tatizo </strong> la <b>mtandao,</b> tafadhali jaribu tena badae!
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3" id="modal-id">
                                            <label for="id-field" class="form-label">Kodi ya Kanda</label>
                                            <input type="text" id="id-field" class="form-control" placeholder="ID" />
                                            <span style="color: red;display: none;" id="jazasimu">Tafadhali jaza Kodi ya Kanda</span>
                                        </div>

                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Jina la Kanda</label>
                                            <input type="text" id="customername-field" class="form-control" placeholder="Enter Name" required />
                                            <span style="color: red;display: none;" id="jazakanda">Tafadhali jaza jina la kanda</span>
                                        </div>

                                    </div>
                                    <div class="modal-footer">
                                        <div class="hstack gap-2 justify-content-end">
                                            <button type="button" class="btn btn-light" onclick="funga()" data-bs-dismiss="modal">Close</button>
                                            <button type="button" class="btn btn-success" onclick="saveKanda()" id="add-btn">Sajili</button>
                                            <!-- <button type="button" class="btn btn-success" id="edit-btn">Update</button> -->
                                        </div>
                                    </div>
                                </form>
                        </div>
                        </div>
                    </div>

                    <div class="modal fade" id="showEditModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-light p-3">
                                    <h5 class="modal-title" id="exampleModalLabel"></h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                                </div>
                                <form>
                                    <div class="alert alert-success shadow" role="alert" id="alertsuccess1" style="display: none;">
                                        <strong> Hongera! </strong> Kanda <b>iimesajiliwa</b> kikamilifu!
                                    </div>
                                    <div class="alert alert-danger shadow mb-xl-0" role="alert" id="alertexist1" style="display: none;">
                                        <strong> Imeshindwa Kusajili! </strong> Kanda <b>kilishasajiliwa</b> kwenye mfumo tayari!
                                     </div>
                                     <div class="alert alert-warning shadow shadow" role="alert" id="alertmtandao1" style="display: none;">
                                        <strong> Uh oh, kuna tatizo </strong> la <b>mtandao,</b> tafadhali jaribu tena badae!
                                    </div>
                                    <div class="modal-body">

                                        <div class="mb-3" id="modal-id">
                                            <label for="id-field" class="form-label">Kodi ya Kanda</label>
                                            <input type="text" id="code1-field" class="form-control" placeholder="ID"/>
                                            <input type="hidden" id="id1-field" class="form-control" placeholder="ID" />
                                            <span style="color: red;display: none;" id="editsimu">Tafadhali jaza Kodi ya Kanda</span>
                                        </div>

                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Jina la Kanda</label>
                                            <input type="text" id="customername1-field" class="form-control" placeholder="Enter Name" required />
                                            <span style="color: red;display: none;" id="editkanda">Tafadhali jaza jina la kanda</span>
                                        </div>
                                        <div class="mb-3">
                                            <label for="box1-field" class="form-label">Anuani ya Kanda (S.L.P)</label>
                                            <input type="number" id="box1-field" class="form-control" placeholder="Enter Address" required />
                                            <span style="color: red;display: none;" id="editbox">Tafadhali jaza anuani kanda</span>
                                        </div>
                                          <div class="mb-3 form-check form-check-success">
                                            <label for="status-field" class="form-check-label">
                                                <input type="checkbox" id="status-field" class="form-check-input"/> Ipo Active?
                                            </label>
                                            <span style="color: red;display: none;" id="editkanda">Tafadhali jaza jina la kanda</span>
                                        </div>

                                    </div>
                                    <div class="modal-footer">
                                        <div class="hstack gap-2 justify-content-end">
                                            <button type="button" class="btn btn-light" onclick="funga()" data-bs-dismiss="modal">Close</button>
                                            <!-- <button type="button" class="btn btn-success" onclick="saveKanda()" id="add-btn">Sajili</button> -->
                                            <button type="button" class="btn btn-success" onclick="updateKanda()" id="edit-btn">Update</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
<%- include('layouts/partials/footer.ejs' , {card_title :  card_title}) %>
<script type="text/javascript" src="/design/layouts/scripts/kanda_scripts.js"></script>
</body>
</html>