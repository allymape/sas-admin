    <script>
        $('a').click(function(){
            var trackingNumber = $(this).attr('data-id');
            var school_name = $(this).attr('data-name');
            var kumb_ujumbe = document.getElementById('kumb_ujumbe')
            var kumb_na = document.getElementById('cheo-field')
            var trackNo = document.getElementById('kumb-field')
            trackNo.value =trackingNumber
            kumb_ujumbe.textContent = "Weka Kumb Na. ya kibali cha " + school_name
        });
        function sajiliHati(){
            var na_kumb = document.getElementById('cheo-field').value;
            var trackingNo = document.getElementById('kumb-field').value;
            if(na_kumb.length <= 0){
                $("#jazasimu").show();
            }
            if(na_kumb.length > 0){
                $.ajax({
                    url: "/RecKumbNa",
                    type: 'POST',
                    data: JSON.stringify({"trackingNo": trackingNo, "na_kumb": na_kumb}),
                    contentType: 'application/json',
                    success: function(response) {
                        if(response.statusCode == 300){
                                $("#alertsuccess").show();
                            }if(response.statusCode == 306){
                                $("#alertexist").show();
                            }if(response.statusCode == 400 || response.statusCode == 500){
                                $("#alertmtandao").show();
                            }
                    //nata();
                    
                        // if(typeof(response) === "string"){response = JSON.parse(response)}
                    }
                });
            }
        }
    </script>

