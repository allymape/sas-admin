    <!-- Dashboard init -->
    <!-- <scri/../design./../views/assets/js/pages/dashboard-ecommerce.init.js"></script> -->
    <script type="text/javascript" src="/design/layouts/scripts/dashboard_scripts.js"></script>
    <script>
        (function () {
            var periodTabs = document.querySelectorAll("[data-registration-period-key]");
            if (!periodTabs.length) return;

            var getPaneRowsCount = function (tabElement) {
                var targetSelector = tabElement.getAttribute("href");
                if (!targetSelector) return 0;

                var pane = document.querySelector(targetSelector);
                if (!pane) return 0;

                var rows = pane.querySelectorAll("tbody tr");
                if (!rows.length) return 0;

                if (rows.length === 1 && rows[0].textContent.indexOf("Hakuna shule") !== -1) {
                    return 0;
                }

                return rows.length;
            };

            var debugTabClick = function (tabElement) {
                var payload = {
                    period_key: tabElement.getAttribute("data-registration-period-key") || "",
                    period_label: tabElement.getAttribute("data-registration-period-label") || "",
                    total_badge: Number(tabElement.getAttribute("data-registration-period-total") || 0),
                    rows_rendered: getPaneRowsCount(tabElement)
                };

                console.log("Registered schools period tab clicked:", payload);
            };

            periodTabs.forEach(function (tab) {
                tab.addEventListener("click", function () {
                    // Let Bootstrap activate the tab first so DOM state is up-to-date.
                    setTimeout(function () {
                        debugTabClick(tab);
                    }, 0);
                });
            });
        })();
    </script>
   
