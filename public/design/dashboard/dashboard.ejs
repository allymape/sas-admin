                                                        <i class="ri-star-fill"></i>
                                                        <i class="ri-star-fill"></i>
                                                        <i class="ri-star-fill"></i>
                                                        <i class="ri-star-fill"></i>
                                                    </div>
                                                </div>
                                                <div class="text-end mb-0 text-muted">
                                                    - zipo <cite title="Source Title"><%= ngazi[i].idadi %></cite>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <% } %>
                        </div>
                    </div>
