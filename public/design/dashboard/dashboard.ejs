<div class="row">
    <div class="col">
        <div class="h-100">
            <div class="row mb-3 pb-1">
                <div class="col-12">
                    <div class="d-flex align-items-lg-center flex-lg-row flex-column">
                        <div class="flex-grow-1">
                            <h4 class="fs-16 mb-1"><%= salamu %>, <%= name %> !</h4>
                            <p class="text-muted mb-0">Taarifa Fupi ya Uanzishaji na Usajili wa Shule.</p>
                        </div>
                        <div class="mt-3 mt-lg-0">
                            <form action="javascript:void(0);">
                                <% if(useLev == 11){ %>
                                <div class="row g-3 mb-0 align-items-center">
                                    <div class="col-sm-auto">
                                        <div class="input-group">
                                            <input type="text" class="form-control border-0 dash-filter-picker shadow" 
                                            placeholder="Weka Namba ya Ombi" id="scantrackno">
                                            <div class="input-group-text bg-primary border-primary text-white">
                                                <i class="ri-calendar-2-line"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" onclick="sajiliHati()" class="btn btn-soft-success">
                                            <i class="ri-add-circle-line align-middle me-1"></i> Tafuta</button>
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" onclick="lipia()" class="btn btn-soft-success">
                                            <i class="ri-add-circle-line align-middle me-1"></i> Lipia</button>
                                    </div>
                                    <script>
                                        function sajiliHati(){
                                            var scantrackno = document.getElementById('scantrackno').value;
                                            
                                            $.ajax({
                                                url: "/ScanTrackNo",
                                                type: 'POST',
                                                data: JSON.stringify({"trackno": scantrackno}),
                                                contentType: 'application/json',
                                                success: function(response) {
                                                // alert("imefanikiwa")
                                                $('#showModal').modal('show');
                                                var level = document.getElementById('cheo-field');
                                                level.value = response.message;
                                                }
                                            });
                                        }
                                        function lipia(){
                                            var scantrackno = document.getElementById('scantrackno').value;
                                            
                                            $.ajax({
                                                url: "/SimulatePayment",
                                                type: 'POST',
                                                data: JSON.stringify({"trackno": scantrackno}),
                                                contentType: 'application/json',
                                                success: function(response) {
                                                // alert("imefanikiwa")
                                                $('#showModal').modal('show');
                                                var level = document.getElementById('cheo-field');
                                                level.value = response.message;
                                                }
                                            });
                                        }
                                    </script>
                                </div>
                                <% } %>
                                <!--end row-->
                            </form>
                        </div>
                    </div><!-- end card header -->
                </div>
                <!--end col-->
            </div>
