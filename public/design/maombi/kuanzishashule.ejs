<% var card_title=''
   const status = req.query.status;
   const status_title = status == 'approved' ? 'Yaliyokubaliwa' : (status == 'rejected' ? 'Yaliyokataliwa' : 'Yanayosubiri')
%>
<%- include('../layouts/partials/header.ejs' , {
    title : 'Maombi Kuanzisha Shule',
    page_title : 'Maombi Kuanzisha Shule',
    card_title : 'Orodha ya Maombi ya kuanzisha shule '+status_title,
    breadcrumb_main : 'Maombi',
    top_header : '../../maombi/top_headers/maombi_top_header.ejs',
}) %>
<%- include('../maombi/top_headers/search.ejs' , {
    req : req,
    status : status
})
%>
<!--end card-body-->
<div class="card-body">
    <div class="table-responsive table-card mb-4">
        <table class="table align-middle table-nowrap mb-0" id="tasksTable">
            <thead class="table-light text-muted">
                <tr>
                    <th class="sort" data-sort="id">Namba ya Ombi</th>
                    <th class="sort" data-sort="project_name">Shule Pendekezwa</th>
                    <th class="sort" data-sort="tasks_name">Halmashauri</th>
                    <th class="sort" data-sort="assignedto">Mkoa</th>
                    <th class="sort" data-sort="due_date">Muda wa Ombi</th>
                    <th class="sort" data-sort="status">Hali</th>
                     <% if(status == 'approved'){ %>
                        <th class="text-center" id="barua-column" data-status="<%=status%>">Barua</th>
                    <% } %>
                </tr>
            </thead>
            <tbody class="list form-check-all">
            </tbody>
        </table>
    </div>
     <%- include('../paginations/ajax_pagination.ejs') %>
</div>
<%- include('../layouts/partials/footer.ejs' , {
     card_title :  '' ,
     pagination_script : false,
    }) %>
<script type="text/javascript" src="/design/layouts/scripts/anzishashule_scripts.js"></script>
</body>
</html>