<% var card_title=''
   const status = req.query.status;
   const status_title = status == 'approved' ? 'Yaliyokubaliwa' : (status == 'rejected' ? 'Yaliyokataliwa' : 'Yanayosubiri')
%>
<%- include('../layouts/partials/header.ejs' , {
    title : 'Kusajili Shule Zisizo Serikali',
    page_title : 'Kusajili Shule Zisizo Serikali',
    card_title : 'Orodha ya Maombi ya Kusajili Shule (Zisizo Serikali) '+status_title,
    breadcrumb_main : 'Maombi',
    top_header : '../../maombi/top_headers/maombi_top_header.ejs',
}) %>
<%- include('../maombi/top_headers/search.ejs' , {
    req : req,
    status : status
})
%>
<!--end card-body-->
<div class="card-body">
     <div class="ribbon-three ribbon-three-info">
        <span class="badge"><%=`${pagination.total}`%></span>
     </div>
    <div class="table-responsive table-card mb-4">
        <table class="table align-middle table-nowrap mb-0" id="tasksTable">
            <thead class="table-light text-muted">
                <tr>
                    
                    <th class="sort" data-sort="id">Namba ya Ombi</th>
                    <th class="sort" data-sort="project_name">Jina la Shule</th>
                    <% if(status == 'approved'){ %>
                    <th class="sort" data-sort="project_name">Namba ya Usajili</th>
                    <% } %>
                    <th class="sort" data-sort="tasks_name">Halmashauri</th>
                    <th class="sort" data-sort="assignedto">Mkoa</th>
                    <th class="sort" data-sort="due_date">Muda wa Ombi</th>
                    <th class="sort" data-sort="status">Hali</th>
                     <% if(status == 'approved'){ %>
                        <th class="text-center">Barua</th>
                     <% } %>
                    <!--<th class="sort" data-sort="priority">Walioshughulikia</th>-->
                </tr>
            </thead>
            <tbody class="list form-check-all">
                <% for(var i = 0; i < maombi.length; i++){ %>
                <tr>
                    
                    <td class="id"><a href="/SajiliOmbi/<%= maombi[i].tracking_number %>" class="fw-medium link-primary"><%= maombi[i].tracking_number %></a></td>
                    <td class="project_name"><a href="#" class="fw-medium link-primary"><%= maombi[i].school_name %></a></td>
                    <% if(status == 'approved'){ %>
                    <td><%=maombi[i].registration_number%></td>
                    <% } %>
                    <td>
                        <div class="d-flex">
                            <div class="flex-grow-1 tasks_name"><%= maombi[i].LgaName %></div>
                            <div class="flex-shrink-0 ms-4">
                                <ul class="list-inline tasks-list-menu mb-0">
                                    <li class="list-inline-item"><a href="/SajiliOmbi<%= maombi[i].tracking_number %>"><i class="ri-eye-fill align-bottom me-2 text-muted"></i></a></li>
                                </ul>
                            </div>
                        </div>
                    </td>
                    <td class="client_name"><%= maombi[i].RegionName %></td>
                    <td class="due_date text-secondary text-uppercase"  title=" <%= maombi[i].created_at %>"> <%= maombi[i].remain_days %></td>
                    <td class="is_approved">
                        <span class="badge <%= maombi[i].is_approved == 0 ?  'bg-warning' : '' %>
                            <%= maombi[i].is_approved == 1 ?  'bg-primary' : '' %>
                            <%= maombi[i].is_approved == 2 ?  'bg-success' : '' %>
                            <%= maombi[i].is_approved == 3 ?  'bg-danger' : '' %>"
                            >
                            <%= maombi[i].is_approved == 0 ?  'Jipya' : '' %>
                            <%= maombi[i].is_approved == 1 ?  'Linashughulikiwa' : '' %>
                            <%= maombi[i].is_approved == 2 ?  'Limekubaliwa' : '' %>
                            <%= maombi[i].is_approved == 3 ?  'Limekataliwa' : '' %>
                        </span>
                    </td>
                     <% if(status == 'approved' ){ %>
                        <td class="text-center">
                             <% if(maombi[i].folio){ %>
                                 <a target="_blank" title="Barua" data-bs-toggle="tooltip" href="/barua/<%= maombi[i].tracking_number %>">
                                        <i class="ri-file-pdf-fill ri-2x align-bottom me-1 text-danger"></i>
                                 </a>
                            <% } %>    
                        </td>
                    <% } %>
                </tr>
                <% } %>
            </tbody>
        </table>
        <!--end table-->
         <%- include('../paginations/html_pagination.ejs') %>
    </div>
    <div class="d-flex justify-content-end mt-2">
        <div class="pagination-wrap hstack gap-2">
            <a class="page-item pagination-prev disabled" href="#">
                Previous
            </a>
            <ul class="pagination listjs-pagination mb-0"></ul>
            <a class="page-item pagination-next" href="#">
                Next
            </a>
        </div>
    </div>
</div>
<!--end card-body-->
<%- include('../layouts/partials/footer.ejs' , {
     card_title :  '' , 
     pagination_script : true,
    }) %>
<!-- <script type="text/javascript" src="/design/layouts/scripts/anzishashule_scripts.js"></script> -->
</body>
</html>