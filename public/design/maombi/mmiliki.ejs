<% var card_title=''
   const status = req.query.status;
   const status_title = status == 'approved' ? 'Yaliyokubaliwa' : (status == 'rejected' ? 'Yaliyokataliwa' : 'Yanayosubiri')
%>
<%- include('../layouts/partials/header.ejs' , { 
        title : 'Kuthibitishwa kuwa Mmiliki/Meneja' , 
        page_title : 'Kuthibitishwa kuwa Mmiliki/Meneja' , 
        card_title : `Orodha ya Maombi ya Kuthibitishwa kuwa Mmiliki/Meneja wa shule ${status_title}` , 
        breadcrumb_main : 'Maombi' , 
        top_header : '../../maombi/top_headers/maombi_top_header.ejs' , }) 
%>
<%- include('../maombi/top_headers/search.ejs' , {
    req : req,
    status : status
})
%>
<!--end card-body-->
<div class="card-body">
  <div class="ribbon-three ribbon-three-info">
      <span class="badge"><%=`${pagination.total}`%></span>
   </div>
  <div class="table-responsive table-card mb-4">
    <table class="table align-middle table-nowrap mb-0" id="tasksTable">
      <thead class="table-light text-muted">
        <tr>
          <th class="sort" data-sort="id">Namba ya Ombi</th>
          <th class="sort" data-sort="project_name">Jina la Shule</th>
          <th class="sort" data-sort="tasks_name">Halmashauri</th>
          <th class="sort" data-sort="assignedto">Mkoa</th>
          <th class="sort" data-sort="due_date">Muda wa Ombi</th>
          <th class="sort" data-sort="status">Hali</th>
          <% if(status == 'approved'){ %>
          <th class="text-center">Barua</th>
          <% } %>
          <th></th>
        </tr>
      </thead>
      <tbody class="list form-check-all">
        <% for(var i=0; i < maombi.length; i++){ %>
        <% const ombi = maombi[i]; %>
        <tr>
          <td class="id">
            <a href="/ViewOmbiMmilliki/<%= ombi.tracking_number %>" 
            data-id="<%= ombi.tracking_number %>" class="fw-medium link-primary"><%=
                                            ombi.tracking_number %>
            </a>
           </td>
          <td class="project_name">
            <%= ombi.school_name %>
          </td>
          <td>
            <%= ombi.LgaName %>
          </td>
          <td class="client_name">
            <%= ombi.RegionName %>
          </td>
          <td class="due_date" title=" <%= ombi.created_at %>" data-bs-toggle="tooltip">
            <span class="badge bg-secondary"><%= ombi.remain_days %></span>
          </td>
          <td class="is_approved">
            <span class="badge <%= ombi.is_approved == 0 ?  'bg-warning' : '' %>
            <%= ombi.is_approved == 1 ?  'bg-primary' : '' %>
            <%= ombi.is_approved == 2 ?  'bg-success' : '' %>
            <%= ombi.is_approved == 3 ?  'bg-danger' : '' %>"
            >
            <%= ombi.is_approved == 0 ?  'Jipya' : '' %>
            <%= ombi.is_approved == 1 ?  'Linashughulikiwa' : '' %>
            <%= ombi.is_approved == 2 ?  'Limekubaliwa' : '' %>
            <%= ombi.is_approved == 3 ?  'Limekataliwa' : '' %>
            </span>
          </td>
          <% if(status == 'approved'){ %>
                    <td class="text-center">
                        <% if(ombi.folio){ %>
                            <a target="_blank" title="Barua Meneja" data-bs-toggle="tooltip" 
                            href="/barua/<%= ombi.tracking_number %>?type=meneja">
                                <i class="ri-file-pdf-line ri-2x align-bottom me-1 text-danger"></i>
                            </a>
                             <a target="_blank" class="ml-3" title="Barua Mmiliki" data-bs-toggle="tooltip" 
                            href="/barua/<%= ombi.tracking_number %>?type=mmiliki">
                                <i class="ri-file-pdf-fill ri-2x align-bottom me-1 text-danger"></i>
                            </a>
                        <% } %>
                   </td>
            <% } %>
          <td class="text-center">
            <a href="/ViewOmbiMmilliki/<%= ombi.tracking_number %>" class="btn btn-sm btn-outline-primary" >
              <i class="ri-eye-fill align-bottom me-1 text-muted"></i>
              Angalia
            </a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
    <!--end table-->
    
  </div>
    <%- include('../paginations/html_pagination.ejs') %>
</div>
<!--end card-body-->
<%- include('../layouts/partials/footer.ejs' , { card_title : '' , pagination_script : true, }) %>
<!-- <script type="text/javascript" src="/design/layouts/scripts/anzishashule_scripts.js"></script> -->
<script>
  $('a').click(function() {
    var trackingNumber = $(this).attr('data-id');

  });
</script>
</body>

</html>