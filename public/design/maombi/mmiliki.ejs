<% var card_title=''
   const status = req.query.status;
   const status_title = status == 'approved' ? 'Yaliyokubaliwa' : (status == 'rejected' ? 'Yaliyokataliwa' : 'Yanayosubiri')
%>
<%- include('../layouts/partials/header.ejs' , { 
        title : 'Kuthibitishwa kuwa Mmiliki/Meneja' , 
        page_title : 'Kuthibitishwa kuwa Mmiliki/Meneja' , 
        card_title : `Orodha ya Maombi ya Kuthibitishwa kuwa Mmiliki/Meneja wa shule ${status_title}` , 
        breadcrumb_main : 'Maombi' , 
        top_header : '../../maombi/top_headers/maombi_top_header.ejs' , }) 
%>
<div class="card-body border border-dashed border-end-0 border-start-0">
  <form>
    <div class="row g-3">
      <div class="col-xxl-5 col-sm-12">
        <div class="search-box">
          <input type="text" class="form-control search bg-light border-light" placeholder="Tafuta ombi kuendelea nalo...">
          <i class="ri-search-line search-icon"></i>
        </div>
      </div>
      <!--end col-->

      <div class="col-xxl-3 col-sm-4">
        <input type="date" class="form-control bg-light border-light" id="demo-datepicker" data-provider="flatpickr" data-date-format="d M, Y" data-range-date="true" placeholder="Chagua Tarehe ya Ombi">
      </div>
      <!--end col-->

      <div class="col-xxl-3 col-sm-4">
        <div class="input-light">
          <select class="form-control" data-choices data-choices-search-false name="choices-single-default" id="idStatus">
            <option value="">Status</option>
            <option value="all" selected>All</option>
            <option value="New">New</option>
            <option value="Pending">Pending</option>
            <option value="Inprogress">Inprogress</option>
            <option value="Completed">Completed</option>
          </select>
        </div>
      </div>
      <!--end col-->
      <div class="col-xxl-1 col-sm-4">
        <button title="Angalia kwa tarehe na Hali ulizochagua" type="button" class="btn btn-primary w-100" onclick="SearchData();"> <i class="ri-equalizer-fill me-1 align-bottom"></i>
          Angalia
        </button>
      </div>
      <!--end col-->
    </div>
    <!--end row-->
  </form>
</div>
<!--end card-body-->
<div class="card-body">
  <div class="ribbon-three ribbon-three-info">
      <span class="badge"><%=`${pagination.total}`%></span>
   </div>
  <div class="table-responsive table-card mb-4">
    <table class="table align-middle table-nowrap mb-0" id="tasksTable">
      <thead class="table-light text-muted">
        <tr>
          <th scope="col" style="width: 40px;">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="checkAll" value="option">
            </div>
          </th>
          <th class="sort" data-sort="id">Namba ya Ombi</th>
          <th class="sort" data-sort="project_name">Jina la Shule</th>
          <th class="sort" data-sort="tasks_name">Halmashauri</th>
          <th class="sort" data-sort="assignedto">Mkoa</th>
          <th class="sort" data-sort="due_date">Muda wa Ombi</th>
          <th class="sort" data-sort="status">Hali</th>
          <% if(status == 'approved'){ %>
          <th class="text-center">Barua</th>
          <% } %>
          <th></th>
        </tr>
      </thead>
      <tbody class="list form-check-all">
        <% for(var i=0; i < maombi.length; i++){ %>
        <% const ombi = maombi[i]; %>
        <tr>
          <th scope="row">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="chk_child" value="option1">
            </div>
          </th>
          <td class="id">
            <a href="/ViewOmbiMmilliki/<%= ombi.tracking_number %>" 
            data-id="<%= ombi.tracking_number %>" class="fw-medium link-primary">#<%=
                                            ombi.tracking_number %>
            </a>
           </td>
          <td class="project_name">
            <%= ombi.school_name %>
          </td>
          <td>
            <%= ombi.LgaName %>
          </td>
          <td class="client_name">
            <%= ombi.RegionName %>
          </td>
          <td class="due_date" title=" <%= ombi.created_at %>">
            <%= ombi.remain_days %>
          </td>
          <td class="is_approved">
            <%= ombi.is_approved == 0 || ombi.is_approved == 1 ? 'Jipya' : '' %>
            <%= ombi.is_approved == 2 ? 'Limekubaliwa' : '' %>
            <%= ombi.is_approved == 3 ? 'Limekataliwa' : '' %>
          </td>
          <% if(status == 'approved'){ %>
                    <td class="text-center">
                        <% if(ombi.folio){ %>
                            <a target="_blank" title="Barua Meneja" data-bs-toggle="tooltip" href="/barua/<%= ombi.tracking_number %>?type=<%=ombi.is_manager == 1 ? 'meneja' : 'mmiliki' %>">
                                <i class="ri-file-pdf-line ri-2x align-bottom me-1 text-danger"></i>
                            </a>
                        <% } %>
                   </td>
            <% } %>
          <td class="text-center">
            <a href="/ViewOmbiMmilliki/<%= ombi.tracking_number %>" class="btn btn-sm btn-outline-primary" >
              <i class="ri-eye-fill align-bottom me-1 text-muted"></i>
              Angalia
            </a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
    <!--end table-->
    
  </div>
    <%- include('../paginations/html_pagination.ejs') %>
</div>
<!--end card-body-->
<%- include('../layouts/partials/footer.ejs' , { card_title : '' , pagination_script : true, }) %>
<!-- <script type="text/javascript" src="/design/layouts/scripts/anzishashule_scripts.js"></script> -->
<script>
  $('a').click(function() {
    var trackingNumber = $(this).attr('data-id');

  });
</script>
</body>

</html>