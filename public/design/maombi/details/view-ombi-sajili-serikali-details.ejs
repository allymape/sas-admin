                    <input type="text" class="form-control bg-light border-light" id="newName" placeholder="Ingiza Jina...">
                    <!-- <i class="ri-search-line search-icon"></i> -->
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-danger w-xs" data-bs-dismiss="modal">Sitisha</button>
                <button type="button" onclick="changeName('usajili')" class="btn btn-success w-xs">
                    Badili Jina
