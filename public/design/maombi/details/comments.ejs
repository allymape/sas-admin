
 <% if(permission(req , "view-comments")){%>
 <div class="tab-pane" id="home-1" role="tabpanel">
   <!-- <h5 class="card-title">Maoni</h5> -->
     <div class="timeline-2">
        <div class="timeline-continue">
   <% for(var i = 0; i < Maoni.length; i++){ %>
    <% const {name , coments , created_at , rank_name} = Maoni[i]; %>
            <div class="row timeline-right">
                <div class="col-12" style="position: absolute;">
                    <div class="timeline-year">
                        <p class="shadow text-primary">
                            <b>M.<%= Maoni.length - i%></b>
                        </p>
                    </div>
                </div>
                <div class="col-12">
                    <div class="timeline-box shadow" style="margin: 5px 100px;">
                        <div class="timeline-text">
                            <h6><%= name %> (<%= rank_name %>) - <%= dateFormat(created_at , 'ddd DD/MM/YYYY HH:mm:ss') %></h6>
                            <p class="text-muted mb-0 text-justify"><%= coments %></p>
                        </div>
                    </div>
                </div>
            </div>
   <% } %>
      </div>
    </div>
   <% if(permission(req , "create-comments")){%>
      <% if(Maoni.length > 0){ %>
        <hr>
      <% } %>
   <%- include('includes/form_comment.ejs') %>
   <% } %>
 </div>
 <% } %>


