<form class="mt-4">
  <div class="row g-3">
    <div class="col-lg-12">
      <label for="exampleFormControlTextarea1" class="form-label">Andika Maoni</label>
      <textarea class="form-control bg-light border-light ckeditor-classic" id="exampleFormControlTextarea1" rows="3" placeholder="Andika maoni yako hapa.."></textarea>
    </div>
    <div class="col-lg-12">
      <label for="exampleFormControlTextarea1" class="form-label">Tuma kwa</label>
      <select class="js-example-basic-single form-control bg-light border-light" id="staffs" name="state">
        <option value="#">--Chagua--</option>
        <% for(var i=0; i < staffs.length; i++){ %>
        <option value="<%= staffs[i].userId %>-<%= staffs[i].roleId %>">
          <%= staffs[i].name %> (<%= staffs[i].role %>)
        </option>
        <% } %>
      </select>
    </div>
    <input type="hidden" value="<%= userLevel %>" id="userLevel" />
    <input type="hidden" value="0" id="gamechanger" />
    <div id="viambataDiv" class="viambataDiv" style="display: none;">
      <table id="emptbl">
        <tr>
          <th>Viambatisho</th>
          <th>Faili</th>
        </tr>
        <tr>
          <td id="col0">
            <select name="department" id="faili">
              <option value="#">Chagua Faili</option>
              <% for(var i=0; i < objAttachment.length; i++){ %>
              <option value="<%= objAttachment[i].registry_id %>">
                <%= objAttachment[i].attachment_name %>
              </option>
              <% } %>
            </select>
          </td>
          <td id="col1"><input type="file" name="empname" id="failiAttached" /></td>
        </tr>
      </table>
      <table>
        <tr>
          <!-- <td><input type="button" value="Add Row" onclick="addRows()" /></td>  -->
          <!-- <td><input type="button" value="Delete Row" onclick="deleteRows()" /></td>  -->
          <td>
            <button type="button" class="btn btn-danger btn-sm" onclick="Pandisha()">Pandisha</button>
          </td>
        </tr>
      </table>
    </div>

    <div class="col-12 text-start">
      <button type="button" onclick="showViambata()" class="btn btn-ghost-secondary btn-icon waves-effect me-1" title="ambatisha kiambatisho kwenye ombi hili"><i class="ri-attachment-line fs-16"></i></button>
      <button type="button" id="btn-tuma" onclick="tuma(`<%= commentUrl%>` , `<%= commentRedirectUrl %>`)" title="Unatuma ombi liendelee kushughulikiwa zaidi" class="btn btn-primary d-none">Tuma</button>

      <% if(userLevel=='w1' ||  userLevel=='adsa' || userLevel=='ke' ){ %>
        <button type="button" id="btn-wasilisha" onclick="wasilisha(`<%= commentUrl%>` , `<%= commentRedirectUrl %>`)" title="Kwa kubonyeza kifute hiki unalituma ombi hili kwenda ngazi ya juu kwa utekelezaji" class="btn btn-success">
            <%= userLevel == "ke" ? "Thibitisha" : "Wasilisha" %>
        </button>
        <% if(userLevel=='ke' ){ %>
        <button type="button" id="btn-kataa" onclick="kataa(`<%= commentUrl%>` , `<%= commentRedirectUrl %>`)" title="Kwa kubonyeza kifute hiki unakataa usajili wa shule hii" class="btn btn-danger">Kataa</button>
        <% } %>
         <button type="button" id="btn-rudisha" onclick="rudisha(`<%= commentUrl%>` , `<%= commentRedirectUrl %>`)" title="Kwa kubonyeza kifute hiki unalirudisha ombi kwa mwombaji" class="btn btn-info">Rudisha kwa
            Mwombaji
        </button>
      <% } %>
    </div>
  </div>
  <!--end row-->
</form>