<% var card_title=''
   const status = req.query.status;
   const status_title = status == 'approved' ? 'Yaliyokubaliwa' : (status == 'rejected' ? 'Yaliyokataliwa' : 'Yanayosubiri')
%>
<%- include('../layouts/partials/header.ejs' , {
    title : 'Kubadili Meneja',
    page_title : 'Kubadili Meneja',
    card_title : 'Orodha ya Maombi ya Kubadili Meneja wa shule '+status_title,
    breadcrumb_main : 'Maombi',
    top_header : '../../maombi/top_headers/maombi_top_header.ejs',
}) %>
  <div class="card-body border border-dashed border-end-0 border-start-0">
    <form>
        <div class="row g-3">
            <div class="col-xxl-5 col-sm-12">
                <div class="search-box">
                    <input type="text" class="form-control search bg-light border-light" placeholder="Tafuta ombi kuendelea nalo...">
                    <i class="ri-search-line search-icon"></i>
                </div>
            </div>
            <!--end col-->

            <div class="col-xxl-3 col-sm-4">
                <input type="date" class="form-control bg-light border-light" id="demo-datepicker" data-provider="flatpickr" data-date-format="d M, Y" data-range-date="true" placeholder="Chagua Tarehe ya Ombi">
            </div>
            <!--end col-->

            <div class="col-xxl-3 col-sm-4">
                <div class="input-light">
                    <select class="form-control" data-choices data-choices-search-false name="choices-single-default" id="idStatus">
                        <option value="">Status</option>
                        <option value="all" selected>All</option>
                        <option value="New">New</option>
                        <option value="Pending">Pending</option>
                        <option value="Inprogress">Inprogress</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
            </div>
            <!--end col-->
            <div class="col-xxl-1 col-sm-4">
                <button title="Angalia kwa tarehe na Hali ulizochagua" type="button" class="btn btn-primary w-100" onclick="SearchData();"> <i class="ri-equalizer-fill me-1 align-bottom"></i>
                    Angalia
                </button>
            </div>
            <!--end col-->
        </div>
        <!--end row-->
    </form>
</div>
<!--end card-body-->
<div class="card-body">
     <div class="ribbon-three ribbon-three-info">
        <span class="badge"><%=`${pagination.total}`%></span>
     </div>
    <div class="table-responsive table-card mb-4">
        <table class="table align-middle table-nowrap mb-0" id="tasksTable">
            <thead class="table-light text-muted">
                <tr>
                    <th  data-sort="id">Na.</th>
                    <th  data-sort="id">Namba ya Ombi</th>
                    <th  data-sort="tasks_name">Jina la Shule</th>
                    <th  data-sort="project_name">Mmiliki wa sasa</th>
                    <th  data-sort="project_name">Mmiliki Anayependekezwa</th>
                    <th  data-sort="status">Kata</th>
                    <th  data-sort="assignedto">Halmashauri</th>
                    <th  data-sort="due_date">Mkoa</th>
                    <th  data-sort="priority">Muda wa Ombi</th>
                     <% if(status == 'approved'){ %>
                      <th class="text-center">Barua</th>
                    <% } %>
                </tr>
            </thead>
            <tbody class="list form-check-all">
                <% for(var i = 0; i < maombi.length; i++){ %>
                <tr>
                   <td><%- include('../paginations/numbering.ejs' , {
                    index : i
                   }) %></td>
                    <td class="id">
                        <a href="/ViewOmbiMeneja/<%= maombi[i].tracking_number %>" data-id="<%= maombi[i].tracking_number %>" class="fw-medium link-primary">
                            <%= maombi[i].tracking_number %>
                        </a>
                    </td>
                     <td>
                        <div class="d-flex">
                            <div class="flex-grow-1 tasks_name"><%= maombi[i].school_name %></div>
                            <div class="flex-shrink-0 ms-4">
                                <ul class="list-inline tasks-list-menu mb-0">
                                    <li class="list-inline-item"><a href="/ViewOmbiMeneja/<%= maombi[i].tracking_number %>"><i class="ri-eye-fill align-bottom me-2 text-muted"></i></a></li>
                                </ul>
                            </div>
                        </div>
                    </td>
                    <td class="project_name"><%= maombi[i].former_manager_name %></td>
                    <td class="project_name"><%= maombi[i].new_manager_name %></td>
                   
                    <td class="priority"><span class="badge bg-danger text-uppercase"></span><%= maombi[i].WardName %></td>
                    <td class="client_name"><%= maombi[i].LgaName %></td>
                    <td> 
                        <%= maombi[i].RegionName %></td>
                    <td class="due_date"  title=" <%= maombi[i].created_at %>" data-bs-toggle="tooltip">
                        <span class="badge badge-soft-secondary text-uppercase"><%= remainDays(maombi[i].created_at) %></span>
                    </td>
                  <% if(status == 'approved' ){ %>
                        <td class="text-center">
                            <% if(maombi[i].folio){ %>
                                 <a target="_blank" title="Barua" data-bs-toggle="tooltip" href="/barua/<%= maombi[i].tracking_number %>">
                                        <i class="ri-file-pdf-fill ri-2x align-bottom me-1 text-danger"></i>
                                 </a>
                            <% } %>
                        </td>
                    <% } %>
                </tr>
                <% } %>
            </tbody>
        </table>
        <!--end table-->
      
    </div>
  <%- include('../paginations/html_pagination.ejs') %>
</div>
<!--end card-body-->
<%- include('../layouts/partials/footer.ejs' , {
     card_title :  '' , 
     pagination_script : true,
    }) %>
<!-- <script type="text/javascript" src="/design/layouts/scripts/anzishashule_scripts.js"></script> -->
</body>
</html>