<% var card_title = '' %>
<%- include('../layouts/partials/header.ejs' , {
    title : 'Shule',
    page_title : 'Orodha ya Shule',
    card_title : 'Badili Taarifa za Shule',
    breadcrumb_main : 'Mipangilio' 
}) %>
<div class="col-xl-12">
    <div class="card-body form-steps">
      <% var statusCode = req.flash('statusCode') %>
      <% var message = req.flash('message') %>
      <% if(statusCode != '' || message != ''){ %>
            <div class="alert alert-<%=statusCode == 300 ? 'success' : 'danger'%>"><%= message %></div>
        <% } %>
      <form action="/ShuleDetails/<%= school_info.tracking_number %>" method="POST">
        <div class="step-arrow-nav mb-4">
          <ul class="nav nav-pills custom-nav nav-justified" role="tablist">
            <%- include('./includes/buttons.ejs') %>
          </ul>
        </div>
        <div class="tab-content">
          <%- include('./includes/school_info.ejs') %>
          <!-- end tab pane -->
           <%- include('./includes/owner.ejs') %>
          <!-- end tab pane -->
           <%- include('./includes/manager.ejs') %>
          <!-- end tab pane -->
            <%- include('./includes/school_combinations.ejs') %>
          <!-- end tab pane -->
        </div>
        <!-- end tab content -->
         <div class="d-flex align-items-start gap-3 mt-4">
          <button type="button" id="btn-save-schoolinfo" class="btn btn-success btn-label right ms-auto nexttab nexttab" data-nexttab="steparrow-description-info-tab">
            <i class="ri-arrow-right-line label-icon align-middle fs-16 ms-2"></i>Save</button>
        </div>
      </form>
    </div>
    <!-- end card body -->
  </div>
  <!-- end card -->
<%- include('../layouts/partials/footer.ejs' , {card_title :  card_title}) %>
<%- include('../includes/locations' , {
  'location' : institute_info
}) %>
<script type="text/javascript" src="/design/layouts/scripts/shule_scripts.js"></script>
<script>
  $(function(){
       $('#btn-save-schoolinfo').on('click' ,function(e){
        e.preventDefault();
          confirmAction( (response) => {
            $(this).closest('form').submit()
          } , confirmBtnText = 'Yes' , icon='warning' , text = `Are you sure you want to save this changes!` , 
          title = 'Confirmation')
       })
      //  $("#combinations-input").select2()
  })
</script>
</body>

</html>