    <script>
        (function () {
            const $messages = $("#ai-messages");
            const $input = $("#ai-input");
            const $send = $("#ai-send-btn");
            const $reset = $("#ai-reset-btn");
            const $model = $("#ai-model");
            const $numPredict = $("#ai-num-predict");

            if (!$messages.length || !$input.length || !$send.length || !$reset.length) {
                return;
            }

            if (window.__sasAiSupportInitialized) {
                return;
            }
            window.__sasAiSupportInitialized = true;

            let isSending = false;
            let conversation = [
                {
                    role: "assistant",
                    content:
                        "Nipo tayari kukusaidia. Niambie tatizo au swali lako (unaweza pia kutaja tracking number kama EM-YYYYMMDD-123).",
                },
            ];

            const THINKING_MESSAGE = "AI Thinking...";
            const RESPONSE_DELAY_MS = 2000;

            const escapeHtml = (value) =>
                String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");

            const removeThinkingMessage = () => {
                conversation = conversation.filter(
                    (message) => !(message.role === "assistant" && message.content === THINKING_MESSAGE),
                );
            };

            const formatAiMessageContent = (content) => {
                if (String(content || "").trim() === THINKING_MESSAGE) {
                    return `
                        <span class="ai-thinking">
                            <span>AI Thinking</span>
                            <span class="ai-thinking__dots" aria-hidden="true">
                                <span class="ai-thinking__dot"></span>
                                <span class="ai-thinking__dot"></span>
                                <span class="ai-thinking__dot"></span>
                            </span>
                        </span>
                    `;
                }

                return String(content || "")
                    .split("\n")
                    .map((line) => {
                        const trimmed = String(line || "").trim();
                        const escapedLine = escapeHtml(line);

                        if (/^Overdue:\s*Ndiyo\b/i.test(trimmed)) {
                            return `<span class="fw-semibold" style="color: #dc3545;">${escapedLine}</span>`;
                        }

                        if (/^Overdue:\s*Hapana\b/i.test(trimmed)) {
                            return `<span class="fw-semibold" style="color: #198754;">${escapedLine}</span>`;
                        }

                        if (/^Ombi limekaa siku .* wakati muda wa hatua hii ni siku .*\.?$/i.test(trimmed)) {
                            return `<span class="fw-semibold" style="color: #dc3545;">${escapedLine}</span>`;
                        }

                        if (/^Ombi limekaa siku .* kati ya siku .* zinazokubalika\.?$/i.test(trimmed)) {
                            return `<span class="fw-semibold" style="color: #198754;">${escapedLine}</span>`;
                        }

                        return escapedLine;
                    })
                    .join("\n");
            };

            const renderAiTable = (table) => {
                const columns = Array.isArray(table?.columns) ? table.columns : [];
                const rows = Array.isArray(table?.rows) ? table.rows : [];
                if (!columns.length) return "";

                const headerHtml = columns
                    .map((column) => `<th>${escapeHtml(column?.label || "")}</th>`)
                    .join("");

                const bodyHtml = rows.length
                    ? rows
                          .map((row) => {
                              const cells = columns
                                  .map((column) => `<td>${escapeHtml(row?.[column.key] ?? "")}</td>`)
                                  .join("");
                              return `<tr>${cells}</tr>`;
                          })
                          .join("")
                    : `<tr><td colspan="${columns.length}" class="text-muted text-center">Hakuna data ya kuonyesha.</td></tr>`;

                return `
                    <div class="ai-message-table-wrap">
                        <table class="table table-sm table-striped align-middle ai-message-table">
                            <thead>
                                <tr>${headerHtml}</tr>
                            </thead>
                            <tbody>
                                ${bodyHtml}
                            </tbody>
                        </table>
                    </div>
                `;
            };

            const renderAiSummaryList = (items) => {
                const rows = Array.isArray(items) ? items : [];
                if (!rows.length) return "";

                const itemsHtml = rows
                    .map((item) => {
                        const title = escapeHtml(item?.title || "");
                        const body = formatAiMessageContent(item?.body || "");
                        const href = escapeHtml(item?.href || "/TrackOmbi");
                        const actionLabel = escapeHtml(item?.action_label || "Fungua");
                        const hasTitle = Boolean(String(item?.title || "").trim());
                        const hasBody = Boolean(String(item?.body || "").trim());
                        const isLinkOnly =
                            hasTitle &&
                            !hasBody &&
                            String(item?.title || "").trim() === String(item?.action_label || "").trim();

                        return `
                            <div class="ai-message-summary-item">
                                ${!isLinkOnly && hasTitle ? `<div class="ai-message-summary-title">${title}</div>` : ""}
                                ${hasBody ? `<div class="ai-message-summary-body">${body}</div>` : ""}
                                <a href="${href}" class="ai-message-summary-link link-primary">
                                    <i class="ri-external-link-line"></i>
                                    <span>${actionLabel}</span>
                                </a>
                            </div>
                        `;
                    })
                    .join("");

                return `<div class="ai-message-summary-list">${itemsHtml}</div>`;
            };

            const renderAiSupport = () => {
                $messages.empty();
                conversation.forEach((m, index) => {
                    const isUser = m.role === "user";
                    const roleLabel = "";
                    const badge = isUser
                        ? '<span class="badge bg-primary-subtle text-primary d-inline-flex align-items-center gap-1" style="font-size: 0.95rem; padding: 0.5rem 0.75rem;"><i class="ri-user-line" style="font-size: 1rem;"></i><span>Me</span></span>'
                        : '<span class="badge bg-success-subtle text-success d-inline-flex align-items-center gap-1" style="font-size: 0.95rem; padding: 0.5rem 0.75rem;"><i class="ri-robot-line" style="font-size: 1rem;"></i><span>Msaidizi</span></span>';
                    const wrapper = $(`
                        <div class="mb-2">
                          <div class="d-flex align-items-center gap-2 mb-1">
                            ${badge}
                            ${roleLabel ? `<span class="text-muted small">${escapeHtml(roleLabel)}</span>` : ""}
                            <button type="button" class="btn btn-ghost-secondary btn-sm ms-auto ai-copy-btn" data-message-index="${index}">
                              Copy
                            </button>
                          </div>
                          <pre class="mb-0 p-3 rounded" style="white-space: pre-wrap; background: var(--vz-card-bg); border: 1px solid var(--vz-border-color); font-size: 1rem; line-height: 1.65;">${formatAiMessageContent(m.content)}</pre>
                          ${m.summary_list ? renderAiSummaryList(m.summary_list) : ""}
                          ${m.table ? renderAiTable(m.table) : ""}
                        </div>
                    `);
                    $messages.append(wrapper);
                });
                $messages.scrollTop($messages.prop("scrollHeight"));
            };

            const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

            const sendAiSupportMessage = async () => {
                const text = String($input.val() || "").trim();
                if (!text || isSending) return;

                isSending = true;
                conversation.push({ role: "user", content: text });
                removeThinkingMessage();
                conversation.push({ role: "assistant", content: THINKING_MESSAGE });
                renderAiSupport();
                $input.val("");
                $send.prop("disabled", true);
                $reset.prop("disabled", true);
                $input.prop("disabled", true);

                try {
                    const payloadMessages = conversation.filter(
                        (message) => !(message.role === "assistant" && message.content === THINKING_MESSAGE),
                    );
                    const payload = {
                        messages: payloadMessages,
                        model: String($model.val() || "").trim(),
                        num_predict: Number($numPredict.val() || 256),
                    };
                    const res = await fetch("/AISupportChat", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    });
                    const json = await res.json();
                    const statusCode = Number(json?.statusCode || 306);
                    await wait(RESPONSE_DELAY_MS);
                    removeThinkingMessage();
                    if (statusCode !== 300 || !json?.data?.reply) {
                        conversation.push({
                            role: "assistant",
                            content: json?.message || "Imeshindikana kupata majibu ya AI. Hakikisha Ollama ina-run.",
                        });
                        renderAiSupport();
                        return;
                    }

                    conversation.push({
                        role: "assistant",
                        content: String(json.data.reply || "").trim(),
                        summary_list: json?.data?.summary_list || null,
                        table: json?.data?.table || null,
                    });
                    renderAiSupport();
                } catch (error) {
                    removeThinkingMessage();
                    conversation.push({
                        role: "assistant",
                        content: "Imeshindikana kuwasiliana na AI. Hakikisha Ollama ina-run kwenye mashine yako.",
                    });
                    renderAiSupport();
                } finally {
                    isSending = false;
                    $send.prop("disabled", false);
                    $reset.prop("disabled", false);
                    $input.prop("disabled", false);
                    $input.focus();
                }
            };

            $send.on("click", sendAiSupportMessage);
            $input.on("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    sendAiSupportMessage();
                }
            });

            $reset.on("click", () => {
                if (isSending) return;
                conversation = [
                    {
                        role: "assistant",
                        content:
                            "Nipo tayari kukusaidia. Niambie tatizo lako la mfumo, error unayoiona, au taja tracking number husika.",
                    },
                ];
                renderAiSupport();
                $input.focus();
            });

            $messages.on("click", ".ai-copy-btn", async function () {
                const index = Number($(this).data("message-index"));
                const message = conversation[index];
                const content = String(message?.content || "").trim();
                if (!content) return;

                try {
                    await navigator.clipboard.writeText(content);
                    const $button = $(this);
                    const originalText = $button.text();
                    $button.text("Copied");
                    setTimeout(() => $button.text(originalText), 1200);
                } catch (error) {
                    window.prompt("Copy message:", content);
                }
            });

            renderAiSupport();
        })();
    </script>

    <%
      const flashSuccess = typeof req?.flash === 'function' ? req.flash('success') : [];
      const flashWarning = typeof req?.flash === 'function' ? req.flash('warning') : [];
      const flashError = typeof req?.flash === 'function' ? req.flash('error') : [];
      const queryToastMessage = String(req?.query?.toast_message || '').trim();
      const queryToastType = String(req?.query?.toast_type || 'warning').trim() || 'warning';

      let globalToastMessage = '';
      let globalToastType = 'warning';

      if (queryToastMessage) {
        globalToastMessage = queryToastMessage;
        globalToastType = queryToastType;
      } else if (Array.isArray(flashError) && flashError.length > 0) {
        globalToastMessage = String(flashError[0] || '').trim();
        globalToastType = 'danger';
      } else if (Array.isArray(flashWarning) && flashWarning.length > 0) {
        globalToastMessage = String(flashWarning[0] || '').trim();
        globalToastType = 'warning';
      } else if (Array.isArray(flashSuccess) && flashSuccess.length > 0) {
        globalToastMessage = String(flashSuccess[0] || '').trim();
        globalToastType = 'success';
      }

      const globalToastClassName = globalToastType === 'error' ? 'danger' : globalToastType || 'warning';
    %>
    <% if (globalToastMessage) { %>
    <style>
      .toastify.toastify-right.toastify-top {
        margin-top: 70px;
      }
    </style>
    <% } %>

    <script>
        showLoadingSpinner()
        window.onload = () => {
           hideLoadingSpinner()
        }
        window.addEventListener("load", function () {
            if (typeof Toastify === "function" && <%= JSON.stringify(Boolean(globalToastMessage)) %>) {
                Toastify({
                    text: <%- JSON.stringify(globalToastMessage) %>,
                    gravity: "top",
                    position: "right",
                    className: "bg-<%= globalToastClassName %>",
                    duration: 4000,
                    close: true,
                    stopOnFocus: true
                }).showToast();
            }
        });

	        // Global handler for opening letters in a modal instead of a new tab
	        (function(){
	            const modalEl = document.getElementById("globalPdfModal");
	            const titleEl = document.getElementById("globalPdfModalTitle");
	            const frameEl = document.getElementById("globalPdfFrame");
	            const loadingEl = document.getElementById("globalPdfLoading");

	            const getBootstrap = () => {
	                try {
	                    return window.bootstrap || (typeof bootstrap !== "undefined" ? bootstrap : null);
	                } catch (e) {
	                    return window.bootstrap || null;
	                }
	            };

	            const getModalCtor = () => {
	                const bs = getBootstrap();
	                return bs && typeof bs.Modal === "function" ? bs.Modal : null;
	            };

	            let modalInstance = null;
	            let fallbackBackdrop = null;

	            const showFallback = () => {
	                if (!modalEl) return;
	                modalEl.classList.add("show");
	                modalEl.style.display = "block";
	                modalEl.removeAttribute("aria-hidden");
	                document.body.classList.add("modal-open");

	                if (!fallbackBackdrop) {
	                    fallbackBackdrop = document.createElement("div");
	                    fallbackBackdrop.className = "modal-backdrop fade show";
	                    document.body.appendChild(fallbackBackdrop);
	                }
	            };

	            const hideFallback = () => {
	                if (!modalEl) return;
	                modalEl.classList.remove("show");
	                modalEl.style.display = "none";
	                modalEl.setAttribute("aria-hidden", "true");
	                document.body.classList.remove("modal-open");
	                if (fallbackBackdrop && fallbackBackdrop.parentNode) {
	                    fallbackBackdrop.parentNode.removeChild(fallbackBackdrop);
	                }
	                fallbackBackdrop = null;
	            };

	            const setLoading = (isLoading) => {
	                if (!loadingEl) return;
	                loadingEl.classList.toggle("d-none", !isLoading);
	            };

	            window.openPdfModal = (url, options = {}) => {
	                const safeUrl = String(url || "").trim();
	                if (!safeUrl) return;

	                if (!modalEl || !frameEl) {
	                    window.location.assign(safeUrl);
	                    return;
	                }

	                const ModalCtor = getModalCtor();
	                if (ModalCtor && !modalInstance) {
	                    try {
	                        modalInstance = new ModalCtor(modalEl, { backdrop: "static", keyboard: true });
	                    } catch (e) {
	                        modalInstance = null;
	                    }
	                }

	                if (titleEl) {
	                    const title = String(options.title || "Barua").trim() || "Barua";
	                    titleEl.textContent = title;
	                }

	                setLoading(true);
	                frameEl.src = safeUrl;
	                if (modalInstance) {
	                    modalInstance.show();
	                } else {
	                    showFallback();
	                }
	            };

	            if (frameEl) {
	                frameEl.addEventListener("load", function(){
	                    setLoading(false);
	                });
	            }

	            if (modalEl) {
	                modalEl.addEventListener("hidden.bs.modal", function(){
	                    if (frameEl) frameEl.src = "about:blank";
	                    setLoading(true);
	                });

	                // Fallback close button support when Bootstrap isn't available.
	                const closeBtn = modalEl.querySelector ? modalEl.querySelector('[data-bs-dismiss="modal"], .btn-close') : null;
	                if (closeBtn) {
	                    closeBtn.addEventListener("click", function(){
	                        if (modalInstance) return;
	                        hideFallback();
	                        if (frameEl) frameEl.src = "about:blank";
	                        setLoading(true);
	                    });
	                }
	            }

	            // Close fallback on ESC
	            document.addEventListener("keydown", function(e){
	                if (modalInstance) return;
	                if (!modalEl) return;
	                if (!modalEl.classList.contains("show")) return;
	                const key = e && (e.key || e.code);
	                if (key === "Escape" || key === "Esc") {
	                    hideFallback();
	                    if (frameEl) frameEl.src = "about:blank";
	                    setLoading(true);
	                }
	            });

            const isLetterHref = (href) => {
                const value = String(href || "").trim().toLowerCase();
                return value.startsWith("/barua/");
            };

            const handleLetterClick = (event, anchor) => {
                if (!event || event.defaultPrevented) return;
                if (!anchor) return;
                if (anchor.getAttribute("data-no-pdf-modal") === "1") return;
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

                const href = String(anchor.getAttribute("href") || "").trim();
                if (!isLetterHref(href)) return;

                // Ensure no "new tab" behaviour even if some markup has target=_blank.
                if (anchor.getAttribute("target") === "_blank") {
                    anchor.removeAttribute("target");
                    anchor.removeAttribute("rel");
                }

                event.preventDefault();
                event.stopPropagation();
