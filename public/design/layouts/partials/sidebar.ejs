<!-- Vertical Overlay-->
<div class="vertical-overlay">
    <div class="modal fade" id="showModal1" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-light p-3">
                    <h5 class="modal-title" id="exampleModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                </div>
                <form>
                    <div class="alert alert-success shadow" role="alert" id="alertsuccessmwox" style="display: none;">
                        <strong> Hongera! </strong> Nywira <b>imebadilishwa</b> kikamilifu!
                    </div>
                    <div class="alert alert-danger shadow mb-xl-0" role="alert" id="alertexistmwox" style="display: none;">
                        <strong> Imeshindwa kubadili! </strong> Nywira <b>tafadhali</b> jaribu tena baadae!
                        </div>
                        <div class="alert alert-warning shadow shadow" role="alert" id="alertmtandaomwox" style="display: none;">
                        <strong> Uh oh, kuna tatizo </strong> la <b>mtandao,</b> tafadhali jaribu tena badae!
                    </div>
                    <div class="modal-body">

                        <div class="mb-3" id="modal-id" style="display: none;">
                            <label for="id-field" class="form-label">ID</label>
                            <input type="text" id="idi-field" class="form-control" placeholder="ID" readonly />
                        </div>

                        <div class="mb-3">
                            <label for="customername-field" class="form-label">Nywira ya Sasa</label>
                            <input type="hidden" id="id-fieldmwox" class="form-control" />
                            <input type="password" id="old-pass-field" class="form-control" required />
                            <span style="color: red;display: none;" id="jazasimu">Tafadhali jaza Cheo</span>
                            <input type="hidden" id="strengthhiddenmwox" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label for="customername-field" class="form-label">Nywira ya Mpya</label>
                            <input type="password" id="new-pass-field" class="form-control" onkeyup="return passwordChanged();" required />
                            <span style="color: red;display: none;" id="jazasimumwox">Tafadhali jaza Cheo</span>
                            <span id="strengthmwox">Type Password</span>
                        </div>
                        <div class="mb-3">
                            <label for="customername-field" class="form-label">Thibitisha Nywira ya Mpya</label>
                            <input type="password" id="re-pass-field" class="form-control" required />
                            <span style="color: red;display: none;" id="jazasimumwox">Tafadhali jaza Cheo</span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="hstack gap-2 justify-content-end">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                            <div id="sajilbtn">
                                <button type="button" class="btn btn-success" onclick="badliPass()" id="add-btn">Badili</button>
                                </div>
                                <div id="pakiabtn" style="display: none;">
                                    <button type="button" class="btn btn-success btn-load">
                                        <span class="d-flex align-items-center">
                                            <span class="spinner-border flex-shrink-0" role="status">
                                                <span class="visually-hidden">Tafadhali subiri...</span>
                                            </span>
                                            <span class="flex-grow-1 ms-2">
                                                Tafadhali subiri...
                                            </span>
                                        </span>
                                    </button>
                                </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
