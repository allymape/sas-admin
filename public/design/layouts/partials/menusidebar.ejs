%>
<div id="scrollbar">
    <div class="container-fluid">
        <div id="two-column-menu">
        </div>
        <ul class="navbar-nav" id="navbar-nav">
            <li class="menu-title"><span data-key="t-menu">Menu</span></li>

            <% menuItems.forEach( function(item) { 
                if(item.menuTitle){
                    %>
                     <li class="menu-title"><i class="ri-more-fill"></i> <span data-key="t-components"><%= item.menuTitle %></span></li>
                    <%
                }
                if(typeof item.subMenus !== 'undefined' && item.subMenus.length > 0 )
                {
                    %>
                    <li class="nav-item">
                        <a class="nav-link menu-link" 
                            href="<%= item.menuId ? item.url : '/'+item.url %>" 
                            data-bs-toggle="collapse" 
                            role="button" aria-expanded="false" 
                            aria-controls="<%= item.menuId %>"
                        >
                            <i class="<%= item.icon %>"></i> 
                            <span data-key="t-dashboards"><%= item.label %></span>
                        </a>
                         <div class="collapse menu-dropdown
                            <%= routeIs(pluck(item.subMenus , 'pattern').join("|") , getCurrentUrl(req)) ? 'show' : '' %>
                            " 
                            id="<%= item.menuId %>"
                          >
                                <ul class="nav nav-sm flex-column">
                                     <% item.subMenus.forEach( function(subItem) { %>
                                         <li class="nav-item">
                                            <a href="/<%= subItem.url %>" 
                                                class="nav-link <%= routeIs(subItem.pattern , getCurrentUrl(req)) ? 'active' : '' %>" 
                                                data-key="t-analytics">
                                                  <%= subItem.label %>
                                                  <% if(subItem.counterId ){%>
                                                        <span class="badge badge-pill bg-danger" id="<%=subItem.counterId%>" data-key="t-new"></span> 
                                                    <% } %>
                                                </a>
                                         </li>
                                     <% }) %>
                                </ul>
                         </div>
                    </li>
                    <%
                }else{
                    %>
                    <li class="nav-item">
                        <a href="<%= item.url %>" 
                            class="nav-link menu-link <%= routeIs( item.patten , getCurrentUrl(req)) ? 'active' : '' %>"
                         >
                            <i class="ri <%=item.icon%>"></i> 
                            <span data-key="t-widgets"><%=item.label%></span>
                        </a>
                    </li>
                    <% 
                }
            }) 
           %>           
    </div>
</div>
