<% var card_title = '' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Ngazi',
    page_title : 'Orodha ya Ngazi',
    card_title : 'Ngazi zilizopo',
    breadcrumb_main : 'Mipangilio' 
}) %>
  <div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-3">
            <div class="col-sm-auto">
                <div>
                    <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn"><i class="ri-add-line align-bottom me-1"></i> Sajili</button>
                    <!-- <button class="btn btn-soft-danger" onClick="deleteMultiple()"><i class="ri-delete-bin-2-line"></i></button> -->
                </div>
            </div>
            <div class="col-sm">
                <div class="d-flex justify-content-sm-end">
                    <div class="search-box ms-2">
                        <input type="text" class="form-control search" placeholder="Tafuta...">
                        <i class="ri-search-line search-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive table-card mt-3 mb-1">
            <table class="table align-middle table-nowrap" id="ngaziTable">
                <thead class="table-light">
                    <tr>
                        <th width="5%">Na.</th>
                        <th width="5%">Systen ID.</th>
                        <th>Jina la Ngazi</th>
                        <th>Hali</th>
                        <th class="text-center" width="10%"  data-sort="action">Action</th>
                    </tr>
                </thead>
                <tbody class="list form-check-all">
                </tbody>
            </table>
            <div class="noresult" style="display: none">
                <div class="text-center">
                    <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                    <h5 class="mt-2">Sorry! No Result Found</h5>
                    <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
                </div>
            </div>
        </div>
        <%- include('paginations/ajax_pagination.ejs') %>
    </div>
    </div><!-- end card -->

    <div class="modal fade" id="showModal-create" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                        <div class="modal-header bg-light p-3">
                            <h5 class="modal-title" id="exampleModalLabel">Tengeneza</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                        </div>
                    <form>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="rank-field" class="form-label">Jina la Ngazi</label>
                            <input type="text" id="rank-field" class="form-control" placeholder="Enter Name" required />
                            <span style="color: red;display: none;" id="jazakanda">Tafadhali jaza jina la kanda</span>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <div class="hstack gap-2 justify-content-end">
                            <button type="button" class="btn btn-light"  data-bs-dismiss="modal">Close</button>
                            <button type="button" class="btn btn-success" onclick="saveNgazi()" id="add-btn">Sajili</button>
                            <!-- <button type="button" class="btn btn-success" id="edit-btn">Update</button> -->
                        </div>
                    </div>
                </form>
        </div>
        </div>
    </div>
    <div class="modal fade" id="showEditModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-light p-3">
                    <h5 class="modal-title" id="exampleModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                </div>
                <form>
                     <input type="hidden" id="field-id"/>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="rank-field" class="form-label">Jina la Ngazi</label>
                            <input type="text" id="rank1-field" class="form-control" placeholder="Enter Name" required />
                            <span style="color: red;display: none;" id="editkanda">Tafadhali jaza jina la kanda</span>
                        </div>
                        <div class="mb-3 form-check form-check-success">
                            <label for="status-field" class="form-check-label">
                                <input type="checkbox" id="status-field" class="form-check-input"/> Ipo Active?
                            </label>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <div class="hstack gap-2 justify-content-end">
                            <button type="button" class="btn btn-light"  data-bs-dismiss="modal">Close</button>
                            <!-- <button type="button" class="btn btn-success" onclick="saveNgazi()" id="add-btn">Sajili</button> -->
                            <button type="button" class="btn btn-success" onclick="updateNgazi()" id="edit-btn">Update</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

                 
<%- include('layouts/partials/footer.ejs' , {card_title :  card_title}) %>
<script type="text/javascript" src="/design/layouts/scripts/ngazi_scripts.js"></script>
</body>
</html>