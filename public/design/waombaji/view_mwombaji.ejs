<div class="row">
  <div class="col-md-12">
    <div>
      <div class="d-flex">
        <!-- Nav tabs -->
        <ul class="nav nav-pills animation-nav profile-nav gap-2 gap-lg-3 flex-grow-1" role="tablist">
          <li class="nav-item">
            <a class="nav-link fs-14 <%= typeof req.query.tab == 'undefined' || req.query.tab == 'overview' ? 'active' : '' %>" data-bs-toggle="tab" href="#overview" role="tab">
              <i class="ri-airplay-fill d-inline-block d-md-none"></i> <span class="d-none d-md-inline-block">Overview</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link fs-14 <%=  req.query.tab == 'schools' ? 'active' : '' %>" data-bs-toggle="tab" href="#schools" role="tab">
              <i class="ri-list-unordered d-inline-block d-md-none"></i> <span class="d-none d-md-inline-block">Schools</span>
            </a>
          </li>
          <!-- <li class="nav-item">
            <a class="nav-link fs-14 <%=  req.query.tab == 'documents' ? 'active' : '' %>" data-bs-toggle="tab" href="#documents" role="tab">
              <i class="ri-folder-4-line d-inline-block d-md-none"></i> <span class="d-none d-md-inline-block">Documents</span>
            </a>
          </li> -->
        </ul>
        <div class="flex-shrink-0">
          <a href="/Mwombaji/<%=applicant[0].id%>/badili" class="btn btn-success">
            <i class="ri-edit-box-line align-bottom"></i> Edit Profile</a>
        </div>
      </div>
      <!-- Tab panes -->
      <div class="tab-content pt-4 text-muted">
        <div class="tab-pane <%= typeof req.query.tab == 'undefined' || req.query.tab == 'overview' ? 'active' : 'fade' %>" id="overview" role="tabpanel">
          <div class="row">
            <div class="col-xxl-3">
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-1">Profile</h5>
                  <div class="progress animated-progress custom-progress progress-label">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 100%" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100">
                      <div class="label">100%</div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-2">Info</h5>
                  <div class="table-responsive">
                    <table class="table table-borderless mb-0">
                      <tbody>
                        <tr>
                          <th class="ps-0" scope="row">Name :</th>
                          <td class="text-muted"><%= nameCase(applicant[0].name) %></td>
                        </tr>
                        <!-- <tr>
                          <th class="ps-0" scope="row">Mobile :</th>
                          <td class="text-muted">+(1) 987 6543</td>
                        </tr> -->
                        <tr>
                          <th class="ps-0" scope="row">Email :</th>
                          <td class="text-muted"><%= applicant[0].email %></td>
                        </tr>
                        <!-- <tr>
                          <th class="ps-0" scope="row">Location :</th>
                          <td class="text-muted">California, United States
                          </td>
                        </tr> -->
                        <tr>
                          <th class="ps-0" scope="row">Joining</th>
                          <td class="text-muted"><%= applicant[0].created_at %></td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div><!-- end card body -->
              </div><!-- end card -->

            </div>
            <!--end col-->
            <div class="col-xxl-9">
              <div class="row">
                <div class="col-md-12">
                  <div class="card ribbon-box right">
                    <div class="card-header align-items-center d-flex">
                      <h4 class="card-title mb-0  me-2">Recent Activity</h4>
                    </div>
                    <div class="card-body">
                        <div class="ribbon-three ribbon-three-info">
                          <span class="badge"><%=`${numberFormat(applications_pagination.total)}`%></span>
                        </div>
                      <div class="tab-content text-muted">
                        <div class="tab-pane active" id="today" role="tabpanel">
                          <div class="profile-timeline">
                            <div class="accordion accordion-flush" id="todayExample">
                               
                                <% for (let i = 0; i < applications.length; i++) { %>
                                <div class="accordion-item border-0">
                                <div class="accordion-header" id="">
                                  <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseFour" aria-expanded="true">
                                    <div class="d-flex">
                                      <div class="flex-shrink-0 avatar-xs">
                                        <div class="avatar-title bg-light text-muted rounded-circle shadow">
                                          <i class="ri-user-3-fill"></i>
                                        </div>
                                      </div>
                                      <div class="flex-grow-1 ms-3">
                                        <h6 class="fs-14 mb-1">
                                           <%=applications[i].application_category%>
                                          on
                                          <%=applications[i].created_at%>
                                          <% var is_approved = applications[i].is_approved%>
                                          <span
                                          class=" badge badge-label <%= is_approved == 2 ? 'bg-success' : (is_approved == 1 ? 'bg-info' : is_approved == 0 ? 'bg-danger' : '') %>"
                                          >
                                           <i class=" <%= is_approved == 2 ? 'mdi mdi-check-all' : (is_approved == 1 ? 'mdi mdi-circle-medium' : is_approved == 0 ? 'ri ri-close-line' : '') %>"></i> 
                                           <%= is_approved == 2 ? 'Approved' : (is_approved == 1 ? 'Not Approved' : is_approved == 0 ? 'Draft' : 'Unknown') %></span>
                                        </h6>
                                          <div class="d-flex justify-content-between">
                                            <small class="text-muted">
                                            Tranking Number : <%=applications[i].tracking_number %>
                                            </small>
                                            <span class="badge badge-soft-dark badge-border"><%=applications[i].cheo%></span>
                                          </div>
                                      </div>
                                    </div>
                                  </a>
                                </div>
                                
                                <div id="collapseFour" class="accordion-collapse collapse show" aria-labelledby="headingFour" data-bs-parent="#accordionExample">
                                  <div class="accordion-body ms-2 ps-5 fst-italic">
                                    
                                  </div>
                                </div>
                              </div>
                                <% } %>
                                <%- include('../paginations/html_pagination.ejs' , {
                                    pagination : applications_pagination,
                                    tab : req.query.tab
                                }) %>
                            </div>
                            <!--end accordion-->
                          </div>
                        </div>
                      </div>
                    </div><!-- end card body -->
                  </div><!-- end card -->
                </div><!-- end col -->
              </div><!-- end row -->
            </div>
            <!--end col-->
          </div>
          <!--end row-->
        </div>
        <div class="tab-pane <%=  req.query.tab == 'schools' ? 'active' : 'fade' %>" id="schools" role="tabpanel">
          <div class="card ribbon-box right">
            <div class="card-body">
              <div class="ribbon-three ribbon-three-success">
                          <span class="badge"><%=`${numberFormat(schools_pagination.total)}`%></span>
              </div>
              <h5 class="card-title mb-3">Shule</h5>
              <div class="col-md-12">
                <div class="table-responsive"></div>
                <table class="table table-striped" id="datatable">
                  <thead>
                    <tr>
                      <th>Na.</th>
                      <th>Namba ya Kumb.</th>
                      <th>Name</th>
                      <th>Namba ya Usajili</th>
                      <th>Aina</th>
                      <th>Tarehe Usajili</th>
                      <th>Mkoa</th>
                      <th>Halmashauri</th>
                      <th>Kata</th>
                      <th>Mtaa</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                  </tbody>
                </table>
              </div>
              </div>
            </div>
            <!--end card-body-->
          </div>
          <!--end card-->
        </div>
        <!--end tab-pane-->

        <!-- Modal -->
        <!-- Varying modal content -->
<div class="modal fade" id="varyingcontentModal" tabindex="-1" aria-labelledby="varyingcontentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="ribbon-three ribbon-three-info">
                          <span class="badge">Transfer</span>
                        </div>
            <div class="modal-header">
                <!-- <h5 class="modal-title" id="varyingcontentModalLabel">New message</h5> -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                
                <form>
                    <div class="mb-3">
                        <label for="message-text" class="col-form-label">School Name</label>
                         <input type="text"  class="form-control" id="school-name" readonly disabled/>
                    </div>
                    <div class="mb-3">
                        <label for="message-text" class="col-form-label">Tracking Number</label>
                         <input type="text"  class="form-control" id="tracking-number" readonly disabled />
                    </div>
                    <div class="mb-3">
                        <label for="message-text" class="col-form-label">Registration Number</label>
                         <input type="text"  class="form-control" id="registration-number" readonly disabled />
                    </div>
                     <div class="mb-3">
                        <label for="applicant-name" class="col-form-label">New Applicant:</label>
                        <select  class="form-control" id="applicant-name"></select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Ghairi na Funga</button>
                <button type="button" class="btn btn-primary" disabled id="btn-update-applicant">Badili</button>
            </div>
        </div>
    </div>
  </div>
        <!-- End Modal -->
 
        <!--end tab-pane-->
        <div class="tab-pane <%=  req.query.tab == 'documents' ? 'active' : 'fade' %>" id="documents" role="tabpanel">
          <div class="card ribbon-box right">
            <div class="card-body">
              <div class="ribbon-three ribbon-three-info">
                          <span class="badge"><%=`${numberFormat(attachments_pagination.total)}`%></span>
                </div>
              <div class="d-flex align-items-center mb-4">
                <h5 class="card-title flex-grow-1 mb-0">Documents</h5>
                <!-- <div class="flex-shrink-0">
                  <input class="form-control d-none" type="file" id="formFile">
                  <label for="formFile" class="btn btn-danger"><i class="ri-upload-2-fill me-1 align-bottom"></i> Upload
                    File</label>
                </div> -->
              </div>
              <div class="row">
                <div class="col-md-12">
                  <div class="table-responsive">
                    <table class="table table-borderless mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Na.</th>
                          <th>Nyaraka</th>
                          <th>Aina</th>
                          <th>Namba ya Kumb.</th>
                          <th></th>
                          <th>Tarehe ya Kupandishwa</th>
                          <th class="text-right"></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% for (let index = 0; index < attachments.length; index++) { const item = attachments[index]; %>
                          <tr>
                            <td>
                              <%- include('../paginations/numbering.ejs' , {
                                index : index,
                                pagination : attachments_pagination,
                              }) %>
                            </td>
                             <td>
                            <div class="d-flex align-items-center">
                              <div class="avatar-xxs">
                                <div class="avatar-title bg-soft-danger text-danger rounded fs-15 shadow">
                                  <i class="ri-file-pdf-fill"></i>
                                </div>
                              </div>
                              <div class="ms-3 flex-grow-1">
                                <h6 class="fs-15 mb-0">
                                  <a href="javascript:void(0);"><%= item.name %></a></h6>
                              </div>
                            </div>
                          </td>
                          <td>PDF</td>
                          <td><%= item.tracking_number %></td>
                          <td><%= item.application_category_name %></td>
                          <td><%= item.created_at %></td>
                          <td class="right">
                            <div class="dropdown">
                              <a href="javascript:void(0);" class="btn btn-light btn-icon" id="dropdownMenuLink15" data-bs-toggle="dropdown" aria-expanded="true">
                                <i class="ri-equalizer-fill"></i>
                              </a>
                              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuLink15">
                                <li><a class="dropdown-item" href="javascript:void(0);"><i class="ri-eye-fill me-2 align-middle text-muted"></i>View</a>
                                </li>
                                <li><a class="dropdown-item" href="javascript:void(0);"><i class="ri-download-2-fill me-2 align-middle text-muted"></i>Download</a>
                                </li>
                              </ul>
                            </div>
                          </td>
                        </tr>
                          
                        <% } %>
                      </tbody>
                    </table>
                    <%- include('../paginations/html_pagination.ejs' , {
                      pagination : attachments_pagination,
                      tab : req.query.tab
                    }) %>
                  </div>
                  <!-- <div class="text-center mt-3">
                    <a href="javascript:void(0);" class="text-success "><i class="mdi mdi-loading mdi-spin fs-20 align-middle me-2"></i>
                      Load more </a>
                  </div> -->
                </div>
              </div>
            </div>
          </div>
        </div>
        <!--end tab-pane-->
      </div>
      <!--end tab-content-->
    </div>
  </div>
  <!--end col-->
</div>
<!--end row-->


<!-- container-fluid -->
<%- include('../layouts/partials/footer.ejs' , {
card_title :  card_title , 
pagination_script : false,
scripts : [
          {src : '/design/layouts/scripts/waombaji_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
        ]
}) %>
<script>
    $(document).ready(function() {
        tableData('datatable' , '/ApplicantSchools/<%=applicant_id%>' , 'POST',
            [
                    { data: null, render : (data , type , row , meta) => {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    } },
                    { data: "tracking_number", name: "tracking_number" },
                     { data: "name", name: "name" },
                    { data: "reg_number", name: "reg_number" },
                    { data: "type", name: "type" },
                    { data: "registration_date", name: "registration_date" ,  render: (data , type , row) => {
                        return data ? changeOnlyDateFormat(data) : ''
                    }},
                    { data: "region", name: "region" },
                    { data: "district", name: "district" },
                    { data: "ward", name: "ward" },
                    { data: "village", name: "village" },
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                          return `<div class="dropdown">
                              <a href="javascript:void(0);" class="btn btn-light btn-icon" id="dropdownMenuLink15" data-bs-toggle="dropdown" aria-expanded="true">
                                <i class="ri-equalizer-fill"></i>
                              </a>
                              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuLink15">
                                <li>
                                   <a class="dropdown-item transfer-school"
                                    href="javascript:void(0);"
                                    data-tracking_number="${row.tracking_number}"
                                    data-school_name="${row.name}"
                                    data-registration_number="${row.reg_number }"
                                    data-current_applicant_email="<%= applicant[0].email %>"
                                    >
                                    <i class="ri-file-transfer-line me-2 align-middle text-muted"></i>
                                    Transfer
                                  </a>
                                </li>
                              </ul>
                            </div>`;
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    class : 'text-center'
                    },
            ],
        );
    });
</script>
<!-- <script type="text/javascript" src="../design/layouts/scripts/waombaji_scripts.js"></script> -->
</body>

</html>