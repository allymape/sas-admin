        <div class="main-content">

            <div class="page-content">
                <div class="container-fluid">

                    <!-- start page title -->
                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Malipo</h4>

                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="javascript: void(0);">Mipangilio</a></li>
                                        <li class="breadcrumb-item active">Ada za Malipo</li>
                                    </ol>
                                </div>

                            </div>
                        </div>
                    </div>
                    <!-- end page title -->

                    <div class="row">
                        <div class="col-lg-12">
                            <div class="card">
                                <div class="card-header">
                                    <h4 class="card-title mb-0">Orodha ya Ada za Malipo</h4>
                                </div><!-- end card header -->

                                <div class="card-body">
                                    <div id="customerList">
                                        <div class="row g-4 mb-3">
                                            <div class="col-sm-auto">
                                                <div>
                                                    <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn" data-bs-target="#showModal"><i class="ri-add-line align-bottom me-1"></i> Sajili</button>
                                                    <!-- <button class="btn btn-soft-danger" onClick="deleteMultiple()"><i class="ri-delete-bin-2-line"></i></button> -->
                                                </div>
                                            </div>
                                            <div class="col-sm">
                                                <div class="d-flex justify-content-sm-end">
                                                    <div class="search-box ms-2">
                                                        <input type="text" class="form-control search" placeholder="Tafuta...">
                                                        <i class="ri-search-line search-icon"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="table-responsive table-card mt-3 mb-1">
                                            <table class="table align-middle table-nowrap" id="customerTable">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th width="5%">
                                                           Na.
                                                        </th>
                                                        <th class="sort" data-sort="customer_name">#</th>
                                                        <!-- <th class="sort" data-sort="email">Jina</th> -->
                                                        <th class="sort" data-sort="email">Aina ya Malipo</th>
                                                        <th class="sort" data-sort="email">Kiasi</th>
                                                        <th class="sort text-center" width="15%" data-sort="action">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="list form-check-all">
                                                    <% for(var i = 0; i < data.length; i++){ %>
                                                    <tr>
                                                        <td scope="row">
                                                            <%=(i+1)%>
                                                        </td>
                                                        <td class="id"><a href="javascript:void(0);" class="fw-medium link-primary">#<%= data[i].feeCode %></a></td>
                                                        <td class="phone"><%= data[i].Fee %></td>
                                                        <td class="phone"><%= data[i].Kiasi %></td>

                                                        <td>
                                                            <div class="d-flex gap-2">
                                                                <!-- <div class="edit"> -->
                                                                    <button class="btn btn-sm btn-link btn-sm text-primary"
                                                                    onclick="AddZone1(this); return false;" data-fee_id="<%= data[i].fee_id %>" 
                                                                    data-id="<%= data[i].feeCode %>" data-name="<%= data[i].Fee %>" 
                                                                    data-amount="<%= data[i].Kiasi %>" ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-edit-3"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                                                                <!-- </div> -->
                                                                <button type="button" class="btn btn-link btn-sm text-danger" 
                                                                data-bs-toggle="modal" data-id="<%= data[i].fee_id %>" 
                                                                id="create-btn" 
                                                                onclick="deleteMalipo(this); return false;"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-trash-2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg></button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
