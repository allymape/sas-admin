    <script>
        function AddZone1(e){
            var code = e.getAttribute('data-id');
            var name = e.getAttribute('data-name');
            var amount = e.getAttribute('data-amount');
            var fee_id = e.getAttribute('data-fee_id');
            document.getElementById("ada-field-edit").value = name;
            document.getElementById("code-field-edit").value = code;
            document.getElementById("kiasi-field-edit").value = amount;
            document.getElementById("id-field-edit").value = fee_id;
            $('#showModal_edit').modal('show');
        }
        function editHati(){
            var ada = document.getElementById('ada-field-edit').value;
            var kiasi = document.getElementById('kiasi-field-edit').value;
            var code = document.getElementById('code-field-edit').value;
            var fee_id = document.getElementById("id-field-edit").value;
            if(ada.length <= 0){
                $("#jazada1").show();
            }
            if(code.length <= 0){
                $("#jazacode1").show();
            }
            if(kiasi.length <= 0){
                $("#jazakiasi1").show();
            }
            if(ada.length > 0 && code.length > 0 && kiasi.length > 0){
                $.ajax({
                    url: "/EditAda",
                    type: 'POST',
                    data: JSON.stringify({"ada": ada, "code": code, "kiasi": kiasi, "fee_id": fee_id}),
                    contentType: 'application/json',
                    success: function(response) {
                        if(response.statusCode == 300){
                            $("#alertsuccess1").show();
                        }if(response.statusCode == 306){
                            $("#alertexist1").show();
                        }if(response.statusCode == 400 || response.statusCode == 500){
                            $("#alertmtandao1").show();
                        }
                    }
                });
            }
        }
    </script>
