                    <div class="modal fade" id="showModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-light p-3">
                                    <h5 class="modal-title" id="exampleModalLabel"></h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                                </div>
                                <form>
                                    <div class="alert alert-success shadow" role="alert" id="alertsuccess" style="display: none;">
                                        <strong> Hongera! </strong> Malipo <b>yamesajiliwa</b> kikamilifu!
                                    </div>
                                    <div class="alert alert-danger shadow mb-xl-0" role="alert" id="alertexist" style="display: none;">
                                        <strong> Imeshindwa Kusajili! </strong> Malipo <b>yalishasajiliwa</b> kwenye mfumo tayari!
                                     </div>
                                     <div class="alert alert-warning shadow shadow" role="alert" id="alertmtandao" style="display: none;">
                                        <strong> Uh oh, kuna tatizo </strong> la <b>mtandao,</b> tafadhali jaribu tena badae!
                                    </div>
                                    <div class="modal-body">

                                        <div class="mb-3" id="modal-id" style="display: none;">
                                            <label for="id-field" class="form-label">ID</label>
                                            <input type="text" id="id-field" class="form-control" placeholder="ID" readonly />
                                        </div>

                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Jina la Ada</label>
                                            <input type="text" id="ada-field" class="form-control" placeholder="Mfano: Ada ya usajili" required />
                                            <span style="color: red;display: none;" id="jazada">Tafadhali jaza Jina la Ada</span>
                                        </div>
                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Code ya Ada</label>
                                            <input type="text" id="code-field" class="form-control" placeholder="Mfano: RF01" required />
                                            <span style="color: red;display: none;" id="jazacode">Tafadhali jaza Code ya Ada</span>
                                        </div>
                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Kiasi (Tshs)</label>
                                            <input type="text" id="kiasi-field" class="form-control" placeholder="Mfano: 1000" required />
                                            <span style="color: red;display: none;" id="jazakiasi">Tafadhali jaza Kiasi</span>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <div class="hstack gap-2 justify-content-end">
                                            <button type="button" class="btn btn-light" onclick="funga()" data-bs-dismiss="modal">Funga</button>
                                            <button type="button" class="btn btn-success" onclick="sajiliHati()" id="add-btn">Rekodi</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    
                    <div class="modal fade" id="showModal_edit" tabindex="-1" aria-labelledby="exampleModalLabel1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-light p-3">
                                    <h5 class="modal-title" id="exampleModalLabel1"></h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
                                </div>
                                <form>
                                    <div class="alert alert-success shadow" role="alert" id="alertsuccess1" style="display: none;">
                                        <strong> Hongera! </strong> Malipo <b>imebadilishwa</b> kikamilifu!
                                    </div>
                                    <div class="alert alert-danger shadow mb-xl-0" role="alert" id="alertexist1" style="display: none;">
                                        <strong> Imeshindwa Kubadilisha! </strong> Malipo <b>yalishasajiliwa</b> kwenye mfumo tayari!
                                     </div>
                                     <div class="alert alert-warning shadow shadow" role="alert" id="alertmtandao1" style="display: none;">
                                        <strong> Uh oh, kuna tatizo </strong> la <b>mtandao,</b> tafadhali jaribu tena badae!
                                    </div>
                                    <div class="modal-body">

                                        <div class="mb-3" id="modal-id1" style="display: none;">
                                            <label for="id-field" class="form-label">ID</label>
                                            <input type="text" id="id-field-edit" class="form-control" placeholder="ID" readonly />
                                        </div>

                                        <div class="mb-3">
                                            <label for="customername-field1" class="form-label">Jina la Ada</label>
                                            <input type="text" id="ada-field-edit" class="form-control" required />
                                            <span style="color: red;display: none;" id="jazada1">Tafadhali jaza Jina la Ada</span>
                                        </div>
                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Code ya Ada</label>
                                            <input type="text" id="code-field-edit" class="form-control" required />
                                            <span style="color: red;display: none;" id="jazacode1">Tafadhali jaza Code ya Ada</span>
                                        </div>
                                        <div class="mb-3">
                                            <label for="customername-field" class="form-label">Kiasi (Tshs)</label>
                                            <input type="text" id="kiasi-field-edit" class="form-control" required />
                                            <span style="color: red;display: none;" id="jazakiasi1">Tafadhali jaza Kiasi</span>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <div class="hstack gap-2 justify-content-end">
                                            <button type="button" class="btn btn-light" onclick="funga()" data-bs-dismiss="modal">Funga</button>
                                            <button type="button" class="btn btn-success" onclick="editHati()" id="add-btn"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-edit-3"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <script>
                        function sajiliHati(){
                            var ada = document.getElementById('ada-field').value;
                            var kiasi = document.getElementById('kiasi-field').value;
                            var code = document.getElementById('code-field').value;
                            if(ada.length <= 0){
                                $("#jazada").show();
                            }
                            if(code.length <= 0){
                                $("#jazacode").show();
                            }
                            if(kiasi.length <= 0){
                                $("#jazakiasi").show();
                            }
                            if(ada.length > 0 && code.length > 0 && kiasi.length > 0){
                                $.ajax({
                                    url: "/SajiliAda",
                                    type: 'POST',
                                    data: JSON.stringify({"ada": ada, "code": code, "kiasi": kiasi}),
                                    contentType: 'application/json',
                                    success: function(response) {
                                        if(response.statusCode == 300){
                                                $("#alertsuccess").show();
                                            }if(response.statusCode == 306){
                                                $("#alertexist").show();
                                            }if(response.statusCode == 400 || response.statusCode == 500){
                                                $("#alertmtandao").show();
                                            }
                                    //nata();
                                    
                                        // if(typeof(response) === "string"){response = JSON.parse(response)}
                                    }
                                });
                            }
                        }
                        function funga(){
                            window.location.href = "/Malipo"
                        }
                    </script>
                    <script>
                        function vyeoLocation(){
                            var vcheo = document.getElementById("status-field").value;
                            var cheo_rank = vcheo.split(" - ");
                            var location = cheo_rank[0];
                            // alert("location")
                        }
                        function deleteMalipo(e){
                            var nameId = e.getAttribute('data-id');
                            document.getElementById("feeid-field-edit").value = nameId;
                            // var kanda = document.getElementById("ada-field").value;
                            $('#deleteRecordModal').modal('show');
                        }
                        function futaHati(){
                            var malipoId = document.getElementById('feeid-field-edit').value;
                            
                                $.ajax({
                                    url: "/FutaMalipo",
                                    type: 'POST',
                                    data: JSON.stringify({"malipoId": malipoId}),
                                    contentType: 'application/json',
                                    success: function(response) {
                                        alert("Ada ya Malipo imefutwa kikamilifu")
                                    $('#deleteRecordModal').modal('hide');
                                    window.location.href = "/Malipo"
                                    }
                                });

                        }
                    </script>
                    <!-- Modal -->
                    <div class="modal fade zoomIn" id="deleteRecordModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="btn-close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mt-2 text-center">
                                        <lord-icon src="https://cdn.lordicon.com/gsqxdxog.json" trigger="loop" colors="primary:#f7b84b,secondary:#f06548" style="width:100px;height:100px"></lord-icon>
                                        <div class="mt-4 pt-2 fs-15 mx-4 mx-sm-5">
                                            <h4>Are you Sure ?</h4>
                                            <p class="text-muted mx-4 mb-0">Are you Sure You want to Remove this Record ?</p>
                                            <input type="hidden" id="feeid-field-edit" class="form-control"/>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 justify-content-center mt-4 mb-2">
                                        <button type="button" class="btn w-sm btn-light" data-bs-dismiss="modal">Close</button>
                                        <button type="button" class="btn w-sm btn-danger " onclick="futaHati()" id="delete-record">Yes, Delete It!</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!--end modal -->

                </div>
                <!-- container-fluid -->
            </div>
            <!-- End Page-content -->

            <footer class="footer">
