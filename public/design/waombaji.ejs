<% var card_title = '' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Waombaji',
    page_title : 'Orodha ya Waombaji',
    card_title : 'Waombaji Waliopo',
    breadcrumb_main : 'Mipangilio' 
}) %>
<div class="card-body">
    <div class="ribbon-three ribbon-three-info">
        <span class="badge"><%=`${pagination.total}`%></span>
    </div>
<div id="applicantsList">
    <div class="row g-4 mb-3">
        <!-- <div class="col-sm-auto">
            <div>
                <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn" data-bs-target="#showModal">
                    <i class="ri-add-line align-bottom me-1"></i> Sajili</button>
                <button class="btn btn-soft-danger" onClick="deleteMultiple()"><i class="ri-delete-bin-2-line"></i></button>
            </div>
        </div> -->
        <div class="col-sm">
            <div class="d-flex justify-content-sm-end">
                <div class="search-box ms-2 d-flex">
                   <form action="" method="/Waombaji">
                     <input type="text" name="tafuta" 
                     value="<%= req.query.tafuta ? req.query.tafuta : ''%>"
                     class="form-control search" placeholder="Tafuta...">
                    <i class="ri-search-line search-icon"></i>
                   </form>
                   <% if(req.query.tafuta){ %> 
                    <a href="/Waombaji" class="btn btn-link">
                        <i class="ri-delete-back-2-line text-danger"></i>
                   </a>
                   <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive table-card mt-3 mb-1">
        <table class="table align-middle table-nowrap" id="customerTable">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Jina</th>
                    <th>Barua Pepe</th>
                    <th>Imetengezwa</th>
                    <th>Imesasishwa</th>
                    <th>Maombi</th>
                    <th class="text-right"></th>
                </tr>
            </thead>
            <tbody class="list form-check-all">
                <% for(var i = 0; i < applicants.length; i++){ %>
                    <tr>
                        <td class="id">
                             <%- include('paginations/numbering.ejs' , {
                                index : i
                             }) %>
                        </td>
                        <td class="name">
                            <%= nameCase(applicants[i].name) %>
                        </td>
                        <td class="email"><%= applicants[i].email %></td>
                        <td class="date"><%= applicants[i].created_at %></td>
                        <td class="date"><%= applicants[i].updated_at %></td>
                        <td class="text-right">
                            <span class="badge badge-label bg-<%=applicants[i].total_applications > 0 ? 'success' : 'danger'%>">
                                <%= numberFormat(applicants[i].total_applications) %>
                            </span>
                        </td>
                        <td class="text-center">
                                <div class="dropdown">
                                    <a href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="ri-more-2-fill"></i>
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                                        <li><a class="dropdown-item" href="/Mwombaji/<%=applicants[i].id%>">View</a></li>
                                        <li><a class="dropdown-item" href="/Mwombaji/<%=applicants[i].id%>/badili">Edit</a></li>
                                        <li><a class="dropdown-item" href="#">Delete</a></li>
                                    </ul>
                                </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
        <div class="noresult" style="display: none">
            <div class="text-center">
                <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                <h5 class="mt-2">Sorry! No Result Found</h5>
                <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
            </div>
        </div>
    </div>
    <%- include('paginations/html_pagination.ejs') %>
</div>
</div><!-- end card -->
<%- include('layouts/partials/footer.ejs' , {
     card_title :  card_title , 
     pagination_script : false,
    }) %>
<script type="text/javascript" src="design/layouts/scripts/waombaji_scripts.js"></script>
</body>
</html>