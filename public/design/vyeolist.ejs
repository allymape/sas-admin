<div class="modal fade" id="showModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title" id="exampleModalLabel">Tengeneza</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="name-field" class="form-label">Jina la Cheo</label>
                        <input type="text" id="name-field" class="form-control" placeholder="Mfano: USJ2" required />
                        <span style="color: red;display: none;" id="jazasimu">Tafadhali jaza Cheo</span>
                    </div>
                    <div class="mb-3">
                        <label for="description-field" class="form-label">Kirefu</label>
                        <input type="text" id="description-field" class="form-control" placeholder="Mfano: Usajili"  />
                        <span style="color: red;display: none;" id="description">Tafadhali jaza kirefu</span>
                    </div>
                    <div>
                        <label for="uongozi-field" class="form-label">Ngazi ya Uongozi</label>
                        <select class="form-control" data-trigger name="uongozi-field" id="uongozi-field">
                            <option value="#"> Chagua </option>
                            <% for(var i = 0; i < levels.length; i++){ %>
                                <option value="<%= levels[i].id %>"><%= levels[i].name %></option>
                            <% } %>
                        </select>
                        <span style="color: red;display: none;" id="jazacheo">Tafadhali Chagua User Level</span>
                    </div>
              
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" class="btn btn-success" onclick="sajiliHati()">Sajili</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="showEditModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title" id="exampleModalLabel">Badili</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="close-modal"></button>
            </div>
            <form>
                <div class="modal-body">

                    <div class="mb-3" id="modal-id" style="display: none;">
                        <input type="hidden" id="id-field" class="form-control" placeholder="ID" readonly />
                    </div>

                    <div class="mb-3">
                        <label for="name2-field" class="form-label">Jina la Cheo</label>
                        <input type="text" class="form-control" name="name2-field" id="name2-field" placeholder="Mfano: USJ2" required />
                    </div>
                    <div class="mb-3">
                        <label for="description2-field" class="form-label">Kirefu</label>
                        <input type="text" id="description2-field" class="form-control" placeholder="Mfano: Usajili"  />
                    </div>
                    <div>
                        <label for="uongozi2-field" class="form-label">Ngazi ya Uongozi</label>
                        <select class="form-control" name="uongozi2-field" id="uongozi2-field">
                            <option value="# - 0"> Chagua </option>
                            <% for(var i = 0; i < levels.length; i++){ %>
                                <option value="<%= levels[i].id %>"><%= levels[i].name %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="mt-3 form-check form-check-success">
                        <label for="status-field" class="form-check-label">
                            <input type="checkbox" id="status-field" class="form-check-input"/> Ipo Active?
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" class="btn btn-success" onclick="sasishaHati()" id="add-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewrole="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-edit-3"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/vyeo_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    $(document).ready(function() {
        tableData('datatable' ,'/VyeoList' , 'POST',
            [
                    { data: null, // No data source for this column
                        render: function (data, type, row , meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { data: "name", name: "name" },
                    { data: "description", name: "description" },
                    { data: "role", name: "role" },
                    {
                      data: "created_at", name: "created_at",
                            render: (data, type, row) => {
                                if(data ){
                                    return changeDateFormat(data);
                                }
                                return data;
                            },
                    },
                    {
                    data: "updated_at", name: "updated_at",
                            render: (data, type, row) => {
                                if(data ){
                                    return changeDateFormat(data);
                                }
                                return data
                            },
                    },
                      { data: "status", render : (data , type, row) => {
                        return data == 1 ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-danger">Deleted</span>';
                    }},
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                        const elements = [
                                            {
                                                show : true,
                                                type : 'link',
                                                class : 'btn btn-sm btn-outline-primary me-1',
                                                icon : 'bx bx-pencil me-1',
                                                function : 'BadiliData',
                                                btnText : 'Edit'
                                            },
                                        ]
                        return actionButtons(row , elements);
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    searchable: false, // Disable searching for the action buttons column,
                    },
            ]
        );
    });
</script>
