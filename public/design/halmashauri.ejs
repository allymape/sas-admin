<% var card_title = '' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Halmashauri',
    page_title : 'Orodha ya Halmashauri',
    card_title : 'Halmashauri zilizopo iliyopo',
    breadcrumb_main : 'Mipangilio' 
}) %>
 <div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-3">
            <div class="col-sm-auto">
                <div>
                    <!-- <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn" onclick="PullRegions()"><i class="ri-add-line align-bottom me-1"></i> Vuta Halmashauri</button> -->
                    <div class="alert alert-danger shadow mb-xl-0" id="alertmeshindwa" role="alert" style="display: none;">
                        <strong> Imeshindiwa kupakia! </strong> Hakuna<b>Halmashauri</b> mipya ya kupakia. Ahsante!
                        </div>
                        <div class="alert alert-success shadow" id="alertmefanikiwa" role="alert" style="display: none;">
                        <strong> Hongera! Imefanikiwa! </strong> Halmashauri mpya <b>zimepakiwa</b> kikamilifu!
                    </div>
                    <div id="firstbtn">
                        <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn"><i class="ri-add-line align-bottom me-1"></i> Vuta Halmashauri</button>
                    </div>
                    <div id="pakiabtn" style="display: none;">
                        <button type="button" class="btn btn-success btn-load">
                            <span class="d-flex align-items-center">
                                <span class="spinner-border flex-shrink-0" role="status">
                                    <span class="visually-hidden">Inapakia...</span>
                                </span>
                                <span class="flex-grow-1 ms-2">
                                    Inapakia...
                                </span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-sm">
                <div class="d-flex justify-content-sm-end">
                    <div class="search-box ms-2">
                        <input type="text" class="form-control search" placeholder="Tafuta...">
                        <i class="ri-search-line search-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive table-card mt-3 mb-1">
            <table class="table align-middle table-nowrap" id="districtTable">
                <thead class="table-light">
                    <tr>
                        <th class="" width="5%" >Na.</th>
                        <th class="" >Jina la Halmashauri</th>
                        <th >Kodi ya Halmashauri</th>
                        <th >Mkoa</th>
                        <th >Imeingizwa</th>
                        <th >Imesasishwa</th>
                        <!-- <th class="sort" data-sort="action">Action</th> -->
                    </tr>
                </thead>
                <tbody class="list form-check-all">

                </tbody>
            </table>
            <div class="noresult" style="display: none">
                <div class="text-center">
                    <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                    <h5 class="mt-2">Sorry! No Result Found</h5>
                    <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
                </div>
            </div>
        </div>
        <%- include('paginations/ajax_pagination.ejs')%>
    </div>
</div><!-- end card -->
<%- include('layouts/partials/footer.ejs' , {card_title :  card_title}) %>
<script type="text/javascript" src="design/layouts/scripts/halmashauri_scripts.js"></script>
</body>
</html>