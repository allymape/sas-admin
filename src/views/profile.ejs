<% var card_title = '' %>
<% const { officeName = '', kanda = '' } = req.session || {}; %>
<% const isActiveAccount = Number(user?.user_status || 0) === 1; %>
<% const resolvedRoleName = user?.role_name || req.user?.cheo || '-'; %>
<% const canUsernameEdit = typeof canEditUsername !== 'undefined' ? canEditUsername : false; %>
<% const canEmailEdit = typeof canEditEmail !== 'undefined' ? canEditEmail : false; %>
<% const profileImage = user?.profile_photo || '/design/assets/images/users/user-dummy-img.jpg'; %>
<%- include('layouts/partials/header.ejs' , {
    title : 'Profile',
    page_title : 'My Profile',
    card_title : '',
    breadcrumb_main : 'Dashboard' 
}) %>
<div class="card-body profile-page-wrapper">
    <style>
        .profile-page-loader {
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, 0.85);
            z-index: 1200;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .profile-section-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: #2d3f74;
            margin-bottom: .9rem;
        }
        .profile-section-box {
            border: 1px solid rgba(59, 89, 152, .12);
            border-radius: .65rem;
            padding: 1rem;
            margin-bottom: 1rem;
            background: #fff;
        }
        .profile-photo-edit-btn {
            position: absolute;
            bottom: 0;
            right: 2px;
            cursor: pointer;
        }
        .profile-meta-list .meta-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: .55rem;
            padding-bottom: .55rem;
            border-bottom: 1px dashed #edf0f6;
            gap: .8rem;
        }
        .profile-meta-list .meta-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: 0;
        }
        .profile-meta-list .meta-label {
            color: #6c757d;
            font-size: .84rem;
        }
        .profile-meta-list .meta-value {
            color: #212529;
            font-weight: 500;
            text-align: right;
        }
        .required-label::after {
            content: " *";
            color: #dc3545;
            font-weight: 600;
        }
        .field-help {
            font-size: .8rem;
        }
        .password-strength {
            height: .45rem;
            border-radius: 100px;
            overflow: hidden;
            background: #e9edf4;
        }
        .password-strength .bar {
            height: 100%;
            width: 0;
            transition: width .2s ease;
        }
        .summary-value {
            font-size: .84rem;
            color: #566070;
        }
        @media (max-width: 991px) {
            .profile-page-wrapper .card.mt-xxl-n5 {
                margin-top: 0 !important;
            }
        }
    </style>

    <!-- <div id="profile-page-loader" class="profile-page-loader">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
            <div class="mt-2 text-muted">Inapakia taarifa za akaunti...</div>
        </div>
    </div> -->

    <div class="position-relative mx-n4 mt-n4">
        <div class="profile-wid-bg profile-setting-img" style="height: 110px;">
            <img src="/design/assets/images/login_bg.png" class="profile-wid-img" alt="">
        </div>
    </div>

    <div id="profile-feedback-area" class="mb-2"></div>

    <div class="row g-3">
        <div class="col-xxl-3 col-lg-4">
            <div class="card mt-n5 mb-3">
                <div class="card-body p-4">
                    <div class="text-center">
                        <div class="profile-user position-relative d-inline-block mx-auto mb-3">
                            <img
                                src="<%= profileImage %>"
                                class="rounded-circle avatar-xl img-thumbnail user-profile-image shadow"
                                alt="Picha ya mtumiaji"
                                id="profile-avatar-preview">
                            <input id="profile-img-file-input" type="file" class="d-none" accept="image/png,image/jpeg,image/jpg,image/webp">
                            <label for="profile-img-file-input" class="profile-photo-edit-btn" title="Badili picha">
                                <span class="avatar-xs">
                                    <span class="avatar-title rounded-circle bg-light text-body shadow">
                                        <i class="ri-camera-fill"></i>
                                    </span>
                                </span>
                            </label>
                        </div>
                        <h5 class="fs-16 mb-1" id="profile-display-name"><%= user?.name || '-' %></h5>
                        <p class="text-muted mb-2">@<span id="profile-display-username"><%= user?.username || '-' %></span></p>
                        <span class="badge <%= isActiveAccount ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %>">
                            <%= isActiveAccount ? 'Active' : 'Inactive' %>
                        </span>
                    </div>

                    <hr class="my-3" />

                    <div class="profile-meta-list">
                        <div class="meta-item">
                            <span class="meta-label">Wadhifa</span>
                            <span class="meta-value"><%= resolvedRoleName %></span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Last Login</span>
                            <span class="meta-value"><%= user?.last_login ? dateFormat(user.last_login, 'DD MMM YYYY HH:mm') : '-' %></span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Last Updated</span>
                            <span class="meta-value"><%= user?.updated_at ? dateFormat(user.updated_at, 'DD MMM YYYY HH:mm') : '-' %></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Ofisi</h5>
                    <div class="d-flex align-items-center mb-2">
                        <div class="avatar-xs d-block flex-shrink-0 me-3">
                            <span class="avatar-title rounded-circle fs-16 bg-dark text-light shadow">
                                <i class="ri-building-2-fill"></i>
                            </span>
                        </div>
                        <div class="summary-value"><%= officeName || '-' %></div>
                    </div>
                    <% if (kanda && req.user.district_code) { %>
                    <div class="d-flex align-items-center">
                        <div class="avatar-xs d-block flex-shrink-0 me-3">
                            <span class="avatar-title rounded-circle fs-16 bg-primary shadow">
                                <i class="ri-map-pin-2-fill"></i>
                            </span>
                        </div>
                        <div class="summary-value"><%= kanda %></div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-xxl-9 col-lg-8">
            <div class="card mt-xxl-n5">
                <div class="card-header">
                    <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#personalDetails" role="tab">
                                <i class="ri-user-line"></i>
                                Taarifa Binafsi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#changePassword" role="tab">
                                <i class="ri-lock-password-line"></i>
                                Badili Nywila
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-4">
                    <div class="tab-content">
                        <div class="tab-pane active" id="personalDetails" role="tabpanel">
                            <form id="profileForm" novalidate>
                                <input type="hidden" id="avatarBase64Input" value="">

                                <div class="profile-section-box">
                                    <h6 class="profile-section-title">A. Taarifa za Msingi</h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="fullNameInput" class="form-label required-label">Jina Kamili</label>
                                            <input type="text" class="form-control" id="fullNameInput" value="<%= user?.name || '' %>" placeholder="Ingiza jina kamili">
                                            <div class="invalid-feedback" id="fullNameError"></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="usernameInput" class="form-label <%= canUsernameEdit ? 'required-label' : '' %>">Jina la Mtumiaji (username)</label>
                                            <input
                                                type="text"
                                                class="form-control"
                                                id="usernameInput"
                                                value="<%= user?.username || '' %>"
                                                <%= canUsernameEdit ? '' : 'readonly disabled' %>
                                                placeholder="Jina la mtumiaji">
                                            <div class="field-help text-muted mt-1"><%= canUsernameEdit ? 'Unaweza kubadili jina la mtumiaji kulingana na ruhusa zako.' : 'Field hii ni read-only.' %></div>
                                            <div class="invalid-feedback" id="usernameError"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="profile-section-box">
                                    <h6 class="profile-section-title">B. Mawasiliano</h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="phonenumberInput" class="form-label required-label">Namba ya Simu</label>
                                            <input type="text" class="form-control" id="phonenumberInput" value="<%= user?.phone_no || '' %>" placeholder="Mfano: 07XXXXXXXX">
                                            <div class="invalid-feedback" id="phoneError"></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="emailInput" class="form-label">Barua Pepe</label>
                                            <input
                                                type="email"
                                                class="form-control"
                                                id="emailInput"
                                                value="<%= user?.email || '' %>"
                                                readonly disabled
                                                placeholder="Ingiza barua pepe">
                                            <div class="field-help text-muted mt-1">Field hii ni read-only.</div>
                                            <div class="invalid-feedback" id="emailError"></div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-check form-switch form-switch-secondary mt-1">
                                                <input type="checkbox" class="form-check-input" id="emailNotifyInput" <%= user?.email_notify ? 'checked' : '' %>>
                                                <label for="emailNotifyInput" class="form-check-label">Nijulishe kwa barua pepe</label>
                                            </div>
                                            <div class="field-help text-muted">Pokea taarifa muhimu kupitia barua pepe</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="profile-section-box mb-2">
                                    <h6 class="profile-section-title">C. Mfumo / Ofisi</h6>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label">Ofisi</label>
                                            <input type="text" class="form-control" value="<%= officeName || '-' %>" disabled readonly>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Wadhifa / Role</label>
                                            <input type="text" class="form-control" value="<%= resolvedRoleName %>" disabled readonly>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Tarehe ya Kusajiliwa</label>
                                            <input type="text" class="form-control" value="<%= user?.created_at ? dateFormat(user.created_at, 'DD MMM YYYY HH:mm') : '-' %>" disabled readonly>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end mt-3">
                                    <button type="submit" id="btn-update-details" class="btn btn-outline-primary">
                                        <span class="ri-user-settings-line me-1"></span>
                                        Badili Taarifa
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="tab-pane" id="changePassword" role="tabpanel">
                            <div class="alert alert-info mb-3">
                                Hakikisha nywila mpya ina angalau herufi 8, herufi kubwa moja, herufi ndogo moja, namba moja na alama maalum moja.
                            </div>

                            <form id="passwordForm" novalidate>
                                <div class="row g-3">
                                    <div class="col-lg-4">
                                        <label for="oldpasswordInput" class="form-label required-label">Nywila ya sasa</label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="oldpasswordInput" autocomplete="current-password" placeholder="Weka nywila ya sasa">
                                            <button class="btn btn-light password-toggle" type="button" data-target="#oldpasswordInput"><i class="ri-eye-line"></i></button>
                                        </div>
                                        <div class="invalid-feedback" id="oldPasswordError"></div>
                                    </div>
                                    <div class="col-lg-4">
                                        <label for="newpasswordInput" class="form-label required-label">Nywila mpya</label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="newpasswordInput" autocomplete="new-password" placeholder="Weka nywila mpya">
                                            <button class="btn btn-light password-toggle" type="button" data-target="#newpasswordInput"><i class="ri-eye-line"></i></button>
                                        </div>
                                        <div class="password-strength mt-2" aria-hidden="true">
                                            <div class="bar" id="passwordStrengthBar"></div>
                                        </div>
                                        <div class="field-help mt-1" id="passwordStrengthText">Nguvu ya nywila: -</div>
                                        <div class="invalid-feedback" id="newPasswordError"></div>
                                    </div>
                                    <div class="col-lg-4">
                                        <label for="confirmpasswordInput" class="form-label required-label">Thibitisha nywila mpya</label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="confirmpasswordInput" autocomplete="new-password" placeholder="Rudia nywila mpya">
                                            <button class="btn btn-light password-toggle" type="button" data-target="#confirmpasswordInput"><i class="ri-eye-line"></i></button>
                                        </div>
                                        <div class="field-help text-danger mt-1 d-none" id="passwordMismatch">Nywila mpya na uthibitisho havifanani.</div>
                                        <div class="invalid-feedback" id="confirmPasswordError"></div>
                                    </div>

                                    <div class="col-12 d-flex justify-content-end mt-2">
                                        <button type="submit" id="btn-change-password" class="btn btn-success" disabled>
                                            Badili Nywila
                                        </button>
                                    </div>
                                </div>
                            </form>

                            <div class="mt-4 mb-3 border-bottom pb-2 d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">Last 10 Login History</h5>
                                <span class="text-muted fs-12">IP</span>
                            </div>
                            <% activities.forEach(item => { %>
                            <div class="d-flex align-items-center mb-3">
                                <div class="flex-shrink-0 avatar-sm">
                                    <div class="avatar-title bg-light text-primary rounded-3 fs-18 shadow">
                                        <i class="ri-<%= item.device == 'Phone' ? 'smartphone' : 'computer'%>-line"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="mb-1"><%= item.device %></h6>
                                    <p class="text-muted mb-0">
                                        <%= item.browser %> - <%= dateFormat(item.created_at , 'DD MMM YYYY') %> saa <%= dateFormat(item.created_at , 'HH:mm:ss') %>
                                    </p>
                                </div>
                                <div>
                                    <span class="badge badge-label bg-primary"><i class="mdi mdi-circle-medium"></i> <%= item.ip %></span>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('layouts/partials/footer.ejs' , {card_title :  card_title}) %>
<script type="text/javascript" src="/design/layouts/scripts/profile_scripts.js"></script>
</body>
</html>
