<% var card_title = '' %>
<%- include('layouts/partials/header.ejs' , {
    title : 'Masomo ya Michepuo',
    page_title : 'Orodha ya Masomo ya Michepuo',
    card_title : 'Masomo ya Michepuo yaliyopo',
    breadcrumb_main : 'Mipangilio',
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>
<div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-3">
            <div class="col-sm-auto">
                <button type="button" class="btn btn-success add-btn" id="create-btn">
                    <i class="ri-add-line align-bottom me-1"></i> Sajili
                </button>
            </div>
        </div>

        <div class="col-md-12">
            <div class="table-responsive table-card mt-3 mb-1">
                <table class="table align-middle table-nowrap" id="datatable">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">Na.</th>
                            <th>Tahasusi</th>
                            <th>Somo</th>
                            <th>Imetengenezwa</th>
                            <th>Imesasishwa</th>
                            <th class="text-center" width="10%">Action</th>
                        </tr>
                    </thead>
                    <tbody class="list form-check-all"></tbody>
                </table>
                <div class="noresult" style="display: none">
                    <div class="text-center">
                        <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop"
                            colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                        <h5 class="mt-2">Hakuna matokeo</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="showModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title">Sajili Somo la Mchepuo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="combination-field" class="form-label">Tahasusi</label>
                        <select id="combination-field" class="form-select">
                            <option value="">Chagua Tahasusi</option>
                        </select>
                        <span class="text-danger" style="display: none;" id="jaza-combination">Tafadhali chagua Tahasusi.</span>
                    </div>
                    <div class="mb-1">
                        <label for="subject-field" class="form-label">Masomo</label>
                        <select id="subject-field" class="form-select" multiple size="8">
                        </select>
                        <small class="text-muted d-block mt-1">Unaweza kuchagua zaidi ya Somo moja.</small>
                        <span class="text-danger" style="display: none;" id="jaza-subject">Tafadhali chagua Somo angalau moja.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" class="btn btn-success" onclick="sajiliSomoLaMchepuo()">Sajili</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="showEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title">Badili Somo la Mchepuo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <input type="hidden" id="id-field" />
                    <div class="mb-3">
                        <label for="combination2-field" class="form-label">Tahasusi</label>
                        <select id="combination2-field" class="form-select">
                            <option value="">Chagua Tahasusi</option>
                        </select>
                        <span class="text-danger" style="display: none;" id="jaza-combination2">Tafadhali chagua Tahasusi.</span>
                    </div>
                    <div class="mb-1">
                        <label for="subject2-field" class="form-label">Somo</label>
                        <select id="subject2-field" class="form-select">
                            <option value="">Chagua Somo</option>
                        </select>
                        <span class="text-danger" style="display: none;" id="jaza-subject2">Tafadhali chagua Somo.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" class="btn btn-success" onclick="sasishaSomoLaMchepuo()">Hifadhi</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'}
          ]
    }) %>

<script>
    const reloadCombinationSubjectTable = () => {
        $('#datatable').DataTable().ajax.reload(null, false);
    };

    const lookupData = {
        combinations: [],
        subjects: []
    };

    const renderOptions = (selector, items, valueKey, labelKey, selectedValue = "") => {
        const selected = String(selectedValue || "");
        const options = ['<option value="">Chagua</option>'];
        items.forEach((item) => {
            const value = String(item[valueKey] || "");
            const label = String(item[labelKey] || "");
            options.push(`<option value="${value}" ${value === selected ? "selected" : ""}>${label}</option>`);
        });
        $(selector).html(options.join(""));
    };

    const renderMultiOptions = (selector, items, valueKey, labelKey) => {
        const options = [];
        items.forEach((item) => {
            const value = String(item[valueKey] || "");
            const label = String(item[labelKey] || "");
            options.push(`<option value="${value}">${label}</option>`);
        });
        $(selector).html(options.join(""));
    };

    const loadLookupData = (onDone, force = false) => {
        if (!force && lookupData.combinations.length > 0 && lookupData.subjects.length > 0) {
            if (typeof onDone === "function") onDone();
            return;
        }

        $.get("/MasomoYaMichepuoLookup", (response) => {
            lookupData.combinations = Array.isArray(response?.data?.combinations) ? response.data.combinations : [];
            lookupData.subjects = Array.isArray(response?.data?.subjects) ? response.data.subjects : [];
            if (typeof onDone === "function") onDone();
        }).fail(() => {
            alertMessage("Haujafanikiwa", "Imeshindikana kupakia Tahasusi na Masomo.", "warning");
        });
    };

    $("#create-btn").on("click", function () {
        $("#jaza-combination").hide();
        $("#jaza-subject").hide();
        loadLookupData(() => {
            renderOptions("#combination-field", lookupData.combinations, "id", "combination");
            renderMultiOptions("#subject-field", lookupData.subjects, "id", "subject_name");
            $("#subject-field").val([]);
            modal("showModal", true);
        });
    });

    function BadiliData(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        $("#id-field").val(rowData.id || "");
        $("#jaza-combination2").hide();
        $("#jaza-subject2").hide();

        loadLookupData(() => {
            renderOptions("#combination2-field", lookupData.combinations, "id", "combination", rowData.combination_id);
            renderOptions("#subject2-field", lookupData.subjects, "id", "subject_name", rowData.subject_id);
            modal("showEditModal", true);
        });
    }

    function sajiliSomoLaMchepuo() {
        const combination_id = Number($("#combination-field").val() || 0);
        const subject_ids = ($("#subject-field").val() || [])
            .map((value) => Number(value))
            .filter((value) => Number.isFinite(value) && value > 0);
        $("#jaza-combination").hide();
        $("#jaza-subject").hide();

        if (!combination_id) {
            $("#jaza-combination").show();
            return;
        }
        if (subject_ids.length === 0) {
            $("#jaza-subject").show();
            return;
        }

        ajaxRequest(
            "/tengenezaSomoLaMchepuo",
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showModal", false);
                            reloadCombinationSubjectTable();
                        }
                    }
                );
            },
            JSON.stringify({
                combination_id,
                subject_ids
            })
        );
    }

    function sasishaSomoLaMchepuo() {
        const id = Number($("#id-field").val() || 0);
        const combination_id = Number($("#combination2-field").val() || 0);
        const subject_id = Number($("#subject2-field").val() || 0);
        $("#jaza-combination2").hide();
        $("#jaza-subject2").hide();

        if (!id) {
            alertMessage("Haujafanikiwa", "Somo la Mchepuo halijapatikana.", "warning");
            return;
        }
        if (!combination_id) {
            $("#jaza-combination2").show();
            return;
        }
        if (!subject_id) {
            $("#jaza-subject2").show();
            return;
        }

        ajaxRequest(
            `/badiliSomoLaMchepuo/${id}`,
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showEditModal", false);
                            reloadCombinationSubjectTable();
                        }
                    }
                );
            },
            JSON.stringify({
                combination_id,
                subject_id
            })
        );
    }

    function FutaData(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        const id = Number(rowData.id || 0);
        if (!id) {
            alertMessage("Haujafanikiwa", "Somo la Mchepuo halijapatikana.", "warning");
            return;
        }

        confirmAction(
            () => {
                ajaxRequest(`/futaSomoLaMchepuo/${id}`, "POST", (response) => {
                    const statusCode = Number(response?.statusCode || 306);
                    alertMessage(
                        statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                        response?.message || "Kuna tatizo, jaribu tena.",
                        statusCode === 300 ? "success" : "warning",
                        () => {
                            if (statusCode === 300) {
                                reloadCombinationSubjectTable();
                            }
                        }
                    );
                });
            },
            "Futa",
            "warning",
            "Ukifuta taarifa hii, haitatumika tena kwenye setup.",
            "Futa Somo la Mchepuo?"
        );
    }

    $(document).ready(function() {
        loadLookupData();
        tableData('datatable' ,'/MasomoYaMichepuoList' , 'POST',
            [
                {
                    data: null,
                    render: function (data, type, row , meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                {
                    data: "combination",
                    name: "combination",
                    render: (data) => data ? data : "-"
                },
                {
                    data: "subject_name",
                    name: "subject_name",
                    render: (data) => data ? data : "-"
                },
                {
                    data: "created_at",
                    name: "created_at",
                    render: (data) => data ? changeDateFormat(data) : "-"
                },
                {
                    data: "updated_at",
                    name: "updated_at",
                    render: (data) => data ? changeDateFormat(data) : "-"
                },
                {
                    data: null,
                    render: function (data, type, row) {
                        const elements = [
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-primary me-1',
                                icon : 'bx bx-pencil me-1',
                                function : 'BadiliData',
                                btnText : 'Edit'
                            },
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-danger',
                                icon : 'bx bx-trash me-1',
                                function : 'FutaData',
                                btnText : 'Futa'
                            }
                        ];
                        return actionButtons(row, elements);
                    },
                    orderable: false,
                    searchable: false,
                    className: "text-center"
                }
            ]
        );
    });
</script>
</body>
</html>
