	        // Global handler for opening letters in a modal instead of a new tab
	        (function(){
	            const modalEl = document.getElementById("globalPdfModal");
	            const titleEl = document.getElementById("globalPdfModalTitle");
	            const frameEl = document.getElementById("globalPdfFrame");
	            const loadingEl = document.getElementById("globalPdfLoading");

	            const getBootstrap = () => {
	                try {
	                    return window.bootstrap || (typeof bootstrap !== "undefined" ? bootstrap : null);
	                } catch (e) {
	                    return window.bootstrap || null;
	                }
	            };

	            const getModalCtor = () => {
	                const bs = getBootstrap();
	                return bs && typeof bs.Modal === "function" ? bs.Modal : null;
	            };

	            let modalInstance = null;
	            let fallbackBackdrop = null;

	            const showFallback = () => {
	                if (!modalEl) return;
	                modalEl.classList.add("show");
	                modalEl.style.display = "block";
	                modalEl.removeAttribute("aria-hidden");
	                document.body.classList.add("modal-open");

	                if (!fallbackBackdrop) {
	                    fallbackBackdrop = document.createElement("div");
	                    fallbackBackdrop.className = "modal-backdrop fade show";
	                    document.body.appendChild(fallbackBackdrop);
	                }
	            };

	            const hideFallback = () => {
	                if (!modalEl) return;
	                modalEl.classList.remove("show");
	                modalEl.style.display = "none";
	                modalEl.setAttribute("aria-hidden", "true");
	                document.body.classList.remove("modal-open");
	                if (fallbackBackdrop && fallbackBackdrop.parentNode) {
	                    fallbackBackdrop.parentNode.removeChild(fallbackBackdrop);
	                }
	                fallbackBackdrop = null;
	            };

	            const setLoading = (isLoading) => {
	                if (!loadingEl) return;
	                loadingEl.classList.toggle("d-none", !isLoading);
	            };

	            window.openPdfModal = (url, options = {}) => {
	                const safeUrl = String(url || "").trim();
	                if (!safeUrl) return;

	                if (!modalEl || !frameEl) {
	                    window.location.assign(safeUrl);
	                    return;
	                }

	                const ModalCtor = getModalCtor();
	                if (ModalCtor && !modalInstance) {
	                    try {
	                        modalInstance = new ModalCtor(modalEl, { backdrop: "static", keyboard: true });
	                    } catch (e) {
	                        modalInstance = null;
	                    }
	                }

	                if (titleEl) {
	                    const title = String(options.title || "Barua").trim() || "Barua";
	                    titleEl.textContent = title;
	                }

	                setLoading(true);
	                frameEl.src = safeUrl;
	                if (modalInstance) {
	                    modalInstance.show();
	                } else {
	                    showFallback();
	                }
	            };

	            if (frameEl) {
	                frameEl.addEventListener("load", function(){
	                    setLoading(false);
	                });
	            }

	            if (modalEl) {
	                modalEl.addEventListener("hidden.bs.modal", function(){
	                    if (frameEl) frameEl.src = "about:blank";
	                    setLoading(true);
	                });

	                // Fallback close button support when Bootstrap isn't available.
	                const closeBtn = modalEl.querySelector ? modalEl.querySelector('[data-bs-dismiss="modal"], .btn-close') : null;
	                if (closeBtn) {
	                    closeBtn.addEventListener("click", function(){
	                        if (modalInstance) return;
	                        hideFallback();
	                        if (frameEl) frameEl.src = "about:blank";
	                        setLoading(true);
	                    });
	                }
	            }

	            // Close fallback on ESC
	            document.addEventListener("keydown", function(e){
	                if (modalInstance) return;
	                if (!modalEl) return;
	                if (!modalEl.classList.contains("show")) return;
	                const key = e && (e.key || e.code);
	                if (key === "Escape" || key === "Esc") {
	                    hideFallback();
	                    if (frameEl) frameEl.src = "about:blank";
	                    setLoading(true);
	                }
	            });

            const isLetterHref = (href) => {
                const value = String(href || "").trim().toLowerCase();
                return value.startsWith("/barua/");
            };

            const handleLetterClick = (event, anchor) => {
                if (!event || event.defaultPrevented) return;
                if (!anchor) return;
                if (anchor.getAttribute("data-no-pdf-modal") === "1") return;
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

                const href = String(anchor.getAttribute("href") || "").trim();
                if (!isLetterHref(href)) return;

                // Ensure no "new tab" behaviour even if some markup has target=_blank.
                if (anchor.getAttribute("target") === "_blank") {
                    anchor.removeAttribute("target");
                    anchor.removeAttribute("rel");
                }

                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === "function") {
                    event.stopImmediatePropagation();
                }

                const title = String(anchor.getAttribute("title") || anchor.textContent || "Barua").trim() || "Barua";
                window.openPdfModal(href, { title });
            };

            const bindLetterAnchors = (root) => {
                const scope = root && root.querySelectorAll ? root : document;
                let anchors = [];
                try {
                    anchors = Array.from(scope.querySelectorAll('a[href^="/barua/"], a[href^="/Barua/"]'));
                } catch (e) {
                    anchors = [];
                }

                anchors.forEach((a) => {
                    if (!a || a.getAttribute("data-no-pdf-modal") === "1") return;
                    if (a.dataset && a.dataset.pdfModalBound === "1") return;

                    // Prevent the browser from opening a new tab by default.
                    if (a.getAttribute("target") === "_blank") {
                        a.removeAttribute("target");
                        a.removeAttribute("rel");
                    }

                    if (a.dataset) a.dataset.pdfModalBound = "1";
                    a.addEventListener("click", function (event) {
                        handleLetterClick(event, a);
                    });
                });

                // Also handle legacy markup: <button>...<a href="/Barua/...">...</a></button>
                let buttons = [];
                try {
                    buttons = Array.from(scope.querySelectorAll("button"));
                } catch (e) {
                    buttons = [];
                }
                buttons.forEach((btn) => {
                    if (!btn) return;
                    const a = btn.querySelector ? btn.querySelector('a[href^="/barua/"], a[href^="/Barua/"]') : null;
                    if (!a) return;
                    if (btn.dataset && btn.dataset.pdfModalBound === "1") return;
                    if (btn.dataset) btn.dataset.pdfModalBound = "1";
                    btn.addEventListener("click", function (event) {
                        handleLetterClick(event, a);
                    });
                });
            };

            // Initial bind for all pages.
            bindLetterAnchors(document);

            // MutationObserver for dynamically injected content (tables, ajax, etc).
            if (document.body && typeof MutationObserver === "function") {
                const observer = new MutationObserver((mutations) => {
                    mutations.forEach((m) => {
                        (m.addedNodes || []).forEach((node) => {
                            if (!node || node.nodeType !== 1) return;
                            bindLetterAnchors(node);
                        });
                    });
                });
                observer.observe(document.body, { childList: true, subtree: true });
            }

            // Capture-phase handler: runs before other click handlers.
            document.addEventListener("click", function(event){
                const anchor = event.target && event.target.closest ? event.target.closest("a") : null;
                if (!anchor) return;
                handleLetterClick(event, anchor);
            }, true);

            // Fallback delegated handler (in case some anchor is missed).
            document.addEventListener("click", function(event){
                const anchor = event.target && event.target.closest ? event.target.closest("a") : null;
                if (!anchor) return;
                handleLetterClick(event, anchor);
            }, false);
        })();
