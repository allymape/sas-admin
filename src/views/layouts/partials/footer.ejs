	<script>
	  (function () {
	    const THEME_KEY = "sas_layout_mode";

    const syncDefaultAttribute = () => {
      try {
        const attrs = {};
        Array.from(document.documentElement.attributes || []).forEach((attr) => {
          if (!attr || !attr.name) return;
          attrs[attr.name] = attr.value;
        });
        sessionStorage.setItem("defaultAttribute", JSON.stringify(attrs));
      } catch (error) {}
    };

    const persistTheme = (theme) => {
      if (theme !== "dark" && theme !== "light") return;
      try {
        document.documentElement.setAttribute("data-layout-mode", theme);
        localStorage.setItem(THEME_KEY, theme);
        sessionStorage.setItem("data-layout-mode", theme);
        syncDefaultAttribute();
      } catch (error) {}
    };

    const resolveCurrentTheme = () => {
      const htmlTheme = String(document.documentElement.getAttribute("data-layout-mode") || "").toLowerCase();
      if (htmlTheme === "dark" || htmlTheme === "light") return htmlTheme;
      const sessionTheme = String(sessionStorage.getItem("data-layout-mode") || "").toLowerCase();
      if (sessionTheme === "dark" || sessionTheme === "light") return sessionTheme;
      return "light";
    };

    document.addEventListener("DOMContentLoaded", () => {
      const savedTheme = String(localStorage.getItem(THEME_KEY) || "").toLowerCase();
      if (savedTheme === "dark" || savedTheme === "light") {
        persistTheme(savedTheme);
      } else {
        persistTheme(resolveCurrentTheme());
      }

      document.querySelectorAll(".light-dark-mode").forEach((button) => {
        button.addEventListener("click", () => {
          setTimeout(() => persistTheme(resolveCurrentTheme()), 0);
        });
      });

      document.querySelectorAll("[name='data-layout-mode']").forEach((input) => {
        input.addEventListener("change", (event) => {
          const selected = String(event?.target?.value || "").toLowerCase();
          persistTheme(selected);
        });
      });
	    });
	  })();
	</script>

	<script>
	  (function () {
	    // Persist left menu (hamburger) state across refresh.
	    const KEY_SIZE = "sas_sidebar_size";
	    const KEY_HAMBURGER_OPEN = "sas_hamburger_open";

	    const apply = () => {
	      try {
	        const savedSize = localStorage.getItem(KEY_SIZE);
	        if (savedSize !== null) {
	          document.documentElement.setAttribute("data-sidebar-size", savedSize);
	          sessionStorage.setItem("data-sidebar-size", savedSize);
	        }

	        const open = localStorage.getItem(KEY_HAMBURGER_OPEN) === "1";
	        const hamburger = document.querySelector("#topnav-hamburger-icon .hamburger-icon");
	        if (hamburger) hamburger.classList.toggle("open", open);
	      } catch (error) {}
	    };

	    const save = () => {
	      try {
	        const size = document.documentElement.getAttribute("data-sidebar-size") || "";
	        localStorage.setItem(KEY_SIZE, size);
	        sessionStorage.setItem("data-sidebar-size", size);

	        const open = document.querySelector(".hamburger-icon")?.classList.contains("open");
	        localStorage.setItem(KEY_HAMBURGER_OPEN, open ? "1" : "0");
	      } catch (error) {}
	    };

	    const bind = () => {
	      const btn = document.getElementById("topnav-hamburger-icon");
	      if (!btn) return;
	      // Run after the theme/app.js click handler so we store the *new* state (not the old one).
	      btn.addEventListener("click", () => setTimeout(save, 0));
	    };

	    if (document.readyState === "loading") {
	      document.addEventListener("DOMContentLoaded", () => {
	        apply();
	        bind();
	      });
	    } else {
	      apply();
	      bind();
	    }

	    // One more apply after load (in case app.js resets on load callbacks).
	    window.addEventListener("load", () => setTimeout(apply, 0));
	  })();
	</script>
