        $(function(){
            const SESSION_CHECK_INTERVAL_MS = 30000;
            const SESSION_WARNING_THRESHOLD_SECONDS = 125;
            const SESSION_EXPIRED_SECONDS = 0;

            let isSessionPromptOpen = false;
            let isSessionCheckInFlight = false;
            let countdownInterval = null;

            const toInt = (value, fallback = 0) => {
                const parsed = Number.parseInt(value, 10);
                return Number.isFinite(parsed) ? parsed : fallback;
            };

            const clearCountdown = () => {
                if (countdownInterval) {
                    clearInterval(countdownInterval);
                    countdownInterval = null;
                }
            };

            const closeSessionPrompt = () => {
                clearCountdown();
                isSessionPromptOpen = false;
            };

            const extendSession = () => {
                $.ajax({
                    url : '/ExtendSession',
                    type : 'post',
                    data : {},
                    success : (response) => {
                        const { statusCode, message } = response || {};
                        if (toInt(statusCode) === 300) {
                            alertMessage('Alert', message || 'Session extended successfully', 'success', () => {}, null);
                        } else {
                            window.location.reload();
                        }
                        closeSessionPrompt();
                    },
                    error : (xhr , xhrStatus , xhrText) => {
                        console.log(xhr , xhrStatus , xhrText);
                        closeSessionPrompt();
                    }
                });
            };

            const showSessionPrompt = (remainSeconds) => {
                if (isSessionPromptOpen || (window.Swal && Swal.isVisible())) return;

                isSessionPromptOpen = true;
                confirmAction(
                    extendSession,
                    'Extend Session',
                    'warning',
                    ``,
                    'Are you still here?',
                    `Your session is about to expire in <strong><span id="timer">${remainSeconds}</span></strong> seconds.`,
                    () => {
                        let timeLeft = remainSeconds;
                        clearCountdown();
                        countdownInterval = setInterval(() => {
                            timeLeft -= 1;
                            const container = window.Swal ? Swal.getHtmlContainer() : null;
                            const timerNode = container ? container.querySelector('#timer') : null;
                            if (timerNode) timerNode.textContent = timeLeft;

                            if (timeLeft <= SESSION_EXPIRED_SECONDS) {
                                clearCountdown();
                                if (window.Swal) Swal.close();
                                closeSessionPrompt();
                                setTimeout(() => window.location.reload(), 500);
                            }
                        }, 1000);
                    }
                );
            };

            const checkSessionExpiry = () => {
                if (isSessionCheckInFlight) return;
                if (document.hidden) return;

                isSessionCheckInFlight = true;
                $.ajax({
                    url : '/CheckSessionExpire',
                    type : 'post',
                    data : {},
                    success : (response) => {
                        const remainSeconds = toInt(response?.remain_seconds, 0);
                        const statusCode = toInt(response?.statusCode, 300);

                        if (statusCode !== 300 || remainSeconds <= SESSION_EXPIRED_SECONDS) {
                            window.location.reload();
                            return;
                        }

                        if (remainSeconds < SESSION_WARNING_THRESHOLD_SECONDS) {
                            showSessionPrompt(remainSeconds);
                        }
                    },
                    error : (xhr , xhrStatus , xhrText) => {
                        console.log(xhr , xhrStatus , xhrText);
                        if (xhr?.status === 401 || xhr?.status === 403) {
                            window.location.reload();
                        }
                    },
                    complete: () => {
                        isSessionCheckInFlight = false;
                    }
                });
            };

            checkSessionExpiry();
            setInterval(checkSessionExpiry, SESSION_CHECK_INTERVAL_MS);
            document.addEventListener('visibilitychange', () => {
                if (!document.hidden) checkSessionExpiry();
            });
        })
    </script>
    <script>
        (() => {
            const ELLIPSIS_SELECTOR = '.ellipsis-tooltip, .text-truncate';

            const upsertEllipsisTooltip = (element) => {
                if (!element) return;

                const text = (element.getAttribute('data-tooltip-text') || element.textContent || '').trim();
                const isTruncated = element.scrollWidth > element.clientWidth;
                const tooltipInstance = window.bootstrap?.Tooltip?.getInstance(element);
                const isOwned = element.dataset.ellipsisTooltipOwned === '1';

                if (!text || !isTruncated) {
                    if (isOwned && tooltipInstance) tooltipInstance.dispose();
                    if (isOwned) {
                        element.removeAttribute('title');
                        element.removeAttribute('data-bs-toggle');
                        delete element.dataset.ellipsisTooltipOwned;
                    }
                    return;
                }

                element.setAttribute('title', text);
                element.setAttribute('data-bs-toggle', 'tooltip');
                element.dataset.ellipsisTooltipOwned = '1';

                if (tooltipInstance) {
                    tooltipInstance.dispose();
                }
                if (window.bootstrap?.Tooltip) {
                    new bootstrap.Tooltip(element);
                }
            };

            const refreshEllipsisTooltips = () => {
                document.querySelectorAll(ELLIPSIS_SELECTOR).forEach(upsertEllipsisTooltip);
            };

            let resizeTimer = null;
            window.refreshEllipsisTooltips = refreshEllipsisTooltips;

            document.addEventListener('DOMContentLoaded', refreshEllipsisTooltips);
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(refreshEllipsisTooltips, 150);
            });
        })();
    </script>
