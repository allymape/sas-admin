<!doctype html>
<html lang="en" data-layout="vertical" data-topbar="light" data-sidebar="dark" data-sidebar-size="lg" data-sidebar-image="none" data-sas-theme-mode="system" data-sas-accent="blue">
<head>
    <meta charset="utf-8" />
    <title><%= `${typeof title !== 'undefined' && title ? title : 'Dashboard'} | SAS - School Accreditation System` %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="School Accreditation System (SAS) - Ministry of Education, Science and Technology" name="description" />
    <meta content="MOEST Tanzania" name="author" />
    <meta name="application-name" content="School Accreditation System (SAS)" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="/design/assets/images/favicon.ico">
    <!-- Sweet Alert css-->
    <link href="/design/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
     <!-- jsvectormap css -->
    <link href="/design/assets/libs/jsvectormap/css/jsvectormap.min.css" rel="stylesheet" type="text/css" />
    <!--Swiper slider css-->
    <link href="/design/assets/libs/swiper/swiper-bundle.min.css" rel="stylesheet" type="text/css" />
    <!-- Layout config Js -->
    <script>
      (function () {
        try {
          var MODE_KEY = "sas_theme_mode";
          var ACCENT_KEY = "sas_theme_accent";
          var LEGACY_MODE_KEY = "sas_layout_mode";

          var themeMode = localStorage.getItem(MODE_KEY);
          if (!themeMode) {
            var legacyMode = localStorage.getItem(LEGACY_MODE_KEY);
            if (legacyMode === "light" || legacyMode === "dark") {
              themeMode = legacyMode;
            }
          }
          if (themeMode !== "light" && themeMode !== "dark" && themeMode !== "system") {
            themeMode = "system";
          }

          var accent = localStorage.getItem(ACCENT_KEY);
          if (accent !== "blue" && accent !== "indigo" && accent !== "green") {
            accent = "blue";
          }

          var resolvedTheme = themeMode;
          if (themeMode === "system") {
            resolvedTheme = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          }

          document.documentElement.setAttribute("data-sas-theme-mode", themeMode);
          document.documentElement.setAttribute("data-sas-accent", accent);
          document.documentElement.setAttribute("data-layout-mode", resolvedTheme);

          localStorage.setItem(MODE_KEY, themeMode);
          localStorage.setItem(ACCENT_KEY, accent);
          if (themeMode === "light" || themeMode === "dark") {
            localStorage.setItem(LEGACY_MODE_KEY, themeMode);
          }

          sessionStorage.setItem("data-layout-mode", resolvedTheme);
          var attrs = {};
          Array.from(document.documentElement.attributes || []).forEach(function (attr) {
            if (!attr || !attr.name) return;
            attrs[attr.name] = attr.value;
          });
          sessionStorage.setItem("defaultAttribute", JSON.stringify(attrs));
        } catch (error) {}
      })();
    </script>
    <script src="/design/assets/js/layout.js"></script>
    <!-- Bootstrap Css -->
    <link href="/design/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" type="text/css" /> -->
    <!-- Icons Css -->
    <link href="/design/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <!-- App Css-->
    <link href="/design/assets/css/app.min.css" rel="stylesheet" type="text/css" />
    <!-- select2 -->
       <!-- <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" /> -->
    <link href="/css/select2.min.css" rel="stylesheet" />
    <!-- custom Css-->
    <link href="/design/assets/css/custom.min.css" rel="stylesheet" type="text/css" />
    <link href="/design/assets/css/sas-admin-tweaks.css" rel="stylesheet" type="text/css" />
    <!-- <link href="/design/assets/css/custom.css" rel="stylesheet" type="text/css" /> -->
       <!-- quill css -->
    <link href="/design/assets/libs/quill/quill.core.css" rel="stylesheet" type="text/css" />
    <link href="/design/assets/libs/quill/quill.bubble.css" rel="stylesheet" type="text/css" />
    <link href="/design/assets/libs/quill/quill.snow.css" rel="stylesheet" type="text/css" />
<% if(typeof styles !== 'undefined' && Array.isArray(styles)){ %>
<% styles.forEach(element => { %>
    <link href="<%= element.href %>" rel="stylesheet" type="text/css" />
<% }); %>
<% } %>
</head>

<body>
    <a class="sas-skip-link" href="#main-content">Skip To Main Content</a>
    <!-- Begin page -->
     
    <div id="layout-wrapper">
        <%- include('sidebar.ejs')%>
        <%- include('../../includes/spinner.ejs') %>
        <!-- ============================================================== -->
        <!-- Start right Content here -->
        <!-- ============================================================== -->
        <div class="main-content" id="main-content">
            <div class="page-content">
                <div class="container-fluid">
                    <% if(typeof page_title !== 'undefined' && page_title) {%>
                        <!-- start page title -->
                        <%- include('page_title.ejs') %>
                        <!-- end page title -->
                    <% } %>
                    <% if(typeof top_header !== 'undefined' && top_header !== null) {%>
                        <%- include(top_header) %>
                    <% } %>
                    <div class="row">
                        <div class="col-lg-12">
                            <% if((typeof card_title !== 'undefined' && card_title) || (typeof card_header_actions !== 'undefined' && card_header_actions)){ %>
                            <div class="card">
                                <div class="card-header d-flex flex-wrap align-items-center <%= (typeof card_title !== 'undefined' && card_title) ? 'justify-content-between' : 'justify-content-end' %> gap-2">
                                    <% if (typeof card_title !== 'undefined' && card_title) { %>
                                    <h4 class="card-title mb-0"><%=`${typeof card_title != 'undefined' ? card_title :  card_title}`%></h4>
                                    <% } %>
                                    <% if (typeof card_header_actions !== 'undefined' && card_header_actions) { %>
                                        <div class="d-flex flex-wrap align-items-center gap-2">
                                            <%- card_header_actions %>
                                        </div>
                                    <% } %>
                                </div><!-- end card header -->
                                <% } %>
