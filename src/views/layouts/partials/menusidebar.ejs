const currentUrl = getCurrentUrl(req);
const can = (permissionName) => permission(req, permissionName);
const hasAnyPermission = (permissionNames = []) => {
  return permissionNames.some((permissionName) => can(permissionName));
};

const roleName = String(req?.session?.jukumu || req?.user?.jukumu || "").toLowerCase();
const isAdminRole = ["super admin", "super-admin", "admin", "system admin"].some((name) => roleName.includes(name));

const hasVisibleChildren = (items = []) => {
  return items.some((item) => {
    if (Array.isArray(item.subMenus) && item.subMenus.length > 0) {
      return hasVisibleChildren(item.subMenus);
    }
    return !!item.hasPermissionTo;
  });
};

const collectPatterns = (items = []) => {
  return items
    .flatMap((item) => {
      const own = item.pattern ? [item.pattern] : [];
      const child = Array.isArray(item.subMenus) ? collectPatterns(item.subMenus) : [];
      return own.concat(child);
    })
    .filter(Boolean);
};

const renderSubMenus = (items = [], level = 0) => {
  let html = '<ul class="nav nav-sm flex-column">';
  items.forEach((subItem) => {
    const hasChildren = Array.isArray(subItem.subMenus) && subItem.subMenus.length > 0;
    const visible = hasChildren ? hasVisibleChildren(subItem.subMenus) : !!subItem.hasPermissionTo;
    if (!visible) return;

    if (hasChildren) {
      const collapseId =
        subItem.menuId || `submenu-${level}-${String(subItem.label || "").toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
      const descendantPatterns = collectPatterns(subItem.subMenus).join("|");
      const isOpen = routeIs(descendantPatterns, currentUrl);
      const openClass = isOpen ? "show" : "";
      const activeClass = isOpen ? "active" : "";
      html += `
        <li class="nav-item">
          <a class="nav-link menu-link ${activeClass}" href="#${collapseId}" data-bs-toggle="collapse" role="button" aria-expanded="${isOpen ? "true" : "false"}" aria-controls="${collapseId}">
            ${subItem.label}
          </a>
          <div class="collapse menu-dropdown ${openClass}" id="${collapseId}">
            ${renderSubMenus(subItem.subMenus, level + 1)}
          </div>
        </li>
      `;
      return;
    }

    const activeClass = routeIs(subItem.pattern || "", currentUrl) ? "active" : "";
    const counterHtml = subItem.counterId
      ? `<span class="badge badge-pill bg-danger" id="${subItem.counterId}" data-key="t-new"></span>`
      : "";

    html += `
      <li class="nav-item">
        <a href="/${subItem.url}" class="nav-link ${activeClass}" data-key="t-analytics">
          ${subItem.label}
          ${counterHtml}
        </a>
      </li>
    `;
  });

  html += "</ul>";
  return html;
};

