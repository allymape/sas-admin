%>
<div id="scrollbar">
  <div class="container-fluid">
    <div id="two-column-menu">&nbsp;</div>
    <ul class="navbar-nav" id="navbar-nav">
        <% if(req.session.kanda){ %>
        <li class="menu-title text-muted">
            <span><%= req.session.kanda ? `ZONE ${req.session.kanda}` : '' %></span>
        </li>
        <% }%>
      <% menuItems.forEach(function(item) {
        if (typeof item.subMenus !== 'undefined' && item.subMenus.length > 0) {
          if (hasVisibleChildren(item.subMenus)) {
            if (item.menuTitle) { %>
              <li class="menu-title"><i class="ri-more-fill"></i> <span data-key="t-components"><%= item.menuTitle %></span></li>
            <% }
            const childPatterns = collectPatterns(item.subMenus).join("|");
            const isOpen = routeIs(childPatterns, currentUrl);
            %>
            <li class="nav-item">
              <a class="nav-link menu-link <%= isOpen ? 'active' : '' %>"
                 href="<%= item.menuId ? item.url : '/' + item.url %>"
                 data-bs-toggle="collapse"
                 role="button"
                 aria-expanded="<%= isOpen ? 'true' : 'false' %>"
                 aria-controls="<%= item.menuId %>">
                <i class="<%= item.icon %>"></i>
                <span data-key="t-dashboards"><%= item.label %></span>
              </a>
              <div class="collapse menu-dropdown <%= isOpen ? 'show' : '' %>" id="<%= item.menuId %>">
                <%- renderSubMenus(item.subMenus) %>
              </div>
            </li>
          <% }
        } else {
          if (item.hasPermissionTo) {
            if (item.menuTitle) { %>
              <li class="menu-title"><i class="ri-more-fill"></i> <span data-key="t-components"><%= item.menuTitle %></span></li>
            <% } %>
            <li class="nav-item">
              <a href="/<%= item.url %>"
                 <%= typeof item.menuId !== 'undefined' && item.menuId ? `id=${item.menuId}` : '' %>
                 class="nav-link menu-link <%= routeIs(item.pattern, currentUrl) ? 'active' : '' %>">
                <i class="<%= item.icon %>"></i>
                <span data-key="t-widgets"><%= item.label %></span>
              </a>
            </li>
          <% }
        }
      }); %>
    </ul>
  </div>
</div>
