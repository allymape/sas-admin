                                        <span class="d-flex align-items-center">
                                            <span class="spinner-border flex-shrink-0" role="status">
                                                <span class="visually-hidden">Tafadhali subiri...</span>
                                            </span>
                                            <span class="flex-grow-1 ms-2">
                                                Tafadhali subiri...
                                            </span>
                                        </span>
                                    </button>
                                </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
    (function ensureHandoverMenuOpen() {
        document.addEventListener("DOMContentLoaded", function () {
            var path = String(window.location.pathname || "").toLowerCase();
            if (!path.startsWith("/handover")) return;

            var applicationsCollapse = document.getElementById("sidebarApplications");
            var applicationsTrigger = document.querySelector('a[aria-controls="sidebarApplications"]');
            if (applicationsCollapse && applicationsTrigger) {
                applicationsCollapse.classList.add("show");
                applicationsTrigger.classList.add("active");
                applicationsTrigger.setAttribute("aria-expanded", "true");
            }

            var handoverCollapse = document.getElementById("submenu-applications-handover");
            var handoverTrigger = document.querySelector('a[aria-controls="submenu-applications-handover"]');
            if (handoverCollapse && handoverTrigger) {
                handoverCollapse.classList.add("show");
                handoverTrigger.classList.add("active");
                handoverTrigger.setAttribute("aria-expanded", "true");
            }
        });
    })();
</script>
