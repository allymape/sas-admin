<!doctype html>
<html lang="en" data-layout="vertical" data-topbar="light" data-sidebar="dark" data-sidebar-size="lg">

    <head>
        
        <meta charset="utf-8" />
        <title>Verify Account | IRS - Institution Registration System</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
        <meta content="Themesbrand" name="author" />
        <!-- App favicon -->
        <link rel="shortcut icon" href="../design/assets/images/favicon.ico">

        <!-- Layout config Js -->
        <script src="../design/assets/js/layout.js"></script>
        <!-- Bootstrap Css -->
        <link href="../design/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
        <!-- Icons Css -->
        <link href="../design/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
        <!-- App Css-->
        <link href="../design/assets/css/app.min.css" rel="stylesheet" type="text/css" />
        <!-- custom Css-->
        <link href="../design/assets/css/custom.min.css" rel="stylesheet" type="text/css" />


    </head>

    <body>

        <div class="auth-page-wrapper pt-5">
            <!-- auth page bg -->
            <div class="auth-one-bg-position auth-one-bg"  id="auth-particles">
                <div class="bg-overlay"></div>
                
                <div class="shape">
                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 1440 120">
                        <path d="M 0,36 C 144,53.6 432,123.2 720,124 C 1008,124.8 1296,56.8 1440,40L1440 140L0 140z"></path>
                    </svg>
                </div>
            </div>

            <!-- auth page content -->
            <div class="auth-page-content">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="text-center mt-sm-5 mb-4 text-white-50">
                                <div>
                                    <p class="mt-3 fs-15 fw-medium">JAMHURI YA MUUNGANO WA TANZANIA</p>
                                    
                                    <a href="#" class="d-inline-block auth-logo">
                                        <img src="../design/assets/images/arm.png" alt="" height="100">
                                    </a>
                                </div>
                                <p class="mt-3 fs-15 fw-medium">WIZARA YA ELIMU SAYANSI NA TEKNOLOJIA</p>
                                <!-- <p class="mt-3 fs-15 fw-medium">Mfumo wa Uanzishaji na usajili  wa shule</p> -->
                            </div>
                        </div>
                    </div>
                    <!-- end row -->

                    <div class="row justify-content-center">
                        <div class="col-md-8 col-lg-6 col-xl-5">
                            <div class="card mt-4">
                            
                                <div class="card-body p-4"> 
                                    <div class="text-center mt-2">
                                        <% if(statusCode == 300){ %>
                                            <h5 class="text-primary">Karibu katika Mfumo wa Usajili wa Shule</h5>
                                        <% } %>
                                        <% if(statusCode == 306){ %>
                                            <h5 class="text-primary">Tumeshindwa kutambua taarifa zako, tafadhali wasiliana na System Administrator</h5>
                                        <% } %>
                                        <% if(statusCode == 400){ %>
                                            <h5 class="text-primary">Kuna Tatizo la kimtandao tafadhali jaribu tena baaadae au wasiliana na System Administrator</h5>
                                        <% } %>
                                        <!-- <p class="text-muted">Weka Upya Nenosiri hapa</p> -->

                                        <lord-icon
                                            src="https://cdn.lordicon.com/rhvddzym.json"
                                            trigger="loop"
                                            colors="primary:#0ab39c"
                                            class="avatar-xl">
                                        </lord-icon>

                                    </div>
                                    <% if(statusCode == 300){ %>
                                    <div class="alert alert-borderless alert-warning text-center mb-2 mx-2" role="alert">
                                        Bofya hapo chini kuendelea!
                                    </div>
                                    <% } %>
                                    <div class="p-2">
                                        <form action="/" method="GET">
                                            <!-- <div class="mb-4">
                                                <label class="form-label">Barua pepe</label>
                                                <input type="email" class="form-control email" id="email" name="email" placeholder="Weka barua pepe">
                                            </div> -->
                                            <% if(statusCode == 300){ %>
                                            <div class="text-center mt-4">
                                                <button class="btn btn-success w-100" type="submit">Endelea</button>
                                            </div>
                                            <% } %>
                                        </form><!-- end form -->
                                    </div>
                                </div>
                                <!-- end card body -->
                            </div>
                            <!-- end card -->

                            <!-- <div class="mt-4 text-center">
                                <p class="mb-0">Subiri, Nimekumbuka Nenosiri langu... <a href="/" class="fw-semibold text-primary text-decoration-underline"> Bofya hapa </a> </p>
                            </div> -->

                        </div>
                    </div>
                    <!-- end row -->
                </div>
                <!-- end container -->
            </div>
            <!-- end auth page content -->

            <!-- footer -->
            <footer class="footer">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="text-center">
                                <p class="mb-0 text-muted">&copy; <script>document.write(new Date().getFullYear())</script> SAS</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
            <!-- end Footer -->
        </div>
        <!-- end auth-page-wrapper -->

        <!-- JAVASCRIPT -->
        <script src="../design/assets/libs/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="../design/assets/libs/simplebar/simplebar.min.js"></script>
        <script src="../design/assets/libs/node-waves/waves.min.js"></script>
        <script src="../design/assets/libs/feather-icons/feather.min.js"></script>
        <script src="../design/assets/js/pages/plugins/lord-icon-2.1.0.js"></script>
        <script src="../design/assets/js/plugins.js"></script>

        <!-- particles js -->
        <script src="../design/assets/libs/particles.js/particles.js"></script>
        
        <!-- particles app js -->
        <script src="../design/assets/js/pages/particles.app.js"></script>
    </body>

</html>