<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'}
          ]
    }) %>

<script>
    const applyWrapTooltips = () => {
        document.querySelectorAll(".label-nowrap, #datatable thead th").forEach((element) => {
            const isTableHeader = element.matches("#datatable thead th");
            const existingTitle = String(element.getAttribute("title") || "").trim();
            const fullText = String(element.dataset.fullText || existingTitle || element.textContent || "").trim();
            element.dataset.fullText = fullText;
            const hasOverflow = element.scrollWidth > element.clientWidth;

            if (isTableHeader || hasOverflow) {
                element.setAttribute("title", fullText);
                element.setAttribute("data-bs-toggle", "tooltip");
                if (!bootstrap.Tooltip.getInstance(element)) {
                    new bootstrap.Tooltip(element, { container: "body" });
                }
            } else {
                const instance = bootstrap.Tooltip.getInstance(element);
                if (instance) instance.dispose();
                element.removeAttribute("title");
                element.removeAttribute("data-bs-toggle");
            }
        });
    };

    const calculateDerivedStudents = (mode = "create") => {
        const p = mode === "edit" ? "e" : "c";
        const maxPerStream = Number($(`#${p}-max-students-per-stream`).val() || 0);
        const minStreams = Number($(`#${p}-min-streams`).val() || 0);
        const maxStreamsPerSchool = Number($(`#${p}-max-streams-per-school`).val() || 0);
        const minTotalClasses = Number($(`#${p}-min-total-classes`).val() || 0);

        const studentsPerSingleStreamSchool = maxPerStream > 0 && minStreams > 0
            ? (maxPerStream * minStreams)
            : "";

        const maxPerClass = maxPerStream > 0 && maxStreamsPerSchool > 0
            ? (maxPerStream * maxStreamsPerSchool)
            : "";
        const maxPerSchool = maxPerClass !== "" && minTotalClasses > 0
            ? (Number(maxPerClass) * minTotalClasses)
            : "";

        $(`#${p}-students-per-single-stream-school`).val(studentsPerSingleStreamSchool);
        $(`#${p}-max-students-per-class`).val(maxPerClass);
        $(`#${p}-max-students-per-school`).val(maxPerSchool);
    };

    const toDbFieldName = (id = "") => (
        String(id || "")
            .replace(/^[ce]-/, "")
            .replace(/-/g, "_")
    );

    const attachDbFieldNames = () => {
        document
            .querySelectorAll("#showModal [id^='c-'], #showEditModal [id^='e-']")
            .forEach((input) => {
                if (!input || input.type === "hidden") return;
                if (!(input.classList.contains("form-control") || input.classList.contains("form-select"))) return;

                const wrapper = input.parentElement;
                if (!wrapper) return;
                if (wrapper.querySelector(`small[data-db-for='${input.id}']`)) return;

                const dbFieldName = toDbFieldName(input.id);
                const small = document.createElement("small");
                small.className = "text-muted db-field-name";
                small.dataset.dbFor = input.id;
                small.textContent = dbFieldName;
                input.insertAdjacentElement("afterend", small);
            });
    };

    let schoolTypeLookups = {
        school_categories: [],
        school_sub_categories: []
    };

    const setOptions = (selectId, items, selectedValue = "", placeholder = "-- Chagua --") => {
        const select = $(selectId);
        select.empty();
        select.append(`<option value="">${placeholder}</option>`);
        (items || []).forEach((item) => {
            const value = String(item.id || "");
            const selected = String(selectedValue || "") === value ? "selected" : "";
            select.append(`<option value="${value}" ${selected}>${item.name || ""}</option>`);
        });
    };

    const loadSchoolTypeLookups = (callback = null) => {
        ajaxRequest("/SchoolTypeStandardLookups", "GET", (response) => {
            if (Number(response?.statusCode || 306) === 300) {
                schoolTypeLookups = response?.data || {};
                setOptions("#c-school-category-id", schoolTypeLookups.school_categories, "");
                setOptions("#e-school-category-id", schoolTypeLookups.school_categories, "");
                setOptions("#c-school-sub-category-id", schoolTypeLookups.school_sub_categories, "", "-- Si lazima --");
                setOptions("#e-school-sub-category-id", schoolTypeLookups.school_sub_categories, "", "-- Si lazima --");
                if (typeof callback === "function") callback();
            } else {
                alertMessage("Tahadhari", response?.message || "Imeshindikana kuvuta lookups.", "warning");
            }
        }, {}, false);
    };

    const reloadTable = () => {
        $("#datatable").DataTable().ajax.reload(null, false);
    };

    const clearCreateForm = () => {
        $("#c-form-error").hide();
        $("#c-school-category-id").val("");
        $("#c-school-sub-category-id").val("");
        $("#c-education-track").val("");
        $("#c-min-plot-size-spread-acre").val("");
        $("#c-min-plot-size-storey-acre").val("");
        $("#c-max-plot-ratio").val("");
        $("#c-max-built-area-percent").val("");
        $("#c-max-storeys").val("");
        $("#c-min-front-setback-m").val("");
        $("#c-min-rear-setback-m").val("");
        $("#c-min-side-setback-m").val("");
        $("#c-max-students-per-stream").val("");
        $("#c-min-streams").val("");
        $("#c-students-per-single-stream-school").val("");
        $("#c-max-streams-per-school").val("");
        $("#c-max-students-per-class").val("");
        $("#c-min-total-classes").val("");
        $("#c-max-students-per-school").val("");
        $("#c-is-active").val("1");
        calculateDerivedStudents("create");
    };

    const payloadFromForm = (mode = "create") => {
        const p = mode === "edit" ? "e" : "c";
        return {
            school_category_id: $(`#${p}-school-category-id`).val(),
            school_sub_category_id: $(`#${p}-school-sub-category-id`).val(),
            education_track: $(`#${p}-education-track`).val(),
            min_plot_size_spread_acre: $(`#${p}-min-plot-size-spread-acre`).val(),
            min_plot_size_storey_acre: $(`#${p}-min-plot-size-storey-acre`).val(),
            max_plot_ratio: $(`#${p}-max-plot-ratio`).val(),
            max_built_area_percent: $(`#${p}-max-built-area-percent`).val(),
            max_storeys: $(`#${p}-max-storeys`).val(),
            min_front_setback_m: $(`#${p}-min-front-setback-m`).val(),
            min_rear_setback_m: $(`#${p}-min-rear-setback-m`).val(),
            min_side_setback_m: $(`#${p}-min-side-setback-m`).val(),
            max_students_per_stream: $(`#${p}-max-students-per-stream`).val(),
            min_streams: $(`#${p}-min-streams`).val(),
            students_per_single_stream_school: $(`#${p}-students-per-single-stream-school`).val(),
            max_streams_per_school: $(`#${p}-max-streams-per-school`).val(),
            max_students_per_class: $(`#${p}-max-students-per-class`).val(),
            min_total_classes: $(`#${p}-min-total-classes`).val(),
            max_students_per_school: $(`#${p}-max-students-per-school`).val(),
            is_active: $(`#${p}-is-active`).val(),
        };
    };

    $("#create-btn").on("click", function () {
        clearCreateForm();
        loadSchoolTypeLookups(() => {
            modal("showModal", true);
        });
    });

    function BadiliData(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        $("#e-form-error").hide();
        $("#e-id").val(rowData.id || "");

        loadSchoolTypeLookups(() => {
            $("#e-school-category-id").val(String(rowData.school_category_id || ""));
            $("#e-school-sub-category-id").val(String(rowData.school_sub_category_id || ""));
            $("#e-education-track").val(rowData.education_track || "");
            $("#e-min-plot-size-spread-acre").val(rowData.min_plot_size_spread_acre ?? "");
            $("#e-min-plot-size-storey-acre").val(rowData.min_plot_size_storey_acre ?? "");
