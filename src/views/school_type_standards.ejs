            calculateDerivedStudents("edit");
            modal("showEditModal", true);
        });
    }

    function sajiliKiwangoAinaYaShule() {
        const payload = payloadFromForm("create");
        if (!payload.school_category_id) {
            $("#c-form-error").text("Tafadhali chagua Aina ya Shule.").show();
            return;
        }

        $("#c-form-error").hide();
        ajaxRequest(
            "/tengenezaKiwangoAinaYaShule",
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showModal", false);
                            reloadTable();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function sasishaKiwangoAinaYaShule() {
        const id = Number($("#e-id").val() || 0);
        const payload = payloadFromForm("edit");

        if (!payload.school_category_id) {
            $("#e-form-error").text("Tafadhali chagua Aina ya Shule.").show();
            return;
        }

        if (!id) {
            $("#e-form-error").text("Kiwango hakijapatikana.").show();
            return;
        }

        $("#e-form-error").hide();
        ajaxRequest(
            `/badiliKiwangoAinaYaShule/${id}`,
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showEditModal", false);
                            reloadTable();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function FutaData(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        const id = Number(rowData.id || 0);
        if (!id) {
            alertMessage("Haujafanikiwa", "Kiwango hakijapatikana.", "warning");
            return;
        }

        confirmAction(
            () => {
                ajaxRequest(`/futaKiwangoAinaYaShule/${id}`, "POST", (response) => {
                    const statusCode = Number(response?.statusCode || 306);
                    alertMessage(
                        statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                        response?.message || "Kuna tatizo, jaribu tena.",
                        statusCode === 300 ? "success" : "warning",
                        () => {
                            if (statusCode === 300) {
                                reloadTable();
                            }
                        }
                    );
                });
            },
            "Futa",
            "warning",
            "Ukifuta taarifa hii, haitatumika tena kwenye setup.",
            "Futa Kiwango cha Aina ya Shule?"
        );
    }

