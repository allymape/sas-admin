<% var card_title = '' %>
<%- include('layouts/partials/header.ejs' , {
    title : 'Viwango vya Aina za Shule',
    page_title : 'Orodha ya Viwango vya Aina za Shule',
    card_title : 'Viwango vilivyosajiliwa',
    breadcrumb_main : 'Mipangilio',
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>
<style>
    .standards-table-wrap {
        border: 1px solid #e9ebec;
        border-radius: 8px;
        background: #ffffff;
        overflow: auto;
    }

    .label-nowrap {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .db-field-name {
        display: block;
        margin-top: 4px;
        font-size: 11px;
    }

    #datatable {
        width: 100% !important;
        min-width: 2100px;
    }

    #datatable th,
    #datatable td {
        white-space: normal !important;
        word-break: break-word;
        vertical-align: top;
    }

    #datatable thead th {
        font-size: 11px;
        font-weight: 700;
        line-height: 1.2;
        padding-top: 8px;
        padding-bottom: 8px;
        text-align: center;
        vertical-align: middle;
        background: #f8fafc !important;
        border-bottom: 1px solid #dfe5ec !important;
        position: sticky;
        top: 0;
        z-index: 4;
    }

    #datatable tbody td {
        font-size: 12px;
        line-height: 1.25;
    }

    #datatable tbody tr:nth-child(even) td {
        background-color: #fbfcff;
    }

    #datatable tbody tr:hover td {
        background-color: #f2f8ff;
    }

    #datatable th:first-child,
    #datatable td:first-child {
        position: sticky;
        left: 0;
        z-index: 5;
        background: #ffffff;
        box-shadow: 1px 0 0 #e9ebec;
    }

    #datatable thead th:first-child {
        z-index: 6;
        background: #f8fafc !important;
    }

    #datatable th:last-child,
    #datatable td:last-child {
        position: sticky;
        right: 0;
        z-index: 5;
        background: #ffffff;
        box-shadow: -1px 0 0 #e9ebec;
    }

    #datatable thead th:last-child {
        z-index: 6;
        background: #f8fafc !important;
    }
</style>
<div class="card-body">
