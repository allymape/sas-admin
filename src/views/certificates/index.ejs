<%- include('../layouts/partials/header.ejs' , {
  title : 'Vyeti',
  page_title : 'Vyeti (Usajili)',
  card_title : ''
}) %>

<style>
  .cert-hero { background: linear-gradient(135deg, rgba(13,110,253,.08), rgba(25,135,84,.06)); border: 1px solid rgba(0,0,0,.06); }
  .cert-tabs .nav-link { font-weight: 700; }
  .cert-search { min-width: 280px; }
  .cert-metric { border: 1px solid rgba(0,0,0,.06); background: #fff; }
  .cert-table thead th { position: sticky; top: 0; z-index: 1; background: #f8fafc; }
  .cert-code { background: #0f172a; color: #fff; padding: 2px 8px; border-radius: 6px; font-size: .85rem; }
  .cert-muted { color: #64748b; }
  .cert-empty { border: 1px dashed rgba(0,0,0,.15); background: rgba(248,250,252,.8); }
</style>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header border-0 pb-0">
        <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
          <div class="d-flex align-items-center gap-2">
            <span class="avatar-sm rounded bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center">
              <i class="ri-award-line fs-16"></i>
            </span>
            <div>
              <h5 class="card-title mb-0">Vyeti (Usajili)</h5>
              <div class="cert-muted small">Hapa ndipo unatoa vyeti na kuona vilivyotolewa.</div>
            </div>
          </div>

          <form method="GET" action="/vyeti" class="d-flex flex-wrap gap-2 align-items-center">
            <input type="hidden" name="tab" value="<%= tab %>">
            <div class="input-group input-group-sm" style="min-width:340px">
              <span class="input-group-text bg-white"><i class="ri-search-2-line"></i></span>
              <input type="text" class="form-control cert-search" name="search" value="<%= search || '' %>" placeholder="Tafuta: Tracking #, Jina la shule, Reg #">
              <button class="btn btn-primary text-white" type="submit">Tafuta</button>
            </div>
            <% if (search) { %>
              <a class="btn btn-sm btn-light" href="/vyeti?tab=<%= tab %>">
                <i class="ri-close-line align-bottom me-1"></i> Futa
              </a>
            <% } %>
          </form>
        </div>

        <div class="cert-hero rounded p-3 mt-3">
          <div class="row g-3 align-items-center">
            <div class="col-lg-6">
              <div class="fw-semibold">Muhtasari</div>
              <div class="cert-muted small">Chagua <b>Vinavyosubiri</b> ili kutoa cheti, au <b>Vilivyotolewa</b> ili ku-view cheti.</div>
              <div class="mt-2">
                <span class="badge bg-primary-subtle text-primary me-1">Security: QR + Verification Code</span>
                <span class="badge bg-success-subtle text-success me-1">PDF Preview (Modal)</span>
                <span class="badge bg-warning-subtle text-warning">Reg # ni lazima ili kutoa</span>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                <div class="cert-metric rounded px-3 py-2">
                  <div class="cert-muted small">Tab</div>
                  <div class="fw-bold"><%= tab === 'pending' ? 'Vinavyosubiri' : 'Vilivyotolewa' %></div>
                </div>
                <div class="cert-metric rounded px-3 py-2">
                  <div class="cert-muted small">Jumla</div>
                  <div class="fw-bold"><%= Number(pagination?.total || rows?.length || 0).toLocaleString() %></div>
                </div>
                <div class="cert-metric rounded px-3 py-2">
                  <div class="cert-muted small">Ukurasa</div>
                  <div class="fw-bold"><%= Number(pagination?.current_page || 1) %> / <%= Number(pagination?.last_page || 1) %></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="card-body">
        <% if (message) { %>
          <div class="alert alert-warning"><%= message %></div>
        <% } %>

        <ul class="nav nav-tabs nav-tabs-custom gap-1 cert-tabs mb-3" role="tablist">
          <li class="nav-item">
            <a class="nav-link <%= tab === 'pending' ? 'active' : '' %>" href="/vyeti?tab=pending<%= search ? `&search=${encodeURIComponent(search)}` : '' %>">
              <i class="ri-time-line align-bottom me-1"></i> Vinavyosubiri
              <% if (tab === 'pending') { %>
                <span class="badge bg-primary ms-2"><%= Number(pagination?.total || 0).toLocaleString() %></span>
              <% } %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= tab === 'issued' ? 'active' : '' %>" href="/vyeti?tab=issued<%= search ? `&search=${encodeURIComponent(search)}` : '' %>">
              <i class="ri-checkbox-circle-line align-bottom me-1"></i> Vilivyotolewa
              <% if (tab === 'issued') { %>
                <span class="badge bg-success ms-2"><%= Number(pagination?.total || 0).toLocaleString() %></span>
              <% } %>
            </a>
          </li>
        </ul>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle cert-table">
            <thead>
		              <tr>
		                <th>Tracking #</th>
		                <th>Jina la Shule</th>
		                <th>Mmiliki</th>
		                <th>Halmashauri</th>
		                <% if (tab === 'issued') { %>
		                  <th>Cheti #</th>
		                  <th>Imetolewa</th>
		                  <th>Imebatilishwa</th>
		                <% } %>
		                <th class="text-end">Hatua</th>
		              </tr>
            </thead>
            <tbody>
		              <% if (!rows || rows.length === 0) { %>
		                <tr>
		                  <td colspan="<%= tab === 'issued' ? 8 : 5 %>" class="py-4">
		                    <div class="cert-empty rounded p-4 text-center">
		                      <div class="mb-2">
		                        <span class="avatar-md rounded-circle bg-light d-inline-flex align-items-center justify-content-center">
		                          <i class="ri-inbox-2-line fs-22 text-muted"></i>
		                        </span>
	                      </div>
	                      <div class="fw-semibold">Hakuna taarifa</div>
	                      <div class="cert-muted small">Jaribu kubadili tab au kutafuta kwa Tracking # / Reg #.</div>
	                    </div>
	                  </td>
	                </tr>
	              <% } %>

              <% (rows || []).forEach((r) => { %>
                <tr>
                  <td>
                    <span class="cert-code"><%= r.application_tracking_number || r.tracking_number || '-' %></span>
	                  </td>
	                  <td>
	                    <div class="fw-semibold"><%= (r.school_name || '-').toUpperCase() %></div>
	                    <% if (r.registration_number) { %>
	                      <div class="cert-muted small">Reg #: <%= (r.registration_number || '').toUpperCase() %></div>
	                    <% } %>
	                    <% if (r.file_number || r.school_folio || r.folio) { %>
	                      <div class="cert-muted small">FILE/FOLIO: <%= [r.file_number, r.school_folio, r.folio].filter(Boolean).join('/').toUpperCase() %></div>
	                    <% } %>
	                  </td>
	                  <td>
	                    <div class="fw-semibold"><%= (r.owner_name || '-').toUpperCase() %></div>
	                    <% const addrParts = []; %>
	                    <% const boxNum = String(r.owner_box || '').match(/\\d+/); %>
	                    <% if (boxNum && boxNum[0]) addrParts.push(`S.L.P ${boxNum[0]}`); %>
	                    <% if (r.owner_lga) addrParts.push(r.owner_lga); %>
	                    <% if (r.owner_region) addrParts.push(r.owner_region); %>
	                    <% if (addrParts.length) { %>
	                      <div class="cert-muted small">ANWANI: <%= String(addrParts.join(', ')).toUpperCase() %></div>
	                    <% } %>
	                    <% if (r.registration_date) { %>
	                      <div class="cert-muted small">IMESAJILIWA: <%= dateFormat(r.registration_date, "DD MMM YYYY") %></div>
	                    <% } %>
	                  </td>
	                  <td><%= ([r.council_ngazi, r.council].filter(Boolean).join(' ') || '-').toUpperCase() %></td>
                  <% if (tab === 'issued') { %>
                    <td><%= r.certificate_number || '-' %></td>
                    <td>
                      <div class="fw-semibold"><%= (r.issued_by_name || '-').toUpperCase() %></div>
                      <div class="cert-muted small"><%= r.issued_at ? dateFormat(r.issued_at, "DD MMM YYYY, HH:mm") : '-' %></div>
                    </td>
                    <td>
                      <% if (Number(r.is_revoked || 0) === 1) { %>
                        <div class="fw-semibold text-danger"><%= (r.revoked_by_name || '-').toUpperCase() %></div>
                        <div class="cert-muted small"><%= r.revoked_at ? dateFormat(r.revoked_at, "DD MMM YYYY, HH:mm") : '-' %></div>
                      <% } else { %>
                        <span class="badge bg-success-subtle text-success">HAIJABATILISHWA</span>
                      <% } %>
	                    </td>
	                  <% } %>
	                  <td class="text-end">
                    <% if (tab === 'pending') { %>
                      <form class="js-issue-form" method="POST" action="/vyeti/issue/<%= encodeURIComponent(r.application_tracking_number || r.tracking_number) %>" style="display:inline">
                        <input type="hidden" name="expected_year" value="">
                        <input type="hidden" name="expected_seq" value="">
                        <button
                          class="btn btn-sm btn-primary text-white js-issue-btn"
                          type="submit"
                          data-tracking-number="<%= r.application_tracking_number || r.tracking_number || '' %>"
                          data-school-name="<%= (r.school_name || '').replace(/\"/g, '&quot;') %>"
                          data-registration-number="<%= (r.registration_number || '').replace(/\"/g, '&quot;') %>"
                          <%= !r.registration_number ? 'disabled title=\"Huwezi kutoa cheti: Shule haina namba ya usajili (Reg #).\"' : '' %>
                        >
                          <i class="ri-award-line align-bottom me-1"></i> Issue
                        </button>
                      </form>
                    <% } else { %>
                      <a class="btn btn-sm btn-soft-info js-open-pdf-modal" href="/cheti/<%= encodeURIComponent(r.application_tracking_number || r.tracking_number) %>">
                        <i class="ri-eye-line align-bottom"></i> Tazama
                      </a>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

	        <% if (pagination && pagination.last_page && Number(pagination.last_page) > 1) { %>
	          <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mt-3">
	            <form method="GET" action="/vyeti" class="d-flex align-items-center gap-2">
	              <% const pp = Number(pagination?.per_page || 15); %>
	              <input type="hidden" name="tab" value="<%= tab %>">
	              <% if (search) { %><input type="hidden" name="search" value="<%= search %>"><% } %>
	              <span class="cert-muted small">Kwa ukurasa</span>
	              <select class="form-select form-select-sm" name="per_page" style="width:110px" onchange="this.form.submit()">
	                <% [10,15,20,50,100].forEach((n)=>{ %>
	                  <option value="<%= n %>" <%= pp===n ? 'selected' : '' %>><%= n %></option>
	                <% }) %>
	              </select>
	            </form>

	            <nav aria-label="Pagination">
	              <ul class="pagination pagination-sm mb-0">
	                <% const current = Number(pagination.current_page) || 1; %>
	                <% const last = Number(pagination.last_page) || 1; %>
	                <% const baseParams = new URLSearchParams({ tab: tab, per_page: String(pagination.per_page || 15) }); %>
	                <% if (search) baseParams.set('search', search); %>
	                <% const pageHref = (p) => { const qp = new URLSearchParams(baseParams.toString()); qp.set('page', String(p)); return `/vyeti?${qp.toString()}`; }; %>

	                <li class="page-item <%= current <= 1 ? 'disabled' : '' %>">
	                  <a class="page-link" href="<%= pageHref(Math.max(1, current - 1)) %>">Prev</a>
	                </li>
	                <li class="page-item disabled">
	                  <span class="page-link"><%= current %> / <%= last %></span>
	                </li>
	                <li class="page-item <%= current >= last ? 'disabled' : '' %>">
	                  <a class="page-link" href="<%= pageHref(Math.min(last, current + 1)) %>">Next</a>
	                </li>
	              </ul>
	            </nav>
	          </div>
	        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="pdfPreviewModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Cheti (PDF)</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <iframe id="pdfPreviewFrame" src="" style="width:100%; height:80vh; border:0;"></iframe>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/partials/footer.ejs' , { card_title : '' , pagination_script : false, }) %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const modalEl = document.getElementById("pdfPreviewModal");
    const frame = document.getElementById("pdfPreviewFrame");
    if (modalEl && frame && window.bootstrap) {
      const modal = bootstrap.Modal.getOrCreateInstance(modalEl, { backdrop: "static", keyboard: false });
      document.addEventListener("click", function (e) {
        const link = e.target && e.target.closest ? e.target.closest("a.js-open-pdf-modal") : null;
        if (!link) return;
        const href = link.getAttribute("href");
        if (!href) return;
        e.preventDefault();
        frame.src = href;
        modal.show();
      });
      modalEl.addEventListener("hidden.bs.modal", function () { frame.src = ""; });
    }

    const preview = <%- JSON.stringify(preview || "") %>;
    const tab = <%- JSON.stringify(tab || "") %>;
    if (preview && tab === "issued" && modalEl && frame && window.bootstrap) {
      const modal = bootstrap.Modal.getOrCreateInstance(modalEl, { backdrop: "static", keyboard: false });
      frame.src = "/cheti/" + encodeURIComponent(preview);
      modal.show();
    }

    // SweetAlert confirm before issuing certificate.
    (function () {
      const hasSweetAlert = () => Boolean(window.Swal && typeof window.Swal.fire === "function");
      const issueButtons = Array.from(document.querySelectorAll(".js-issue-btn"));
      if (!issueButtons.length) return;

      const fetchPreview = async (trackingNumber) => {
        const res = await fetch(`/vyeti/issue-preview/${encodeURIComponent(trackingNumber)}`, {
          method: "GET",
          headers: { "Accept": "application/json" },
        });
        const json = await res.json();
        if (!res.ok || json?.success === false) {
          throw new Error(json?.message || "Imeshindikana kupata preview ya cheti.");
        }
        return json?.data || {};
      };

      const confirmIssue = async (payload) => {
        const schoolName = String(payload.school_name || "").trim();
        const regNo = String(payload.registration_number || "").trim();
        const certNo = String(payload.certificate_number || "").trim();
        const text = `Unakaribia kutoa cheti cha "${schoolName || 'Shule'}" yenye namba ya usajili "${regNo || '-'}" na kitakuwa na certificate number "${certNo || '-'}". Je unataka kuendelea?`;

        if (!hasSweetAlert()) return window.confirm(text);

        const result = await window.Swal.fire({
          title: "Thibitisha Utoaji wa Cheti",
          text,
          icon: "question",
          showCancelButton: true,
          confirmButtonText: "Ndio, Endelea",
          cancelButtonText: "Hapana",
          confirmButtonClass: "btn btn-primary w-xs me-2",
          cancelButtonClass: "btn btn-light w-xs",
          buttonsStyling: false,
        });
        return Boolean(result?.isConfirmed);
      };

      issueButtons.forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          const form = btn.closest("form");
          if (!form) return;
          e.preventDefault();

          const trackingNumber = btn.getAttribute("data-tracking-number") || "";
          if (!trackingNumber) return;

          btn.disabled = true;
          const originalHtml = btn.innerHTML;
          btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Inapanga...';

          try {
            const preview = await fetchPreview(trackingNumber);
            const ok = await confirmIssue(preview);
            if (!ok) return;

            const yearInput = form.querySelector("input[name='expected_year']");
            const seqInput = form.querySelector("input[name='expected_seq']");
            if (yearInput) yearInput.value = String(preview.year || "");
            if (seqInput) seqInput.value = String(preview.next_seq || "");

            form.submit();
          } catch (error) {
            const message = String(error?.message || "Imeshindikana ku-issue cheti.");
            if (hasSweetAlert()) {
              window.Swal.fire({
                title: "Imeshindikana",
                text: message,
                icon: "error",
                confirmButtonText: "Sawa",
                confirmButtonClass: "btn btn-danger w-xs",
                buttonsStyling: false,
              });
            } else {
              alert(message);
            }
          } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
          }
        });
      });
    })();
  });
</script>
