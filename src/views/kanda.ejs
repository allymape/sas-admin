                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/kanda_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    $(document).ready(function() {
        tableData('datatable' ,'/Zones' , 'POST',
            [
                    { data: null, // No data source for this column
                        render: function (data, type, row , meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    { data: "zone_name", name: "zone_name" },
                    { data: "zone_code", name: "zone_code" },
                    { data: "box", name: "box", defaultContent: "", render: (data) => {
                        return data == null || data === 0 ? "" : `S.L.P ${data}`;
                    } },
                    {
                      data: "created_at", name: "created_at",
                            render: (data, type, row) => {
                                return data ? changeDateFormat(data) : "";
                            },
                    },
                    {
                    data: "updated_at", name: "updated_at",
                            render: (data, type, row) => {
                                if(data ){
                                    return changeDateFormat(data);
                                }
                                return ""
                            },
                    },
                    { data: "status_id", defaultContent: 0, render: (data, type, row) => {
                        return data == 1 
                            ? '<span class="badge bg-success">Active</span>' 
                            : '<span class="badge bg-danger">Inactive</span>';
                    } },
                    {
                    data: null,
                    defaultContent: "",
                    render: function (data, type, row) {
                            const elements = [
                                            {
                                                show : true,
                                                type : 'link',
                                                class : 'btn btn-sm btn-outline-primary me-1',
                                                icon : 'bx bx-pencil me-1',
                                                function : 'badiliKanda',
                                                btnText : 'Edit'
                                            },
                                            {
                                                show : true,
                                                type : 'link',
                                                class : 'btn btn-sm btn-outline-danger',
                                                icon : 'bx bx-trash me-1',
                                                function : 'futaKanda',
                                                btnText : 'Futa'
                                            },
                                        ];
                             return actionButtons(row , elements);
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    searchable: false, // Disable searching for the action buttons column
                    },
            ]
        );
    });
</script>
