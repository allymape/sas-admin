<%
  const isCreate = mode === "create";
  const a = item || {};
  const templateKey = isCreate ? "" : (a.template_key || "");
  const addressKindValue = String(a.address_kind || "").trim().toLowerCase();
%>

<%- include('../layouts/partials/header.ejs' , {
  title : 'Addressee Format',
  page_title : isCreate ? 'Ongeza Addressee Format' : `Edit Addressee Format - ${templateKey || a.id || ''}`,
  card_title : ''
}) %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0"><%= isCreate ? 'Format Mpya' : 'Hariri Format' %></h5>
        <div class="d-flex gap-2">
          <a href="/letter-addressee-templates" class="btn btn-sm btn-soft-secondary">
            <i class="ri-arrow-left-line align-bottom me-1"></i> Rudi
          </a>
        </div>
      </div>
      <div class="card-body">
        <div class="alert alert-info mb-3">
          Variables zinazotumika hapa (mfano): <code>{{address_title}}</code>, <code>{{address_name}}</code>,
          <code>{{address_box}}</code>, <code>{{address_region}}</code>.
        </div>

        <form method="POST" action="<%= isCreate ? '/letter-addressee-templates' : `/letter-addressee-templates/${a.id}` %>">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Template Key</label>
              <input
                type="text"
                class="form-control"
                name="template_key"
                value="<%= templateKey %>"
                <%= isCreate ? '' : 'readonly' %>
                placeholder="mfano: addressee_taasisi"
                required
              />
              <div class="form-text">Key ni unique (haitakiwi kurudiwa).</div>
            </div>

            <div class="col-md-8">
              <label class="form-label">Jina</label>
              <input type="text" class="form-control" name="name" value="<%= a.name || '' %>" required />
            </div>

            <div class="col-md-4">
              <label class="form-label">Address Kind</label>
              <%
                const knownKinds = [
                  { value: "", label: "(None)" },
                  { value: "binafsi", label: "Binafsi" },
                  { value: "taasisi", label: "Taasisi" },
                ];
                const isKnownKind = knownKinds.some((x) => x.value === addressKindValue);
              %>
              <select class="form-control js-example-basic-single" name="address_kind">
                <% knownKinds.forEach((x) => { %>
                  <option value="<%= x.value %>" <%= x.value === addressKindValue ? "selected" : "" %>><%= x.label %></option>
                <% }) %>
                <% if (addressKindValue && !isKnownKind) { %>
                  <option value="<%= addressKindValue %>" selected><%= addressKindValue %> (Custom)</option>
                <% } %>
              </select>
              <div class="form-text">Unaweza kutumia hii kama tag ya kuonyesha aina ya anwani.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label d-block">Status</label>
              <div class="form-check form-switch mt-2">
                <input
                  class="form-check-input"
                  type="checkbox"
                  role="switch"
                  id="isActiveSwitch"
                  name="is_active"
                  value="1"
                  <%= (typeof a.is_active === 'undefined' || Number(a.is_active) === 1) ? 'checked' : '' %>
                />
                <label class="form-check-label" for="isActiveSwitch">Active</label>
              </div>
              <div class="form-text">Ukiizima, format haitaonekana kwenye list ya kuchagua kwenye templates.</div>
            </div>

            <div class="col-12">
              <label class="form-label">Addressee Template</label>
              <textarea
                class="form-control"
                name="addressee_template"
                rows="7"
                placeholder="{{address_title}},&#10;{{address_name}},&#10;S.L.P {{address_box}},&#10;{{address_region}}."
                required
              ><%= a.addressee_template || '' %></textarea>
              <div class="form-text">
                Kila mstari ni line moja ya anwani. Mfano:
                <code>{{address_title}}</code>, <code>{{address_name}}</code>, <code>S.L.P {{address_box}}</code>, <code>{{address_region}}</code>.
              </div>
            </div>

            <div class="col-12 d-flex justify-content-end gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="ri-save-line align-bottom me-1"></i> Hifadhi
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/partials/footer.ejs' , { card_title : '' , pagination_script : false, }) %>

