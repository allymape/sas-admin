<% var card_title = '' %>
<%- include('layouts/partials/header.ejs' , {
    title : 'Viwango vya Miundombinu',
    page_title : 'Usimamizi wa Viwango vya Miundombinu',
    card_title : 'Kiwango cha Miundombinu',
    breadcrumb_main : 'Mipangilio',
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>

<ul class="nav nav-pills nav-customs nav-danger mb-3" id="infra-tabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" id="infra-items-tab" data-bs-toggle="tab" data-bs-target="#infra-items-pane" type="button" role="tab" aria-controls="infra-items-pane" aria-selected="true">
            Vipengele vya Miundombinu
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="infra-standards-tab" data-bs-toggle="tab" data-bs-target="#infra-standards-pane" type="button" role="tab" aria-controls="infra-standards-pane" aria-selected="false">
            Viwango vya Miundombinu ya Shule
        </button>
    </li>
</ul>

<div class="tab-content" id="infra-tabs-content">
    <div class="tab-pane fade show active" id="infra-items-pane" role="tabpanel" aria-labelledby="infra-items-tab" tabindex="0">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Vipengele vya Miundombinu</h4>
                <button type="button" class="btn btn-success btn-sm" id="create-item-btn">
                    <i class="ri-add-line align-bottom me-1"></i> Ongeza Kipengele
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive table-card mt-1 mb-1">
                    <table class="table align-middle table-nowrap" id="items-datatable">
                        <thead class="table-light">
                            <tr>
                                <th width="5%">Na.</th>
                                <th>Msimbo</th>
                                <th>Jina</th>
                                <th>Kundi</th>
                                <th>Kipimo</th>
                                <th>Hali</th>
                                <th>Imesasishwa</th>
                                <th class="text-center" width="12%">Vitendo</th>
                            </tr>
                        </thead>
                        <tbody class="list form-check-all"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="infra-standards-pane" role="tabpanel" aria-labelledby="infra-standards-tab" tabindex="0">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Viwango vya Miundombinu ya Shule</h4>
                <button type="button" class="btn btn-primary btn-sm" id="create-standard-btn">
                    <i class="ri-add-line align-bottom me-1"></i> Ongeza Kiwango
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive table-card mt-1 mb-1">
                    <table class="table align-middle table-nowrap" id="standards-datatable">
                        <thead class="table-light">
                            <tr>
                                <th width="5%">Na.</th>
                                <th>Aina ya Shule</th>
                                <th>Aina ya Malazi</th>
                                <th>Tahasusi</th>
                                <th>Jinsia</th>
                                <th>Mkondo</th>
                                <th>Kipengele</th>
                                <th>Idadi</th>
                                <th>Hali</th>
                                <th>Imesasishwa</th>
                                <th class="text-center" width="12%">Vitendo</th>
                            </tr>
                        </thead>
                        <tbody class="list form-check-all"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="showItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title">Sajili Kipengele cha Miundombinu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Msimbo *</label>
                            <input type="text" id="c-item-code" class="form-control" maxlength="50" placeholder="Mfano: CLASSROOM" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Jina *</label>
                            <input type="text" id="c-item-name" class="form-control" placeholder="Mfano: Chumba cha Darasa" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kundi</label>
                            <input type="text" id="c-item-group-name" class="form-control" placeholder="Mfano: Madarasa" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kipimo</label>
                            <input type="text" id="c-item-unit" class="form-control" value="count" placeholder="Mfano: count" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Maelezo</label>
                            <textarea id="c-item-description" class="form-control" rows="3" placeholder="Mfano: Idadi ya vyumba vinavyotakiwa kwa shule."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hali</label>
                            <select id="c-item-is-active" class="form-select">
                                <option value="1">Inatumika</option>
                                <option value="0">Imesitishwa</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-2 text-danger" id="c-item-error" style="display:none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                    <button type="button" class="btn btn-success" onclick="sajiliKipengeleMiundombinu()">Sajili</button>
                </div>
            </form>
        </div>
    </div>
</div>

