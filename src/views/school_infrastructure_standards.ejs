<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'}
          ]
    }) %>

<script>
    let infraLookups = {
        school_categories: [],
        school_sub_categories: [],
        school_specializations: [],
        school_gender_types: [],
        infrastructure_items: [],
        stream_bands: []
    };

    const streamBandLabel = (value) => {
        if (value === "single_stream") return "Mkondo Mmoja";
        if (value === "multiple_stream") return "Mikondo Mingi";
        return value || "-";
    };

    const setOptions = (selectId, items, selectedValue = "", placeholder = "-- Chagua --") => {
        const select = $(selectId);
        select.empty();
        select.append(`<option value="">${placeholder}</option>`);
        (items || []).forEach((item) => {
            const value = String(item.id || item.value || "");
            const selected = String(selectedValue || "") === value ? "selected" : "";
            const label = item.name || item.label || "";
            select.append(`<option value="${value}" ${selected}>${label}</option>`);
        });
    };

    const loadInfraLookups = (callback = null) => {
        ajaxRequest("/SchoolInfrastructureStandardLookups", "GET", (response) => {
            if (Number(response?.statusCode || 306) === 300) {
                infraLookups = response?.data || {};

                const streams = (infraLookups.stream_bands || []).map((stream) => ({
                    value: stream,
                    label: streamBandLabel(stream)
                }));

                setOptions("#c-std-school-category-id", infraLookups.school_categories, "");
                setOptions("#e-std-school-category-id", infraLookups.school_categories, "");

                setOptions("#c-std-school-sub-category-id", infraLookups.school_sub_categories, "", "-- Si lazima --");
                setOptions("#e-std-school-sub-category-id", infraLookups.school_sub_categories, "", "-- Si lazima --");

                setOptions("#c-std-school-specialization-id", infraLookups.school_specializations, "", "-- Si lazima --");
                setOptions("#e-std-school-specialization-id", infraLookups.school_specializations, "", "-- Si lazima --");

                setOptions("#c-std-school-gender-type-id", infraLookups.school_gender_types, "", "-- Si lazima --");
                setOptions("#e-std-school-gender-type-id", infraLookups.school_gender_types, "", "-- Si lazima --");

                setOptions("#c-std-stream-band", streams, "");
                setOptions("#e-std-stream-band", streams, "");

                const itemOptions = (infraLookups.infrastructure_items || []).map((item) => ({
                    id: item.id,
                    name: `${item.code || ""} - ${item.name || ""}`
                }));
                setOptions("#c-std-infrastructure-item-id", itemOptions, "");
                setOptions("#e-std-infrastructure-item-id", itemOptions, "");

                if (typeof callback === "function") callback();
            } else {
                alertMessage("Tahadhari", response?.message || "Imeshindikana kuvuta lookups.", "warning");
            }
        }, {}, false);
    };

    const reloadItemsTable = () => {
        $("#items-datatable").DataTable().ajax.reload(null, false);
    };

    const reloadStandardsTable = () => {
        $("#standards-datatable").DataTable().ajax.reload(null, false);
    };

    const payloadFromItemForm = (mode = "create") => {
        const p = mode === "edit" ? "e" : "c";
        return {
            code: $(`#${p}-item-code`).val(),
            name: $(`#${p}-item-name`).val(),
            group_name: $(`#${p}-item-group-name`).val(),
            unit: $(`#${p}-item-unit`).val(),
            description: $(`#${p}-item-description`).val(),
            is_active: $(`#${p}-item-is-active`).val(),
        };
    };

    const payloadFromStandardForm = (mode = "create") => {
        const p = mode === "edit" ? "e" : "c";
        return {
            school_category_id: $(`#${p}-std-school-category-id`).val(),
            school_sub_category_id: $(`#${p}-std-school-sub-category-id`).val(),
            school_specialization_id: $(`#${p}-std-school-specialization-id`).val(),
            school_gender_type_id: $(`#${p}-std-school-gender-type-id`).val(),
            stream_band: $(`#${p}-std-stream-band`).val(),
            infrastructure_item_id: $(`#${p}-std-infrastructure-item-id`).val(),
            required_quantity: $(`#${p}-std-required-quantity`).val(),
            notes: $(`#${p}-std-notes`).val(),
            is_active: $(`#${p}-std-is-active`).val(),
        };
    };

    const clearItemCreateForm = () => {
        $("#c-item-error").hide();
        $("#c-item-code").val("");
        $("#c-item-name").val("");
        $("#c-item-group-name").val("");
        $("#c-item-unit").val("count");
        $("#c-item-description").val("");
        $("#c-item-is-active").val("1");
    };

    const clearStandardCreateForm = () => {
        $("#c-std-error").hide();
        $("#c-std-school-category-id").val("");
        $("#c-std-school-sub-category-id").val("");
        $("#c-std-school-specialization-id").val("");
        $("#c-std-school-gender-type-id").val("");
        $("#c-std-stream-band").val("");
        $("#c-std-infrastructure-item-id").val("");
        $("#c-std-required-quantity").val("");
        $("#c-std-notes").val("");
        $("#c-std-is-active").val("1");
    };

    $("#create-item-btn").on("click", function () {
        clearItemCreateForm();
        modal("showItemModal", true);
    });

    $("#create-standard-btn").on("click", function () {
        clearStandardCreateForm();
        loadInfraLookups(() => {
            modal("showStandardModal", true);
        });
    });

    function sajiliKipengeleMiundombinu() {
        const payload = payloadFromItemForm("create");
        if (!payload.code || !payload.name) {
            $("#c-item-error").text("Code na Jina ni lazima.").show();
            return;
        }

        $("#c-item-error").hide();
        ajaxRequest(
            "/tengenezaKipengeleMiundombinu",
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showItemModal", false);
                            reloadItemsTable();
                            loadInfraLookups();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function BadiliItem(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        $("#e-item-error").hide();
        $("#e-item-id").val(rowData.id || "");
        $("#e-item-code").val(rowData.code || "");
        $("#e-item-name").val(rowData.name || "");
        $("#e-item-group-name").val(rowData.group_name || "");
        $("#e-item-unit").val(rowData.unit || "count");
        $("#e-item-description").val(rowData.description || "");
        $("#e-item-is-active").val(Number(rowData.is_active) === 0 ? "0" : "1");
        modal("showEditItemModal", true);
    }

    function sasishaKipengeleMiundombinu() {
        const id = Number($("#e-item-id").val() || 0);
        const payload = payloadFromItemForm("edit");

        if (!id) {
            $("#e-item-error").text("Kipengele hakijapatikana.").show();
            return;
        }

        if (!payload.code || !payload.name) {
            $("#e-item-error").text("Code na Jina ni lazima.").show();
            return;
        }

        $("#e-item-error").hide();
        ajaxRequest(
            `/badiliKipengeleMiundombinu/${id}`,
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showEditItemModal", false);
                            reloadItemsTable();
                            loadInfraLookups();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function FutaItem(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        const id = Number(rowData.id || 0);
        if (!id) {
            alertMessage("Haujafanikiwa", "Kipengele hakijapatikana.", "warning");
            return;
        }

        confirmAction(
            () => {
                ajaxRequest(`/futaKipengeleMiundombinu/${id}`, "POST", (response) => {
                    const statusCode = Number(response?.statusCode || 306);
                    alertMessage(
                        statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                        response?.message || "Kuna tatizo, jaribu tena.",
                        statusCode === 300 ? "success" : "warning",
                        () => {
                            if (statusCode === 300) {
                                reloadItemsTable();
                                loadInfraLookups();
                            }
                        }
                    );
                });
            },
            "Futa",
            "warning",
            "Ukifuta kipengele hiki, kitaondoka kwenye setup ya viwango.",
            "Futa Kipengele cha Miundombinu?"
        );
    }

    function sajiliKiwangoMiundombinu() {
        const payload = payloadFromStandardForm("create");
        if (!payload.school_category_id || !payload.stream_band || !payload.infrastructure_item_id || payload.required_quantity === "") {
            $("#c-std-error").text("Jaza Aina ya Shule, Band, Kipengele na Idadi Inayotakiwa.").show();
            return;
        }

        $("#c-std-error").hide();
        ajaxRequest(
            "/tengenezaKiwangoMiundombinu",
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showStandardModal", false);
                            reloadStandardsTable();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function BadiliStandard(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        $("#e-std-error").hide();
        $("#e-std-id").val(rowData.id || "");

        loadInfraLookups(() => {
            $("#e-std-school-category-id").val(String(rowData.school_category_id || ""));
            $("#e-std-school-sub-category-id").val(String(rowData.school_sub_category_id || ""));
            $("#e-std-school-specialization-id").val(String(rowData.school_specialization_id || ""));
            $("#e-std-school-gender-type-id").val(String(rowData.school_gender_type_id || ""));
            $("#e-std-stream-band").val(rowData.stream_band || "");
            $("#e-std-infrastructure-item-id").val(String(rowData.infrastructure_item_id || ""));
            $("#e-std-required-quantity").val(rowData.required_quantity ?? "");
            $("#e-std-notes").val(rowData.notes || "");
            $("#e-std-is-active").val(Number(rowData.is_active) === 0 ? "0" : "1");
            modal("showEditStandardModal", true);
        });
    }

    function sasishaKiwangoMiundombinu() {
        const id = Number($("#e-std-id").val() || 0);
        const payload = payloadFromStandardForm("edit");

        if (!id) {
            $("#e-std-error").text("Kiwango hakijapatikana.").show();
            return;
        }

        if (!payload.school_category_id || !payload.stream_band || !payload.infrastructure_item_id || payload.required_quantity === "") {
            $("#e-std-error").text("Jaza Aina ya Shule, Band, Kipengele na Idadi Inayotakiwa.").show();
            return;
        }

        $("#e-std-error").hide();
        ajaxRequest(
            `/badiliKiwangoMiundombinu/${id}`,
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                alertMessage(
                    statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Kuna tatizo, jaribu tena.",
                    statusCode === 300 ? "success" : "warning",
                    () => {
                        if (statusCode === 300) {
                            modal("showEditStandardModal", false);
                            reloadStandardsTable();
                        }
                    }
                );
            },
            JSON.stringify(payload)
        );
    }

    function FutaStandard(button) {
        const rowData = JSON.parse(button.getAttribute("data-row"));
        const id = Number(rowData.id || 0);
        if (!id) {
            alertMessage("Haujafanikiwa", "Kiwango hakijapatikana.", "warning");
            return;
        }

        confirmAction(
            () => {
                ajaxRequest(`/futaKiwangoMiundombinu/${id}`, "POST", (response) => {
                    const statusCode = Number(response?.statusCode || 306);
                    alertMessage(
                        statusCode === 300 ? "Umefanikiwa" : "Haujafanikiwa",
                        response?.message || "Kuna tatizo, jaribu tena.",
                        statusCode === 300 ? "success" : "warning",
                        () => {
                            if (statusCode === 300) {
                                reloadStandardsTable();
                            }
                        }
                    );
                });
            },
            "Futa",
            "warning",
            "Ukifuta kiwango hiki, hakitatumika tena kwenye setup.",
            "Futa Kiwango cha Miundombinu?"
        );
    }

    $(document).ready(function() {
        loadInfraLookups();

        tableData('items-datatable' ,'/MiundombinuItemsList' , 'POST',
            [
                {
                    data: null,
                    render: function (data, type, row , meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { data: "code", name: "code", render: (data) => data || "-" },
                { data: "name", name: "name", render: (data) => data || "-" },
                { data: "group_name", name: "group_name", render: (data) => data || "-" },
                { data: "unit", name: "unit", render: (data) => data || "-" },
                {
                    data: "is_active",
                    name: "is_active",
                    render: (data) => Number(data) === 1
                        ? '<span class="badge bg-success-subtle text-success">Inatumika</span>'
                        : '<span class="badge bg-danger-subtle text-danger">Imesitishwa</span>'
                },
                {
                    data: "updated_at",
                    name: "updated_at",
                    render: (data) => data ? changeDateFormat(data) : "-"
                },
                {
                    data: null,
                    render: function (data, type, row) {
                        const elements = [
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-primary me-1',
                                icon : 'bx bx-pencil me-1',
                                function : 'BadiliItem',
                                btnText : 'Edit'
                            },
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-danger',
                                icon : 'bx bx-trash me-1',
                                function : 'FutaItem',
                                btnText : 'Futa'
                            }
                        ];
                        return actionButtons(row, elements);
                    },
                    orderable: false,
                    searchable: false,
                    className: "text-center"
                }
            ]
        );

        tableData('standards-datatable' ,'/ViwangoMiundombinuList' , 'POST',
            [
                {
                    data: null,
                    render: function (data, type, row , meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { data: "school_category_name", name: "school_category_name", render: (data) => data || "-" },
                { data: "school_sub_category_name", name: "school_sub_category_name", render: (data) => data || "-" },
                { data: "school_specialization_name", name: "school_specialization_name", render: (data) => data || "-" },
                { data: "school_gender_type_name", name: "school_gender_type_name", render: (data) => data || "-" },
                { data: "stream_band", name: "stream_band", render: (data) => streamBandLabel(data) },
                {
                    data: null,
                    name: "infrastructure_item_name",
                    render: (data, type, row) => {
                        const code = row.infrastructure_item_code || "";
                        const name = row.infrastructure_item_name || "-";
                        return code ? `${code} - ${name}` : name;
                    }
                },
                { data: "required_quantity", name: "required_quantity", render: (data) => data ?? "-" },
                {
                    data: "is_active",
                    name: "is_active",
                    render: (data) => Number(data) === 1
                        ? '<span class="badge bg-success-subtle text-success">Inatumika</span>'
                        : '<span class="badge bg-danger-subtle text-danger">Imesitishwa</span>'
                },
                {
                    data: "updated_at",
                    name: "updated_at",
                    render: (data) => data ? changeDateFormat(data) : "-"
                },
                {
                    data: null,
                    render: function (data, type, row) {
                        const elements = [
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-primary me-1',
                                icon : 'bx bx-pencil me-1',
                                function : 'BadiliStandard',
                                btnText : 'Edit'
                            },
                            {
                                show : true,
                                type : 'link',
                                class : 'btn btn-sm btn-outline-danger',
                                icon : 'bx bx-trash me-1',
                                function : 'FutaStandard',
                                btnText : 'Futa'
                            }
                        ];
                        return actionButtons(row, elements);
                    },
                    orderable: false,
                    searchable: false,
                    className: "text-center"
                }
            ]
        );

        $('#infra-tabs button[data-bs-toggle="tab"]').on('shown.bs.tab', function () {
            if ($.fn.DataTable.isDataTable('#items-datatable')) {
                $('#items-datatable').DataTable().columns.adjust();
            }
            if ($.fn.DataTable.isDataTable('#standards-datatable')) {
                $('#standards-datatable').DataTable().columns.adjust();
            }
        });
    });
</script>
</body>
</html>
