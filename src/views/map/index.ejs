
<%- include('../layouts/partials/header.ejs' , {
    title : "Map Data",
    page_title : "School Geo-Location",
    card_title :  "Map View",
    breadcrumb_main : 'Dashibodi',
    styles : [
            { href: '/css/map/leaflet.css' },
            { href: '/css/map/Control.Geocoder.css' },
        ]
}) %>
<style>
  #map {
      height: 600px; /* Set the height of the map */
      width: 100%; /* Optional, but ensures it takes up full width */
  }
  .decision-card {
      border: 1px solid #e9ebec;
      border-radius: 0.75rem;
      background: #fff;
      padding: 0.75rem 0.9rem;
  }
  .decision-card .label {
      color: #6c757d;
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.05em;
  }
  .decision-card .value {
      color: #212529;
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.2;
      margin-top: 0.2rem;
  }
  .decision-card .hint {
      color: #6c757d;
      font-size: 0.76rem;
      margin-top: 0.25rem;
  }
  .decision-list {
      list-style: none;
      margin: 0;
      padding: 0;
  }
  .decision-list li {
      font-size: 0.88rem;
      padding: 0.45rem 0;
      border-bottom: 1px dashed #e9ebec;
  }
  .decision-list li:last-child {
      border-bottom: none;
  }
  .legend-row {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-size: 0.84rem;
      margin-bottom: 0.45rem;
  }
  .legend-row:last-child {
      margin-bottom: 0;
  }
  .legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      display: inline-block;
      border: 1px solid rgba(0,0,0,0.12);
  }
  .map-status-box {
      min-width: 340px;
      border-radius: 12px;
      padding: 0.55rem 0.85rem;
      border: 1px solid #dfe3e8;
      background: #f8fafc;
      text-align: left;
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.06);
  }
  .map-status-label {
      display: block;
      color: #64748b;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      line-height: 1;
      margin-bottom: 0.2rem;
  }
  .map-status-text {
      display: block;
      font-size: 1rem;
      font-weight: 700;
      color: #1f2937;
      line-height: 1.15;
  }
  .map-status-box.status-secondary {
      border-color: #cbd5e1;
      background: #f8fafc;
  }
  .map-status-box.status-success {
      border-color: #86efac;
      background: #f0fdf4;
  }
  .map-status-box.status-warning {
      border-color: #fde68a;
      background: #fffbeb;
  }
  .map-status-box.status-danger {
      border-color: #fecaca;
      background: #fef2f2;
  }
</style>
<div class="card-body">
     <div class="ribbon-three ribbon-three-danger">
        <span class="badge" id="total-school">0</span>
    </div>
    <div class="mb-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <label for="color-metric" class="mb-0 small text-muted">Color Basis</label>
            <select id="color-metric" class="form-select form-select-sm" style="width: 220px;">
                <option value="share_view" selected>Relative share (view)</option>
                <option value="count">Absolute count</option>
            </select>
        </div>
        <div id="map-status-wrap" class="map-status-box status-secondary">
            <span class="map-status-label">Status</span>
            <span id="map-status" class="map-status-text">Inasubiri...</span>
        </div>
    </div>
    <div class="row g-2 mb-3">
        <div class="col-xl-3 col-md-6">
            <div class="decision-card">
                <div class="label">Shule Zilizoonekana</div>
                <div class="value" id="kpi-visible-schools">0</div>
                <div class="hint">Ndani ya eneo la ramani</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="decision-card">
                <div class="label">Mwonekano</div>
                <div class="value" id="kpi-map-mode">POINTS</div>
                <div class="hint">Aina ya uchambuzi wa sasa</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="decision-card">
                <div class="label">Eneo Lenye Wingi</div>
                <div class="value" id="kpi-top-area">-</div>
                <div class="hint" id="kpi-top-area-count">0 shule</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="decision-card">
                <div class="label">Mwisho Kusasishwa</div>
                <div class="value" id="kpi-last-updated">-</div>
                <div class="hint">Inajisasisha moja kwa moja</div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <form class="" style="z-index: 10000;">
            <div class="row g-3">
                <div class="col-xxl-3 col-sm-12">
                    <div class="search-box">
                        <input type="hidden" name="search" value="true">
                        <input type="text" name="name_or_reg" 
                        value="<%= req.query.name_or_reg %>" class="form-control search bg-light border-light" placeholder="Jina au namba ya usajili ...">
                        <i class="ri-search-line search-icon"></i>
                    </div>
                </div>
                <!--end col-->

                <div class="col-xxl-3 col-sm-4">
                    <input type="date" class="form-control bg-light border-light" 
                    id="demo-datepicker" data-provider="flatpickr" 
                    data-date-format="d M, Y" data-range-date="true" 
                    name="date_range"
                    data-default-date="<%= req.query.date_range %>"
                    placeholder="Chagua tarehe ya usajili">
                </div>
                 <!--end col-->
                <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select class="form-control" placeholder="Aina ..."  name="category">
                            <option value=""> Aina ...</option>
                            <% for (let index = 0; index < categories.length; index++) { %>
                            <% const item = categories[index]; %>
                                <option value="<%= item.id %>" <%= req.query.category == item.id ? 'selected' : '' %>>
                                     <%= item.name %>
                                </option>
                            <% } %>
                        </select>
                    </div>
                </div>
                 <!--end col-->
                <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select class="form-control" placeholder="Umiliki ..."  name="ownership">
                            <option value=""> Umiliki ...</option>
                            <% for (let index = 0; index < ownerships.length; index++) { %>
                            <% const item = ownerships[index];
                            %>
                                <option value="<%= item.id %>" <%= req.query.ownership == item.id ? 'selected' : '' %>>
                                     <%= item.name %>
                                </option>
                            <% } %>
                        </select>
                    </div>
                </div>
                <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select id="mkoa-field"  data-choices-search-true class="form-control" placeholder="Mkoa ..."  name="region">
                            <option value=""> Chagua Mkoa ...</option>
                            <% for (let index = 0; index < regions.length; index++) { %>
                            <% const item = regions[index]; %>
                                <option value="<%= item.id %>" <%= req.query.region == item.id ? 'selected' : '' %>>
                                     <%= item.name %>
                                </option>
                            <% } %>
                        </select>
                    </div>
                </div>
                  <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select id="lga-field" class="form-control" placeholder="Halmashauri ..."  name="district">
                            <option value=""> Chagua Halmashauri ...</option>
                        </select>
                    </div>
                </div>
                <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select id="kata-field" class="form-control" placeholder="Kata ..."  name="ward">
                            <option value=""> Chagua Kata ...</option>
                        </select>
                    </div>
                </div>
                <div class="col-xxl-3 col-sm-4">
                    <div class="input-light">
                        <select id="mtaa-field" class="form-control" placeholder="Mtaa ..."  name="street">
                            <option value=""> Chagua Mtaa ...</option>
                        </select>
                    </div>
                </div>
                <!--end col-->
                <div class="col-xxl-2 col-sm-4 d-flex gap-2">
                    <button title="" type="submit" class="btn btn-primary w-100"> 
                        <i class="ri-filter-2-fill me-1 align-bottom"></i>
                        Filter
                    </button>
                     <% if(typeof req.query.search != undefined && req.query.search == "true") { %>
                     <a href="/Map" class="btn btn-danger w-100">
                        <i class="ri-delete-back-2-fill me-1 align-bottom"></i>
                        Futa
                     </a>
                     <% } %>
                </div>
                <div class="col-xxl-10 col-sm-8 text-end">
                    <button class="btn btn-secondary d-none" id="btn-zoom-default" onclick="zoomToLocationAndReset()">
                    <i class="ri-refresh-line me-1 align-bottom"></i>
                        Return to Normal View
                    </button>
                </div>
                <!--end col-->
            </div>
            <!--end row-->
        </form>
        </div>
    </div>
    <hr class="mb-3"/>
    <div class="row g-3" style="z-index: 900;">
        <div class="col-xl-8">
            <div id="map"></div>
        </div>
        <div class="col-xl-4">
            <div class="card border mb-3">
                <div class="card-header bg-soft-info">
                    <h6 class="mb-0">Legend ya Mzigo</h6>
                </div>
                <div class="card-body py-2">
                    <div class="legend-row">
                        <span class="legend-swatch" style="background:#4ade80;"></span>
                        <span>Low concentration</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-swatch" style="background:#f59e0b;"></span>
                        <span>Medium concentration</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-swatch" style="background:#ef4444;"></span>
                        <span>High concentration</span>
                    </div>
                    <div class="small text-muted mt-2" id="legend-note">
                        Inalinganisha maeneo ndani ya view ya sasa.
                    </div>
                </div>
            </div>
            <div class="card border mb-3">
                <div class="card-header bg-soft-primary">
                    <h6 class="mb-0">Top Maeneo</h6>
                </div>
                <div class="card-body py-2">
                    <ul class="decision-list" id="top-areas-list">
                        <li>Hakuna data.</li>
                    </ul>
                </div>
            </div>
            <div class="card border mb-0">
                <div class="card-header bg-soft-warning">
                    <h6 class="mb-0">Action Insights</h6>
                </div>
                <div class="card-body py-2">
                    <ul class="decision-list" id="action-insights-list">
                        <li>Inasubiri data kutoka ramani...</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('../layouts/partials/footer.ejs' , {
    card_title :  '',
    scripts : [
        {src : '/js/map/leaflet.js'},
        {src : '/js/map/leaflet.markercluster.js'},
        {src : '/js/map/Control.Geocoder.js'},
        {src : '/design/layouts/scripts/map_scripts.js'},
        ]
    }) 
%>
<%- include('../includes/locations.ejs') %>
 <script>
    $(function(){
        map.invalidateSize(); // Adjust the map size once modal is fully visible
        mapMoveEnd(true)
        showMyLocation()
    })
 </script>
</body>
</html>
