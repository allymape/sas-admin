<% var card_title = '' %>
<%- include('layouts/partials/header.ejs' , {
    title : 'Majalada ya Shule',
    page_title : 'Orodha ya Majalada ya Shule',
    card_title : 'Majalada ya Shule',
    breadcrumb_main : 'Mipangilio',
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>
<div class="card-body">
    <div id="customerList">
        <div class="row g-4 mb-2">
            <div class="col-sm-auto">
                <button type="button" class="btn btn-outline-success btn-sm" id="generate-missing-file-numbers-btn">
                    <span class="bx bx-refresh me-1"></span>Generate Zisizo na Namba
                    <span class="badge bg-success-subtle text-success ms-1" id="missing-file-count">0</span>
                </button>
            </div>
        </div>
        <div class="col-md-12">
            <div class="table-responsive table-card mt-3 mb-1">
                <table class="table align-middle table-nowrap" id="datatable">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">Na.</th>
                            <th>Jina la Shule</th>
                            <th>Namba ya Usajili</th>
                            <th>Aina ya Shule</th>
                            <th>Umiliki</th>
                            <th>Namba ya Jalada</th>
                            <th class="text-center">Idadi ya Maombi</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody class="list form-check-all"></tbody>
                </table>
                <div class="noresult" style="display: none">
                    <div class="text-center">
                        <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop"
                            colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                        <h5 class="mt-2">Hakuna matokeo</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editFileNumberModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title">Badili Namba ya Jalada</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <input type="hidden" id="file-number-school-id" />
                    <div class="mb-3">
                        <label class="form-label">Shule</label>
                        <input type="text" id="file-number-school-name" class="form-control" readonly />
                    </div>
                    <div class="mb-1">
                        <label for="file-number-input" class="form-label">Namba ya Jalada</label>
                        <input type="text" id="file-number-input" class="form-control" placeholder="Mfano: CD.5/315/1001" />
                        <span class="text-danger" style="display:none;" id="file-number-required">Tafadhali jaza namba ya jalada.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="hstack gap-2 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Funga</button>
                        <button type="button" class="btn btn-primary" id="save-file-number-btn" onclick="saveSchoolFileNumber()">
                            Hifadhi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="schoolApplicationsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light p-3">
                <h5 class="modal-title" id="schoolApplicationsTitle">Maombi ya Shule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table align-middle table-nowrap" id="school-applications-table" width="100%">
                        <thead class="table-light">
                            <tr>
                                <th width="5%">Na.</th>
                                <th>Namba ya Ombi</th>
                                <th>Aina ya Ombi</th>
                                <th>Shule</th>
                                <th>Mwombaji</th>
                                <th>Hali</th>
                                <th>Muda</th>
                                <th class="text-center">Barua</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'}
          ]
    }) %>

<script>
    let schoolApplicationsTable = null;
    let isSavingFileNumber = false;
    let isGeneratingMissing = false;

    function reloadSchoolsTable() {
        if ($.fn.DataTable.isDataTable("#datatable")) {
            $("#datatable").DataTable().ajax.reload(null, false);
        }
    }

    function setMissingFileCount(total) {
        const count = Number(total || 0);
        $("#missing-file-count").text(count);
    }

    function escapeAttribute(value) {
        return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/"/g, "&quot;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    function statusBadge(statusCode) {
        const code = Number(statusCode || 0);
        if (code === 2) return '<span class="badge bg-success">Yaliyokubaliwa</span>';
        if (code === 3) return '<span class="badge bg-danger">Yaliyokataliwa</span>';
        if (code === 4) return '<span class="badge bg-warning text-dark">Yaliyorudishwa</span>';
        if (code === 1) return '<span class="badge bg-info">Yanayochakatwa</span>';
        return '<span class="badge bg-primary">Yaliyowasilishwa</span>';
    }

    function openSchoolApplications(button) {
        const schoolId = Number(button.getAttribute("data-school-id") || 0);
        const schoolName = String(button.getAttribute("data-school-name") || "").trim();
        if (!schoolId) return;

        $("#schoolApplicationsTitle").text(`Maombi ya Shule: ${schoolName || "-"}`);
        const modalEl = document.getElementById("schoolApplicationsModal");
        const modalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
        modalInstance.show();

        const ajaxUrl = `/MajaladaYaShuleApplicationsList/${schoolId}`;

        if ($.fn.DataTable.isDataTable("#school-applications-table")) {
            schoolApplicationsTable.ajax.url(ajaxUrl).load();
            return;
        }

        schoolApplicationsTable = $("#school-applications-table").DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: ajaxUrl,
                type: "POST",
            },
            columns: [
                {
                    data: null,
                    render: (data, type, row, meta) => meta.row + meta.settings._iDisplayStart + 1
                },
                {
                    data: "tracking_number",
                    class: "text-nowrap",
                    render: (data) => data || "-"
                },
                {
                    data: "application_category",
                    render: (data, type, row) => row?.application_category?.app_name || "-"
                },
                {
                    data: "establishing_school",
                    render: (data, type, row) => row?.establishing_school?.school_name || "-"
                },
                {
                    data: "applicant",
                    render: (data, type, row) => row?.applicant?.name || "-"
                },
                {
                    data: "is_approved",
                    class: "text-nowrap",
                    render: (data) => statusBadge(data)
                },
                {
                    data: "created_at",
                    class: "text-nowrap",
                    render: (data) => data ? changeDateFormat(data) : "-"
                },
                {
                    data: null,
                    class: "text-center text-nowrap",
                    render: (data, type, row) => {
                        const trackingNumber = String(row?.tracking_number || "").trim();
                        if (!trackingNumber || Number(row?.is_approved) !== 2) {
                            return "-";
                        }

                        const encodedTracking = encodeURIComponent(trackingNumber);
                        return `<a
                            target="_blank"
                            title="Fungua Barua"
                            data-bs-toggle="tooltip"
                            href="/barua/${encodedTracking}"
                            class="btn btn-sm btn-danger"
                        >
                            <i class="ri-file-pdf-fill align-bottom me-1"></i> Barua
                        </a>`;
                    }
                }
            ],
            order: [[6, "desc"]],
            language: {
                searchPlaceholder: "Search Here ...",
            },
            lengthMenu: [[10, 25, 50, 100], ["10", "25", "50", "100"]],
        });
    }

    function openEditFileNumber(button) {
        const schoolId = Number(button.getAttribute("data-school-id") || 0);
        if (!schoolId) return;

        $("#file-number-school-id").val(schoolId);
        $("#file-number-school-name").val(button.getAttribute("data-school-name") || "-");
        $("#file-number-input").val(button.getAttribute("data-file-number") || "");
        $("#file-number-required").hide();

        const modalEl = document.getElementById("editFileNumberModal");
        const modalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
        modalInstance.show();
    }

    function saveSchoolFileNumber() {
        if (isSavingFileNumber) return;

        const schoolId = Number($("#file-number-school-id").val() || 0);
        const file_number = String($("#file-number-input").val() || "").trim();
        const saveBtn = $("#save-file-number-btn");

        $("#file-number-required").hide();

        if (!schoolId) {
            alertMessage("Haujafanikiwa", "Shule haijapatikana.", "warning");
            return;
        }

        if (!file_number) {
            $("#file-number-required").show();
            return;
        }

        isSavingFileNumber = true;
        saveBtn.prop("disabled", true);

        ajaxRequest(
            `/MajaladaYaShuleBadiliNamba/${schoolId}`,
            "POST",
            (response) => {
                const statusCode = Number(response?.statusCode || 306);
                const success = statusCode === 300;

                alertMessage(
                    success ? "Umefanikiwa" : "Haujafanikiwa",
                    response?.message || "Imeshindikana kubadili namba ya jalada.",
                    success ? "success" : "warning",
                    () => {
                        if (success) {
                            const modalEl = document.getElementById("editFileNumberModal");
                            bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                            reloadSchoolsTable();
                        }
                    }
                );

                isSavingFileNumber = false;
                saveBtn.prop("disabled", false);
            },
            JSON.stringify({ file_number })
        );
    }

    function generateMissingFileNumbers() {
        if (isGeneratingMissing) return;
        const triggerBtn = $("#generate-missing-file-numbers-btn");

        isGeneratingMissing = true;
        triggerBtn.prop("disabled", true);

        ajaxRequest("/MajaladaYaShuleGenerateMissing", "POST", (response) => {
            const statusCode = Number(response?.statusCode || 306);
            const success = statusCode === 300;
            const updated = Number(response?.data?.updated || 0);
            const skipped = Number(response?.data?.skipped || 0);
            const reasons = response?.data?.skipped_reasons || {};
            const registryMissing = Number(reasons?.registry_type_missing || 0);
            const categoryMissing = Number(reasons?.school_category_missing || 0);
            const mappingMissing = Number(reasons?.mapping_not_found || 0);
            const reasonParts = [];
            if (registryMissing > 0) reasonParts.push(`Umiliki haupo: ${registryMissing}`);
            if (categoryMissing > 0) reasonParts.push(`Aina ya shule haipo: ${categoryMissing}`);
            if (mappingMissing > 0) reasonParts.push(`Hakuna pattern inayolingana: ${mappingMissing}`);
            const reasonText = reasonParts.length ? ` Sababu za kurukwa: ${reasonParts.join(", ")}.` : "";
            const message = `${response?.message || "Mchakato umekamilika."} (Zilizowekwa: ${updated}, Zilizorukwa: ${skipped}).${reasonText}`;

            alertMessage(
                success ? "Umefanikiwa" : "Haujafanikiwa",
                message,
                success ? "success" : "warning",
                () => {
                    if (success) {
                        reloadSchoolsTable();
                    }
                }
            );

            isGeneratingMissing = false;
            triggerBtn.prop("disabled", false);
        });
    }

    $(document).ready(function() {
        $("#generate-missing-file-numbers-btn").on("click", function () {
            generateMissingFileNumbers();
        });

        $("#datatable").on("xhr.dt", function (e, settings, json) {
            if (json && typeof json.missingFileNumbersCount !== "undefined") {
                setMissingFileCount(json.missingFileNumbersCount);
            }
        });

        tableData('datatable' ,'/MajaladaYaShuleList' , 'POST',
            [
                {
                    data: null,
                    render: function (data, type, row , meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                {
                    data: "name",
                    name: "name",
                    render: (data) => data || "-"
                },
                {
                    data: "reg_no",
                    name: "reg_no",
                    class: "text-nowrap",
                    render: (data) => data || "-"
                },
                {
                    data: "category",
                    name: "category",
                    render: (data) => data || "-"
                },
                {
                    data: "ownership",
                    name: "ownership",
                    render: (data) => data || "-"
                },
                {
                    data: "file_number",
                    name: "file_number",
                    render: (data) => data || "-"
                },
                {
                    data: "applications_count",
                    name: "applications_count",
                    class: "text-center",
                    render: (data) => {
                        const count = Number(data || 0);
                        return `<span class="badge bg-primary-subtle text-primary">${count}</span>`;
                    }
                },
                {
                    data: null,
                    name: "action",
                    class: "text-end text-nowrap",
                    render: (data, type, row) => {
                        const count = Number(row.applications_count || 0);
                        const schoolId = Number(row.school_id || 0);
                        const schoolName = escapeAttribute(row.name || "-");
                        const fileNumber = escapeAttribute(row.file_number || "");
                        if (!schoolId) return "-";
                        const applicationsButton = count > 0
                            ? `<button type="button"
                                class="btn btn-sm btn-outline-info"
                                data-school-id="${schoolId}"
                                data-school-name="${schoolName}"
                                onclick="openSchoolApplications(this); return false;">
                                <span class="bx bx-list-ul me-1"></span>Ona Maombi
                            </button>`
                            : "";

                        return `<div class="d-flex justify-content-end gap-2">
                            <button type="button"
                                class="btn btn-sm btn-outline-primary"
                                data-school-id="${schoolId}"
                                data-school-name="${schoolName}"
                                data-file-number="${fileNumber}"
                                onclick="openEditFileNumber(this); return false;">
                                <span class="bx bx-edit me-1"></span>Hariri
                            </button>
                            ${applicationsButton}
                        </div>`;
                    }
                }
            ],
            null,
            [
                { targets: [0, 7], orderable: false }
            ]
        );
    });
</script>
