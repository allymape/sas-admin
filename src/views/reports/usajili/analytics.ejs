<% var card_title = '' %>
<%- include('../../layouts/partials/header.ejs' , {
    title : 'Pivot Analytics - Usajili',
    page_title : 'Pivot Analytics ya Usajili wa Shule',
    card_title : 'Pivot Workspace',
    breadcrumb_main : 'Ripoti',
}) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jquery-ui-dist/jquery-ui.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pivottable@2.23.0/dist/pivot.min.css">
<link rel="stylesheet" href="/design/assets/css/usajili-pivot-analytics.css">

<script>
  window.__usajiliPivotConfig = {
    apiUrl: "/RipotiUsajiliPivotData",
    query: <%- JSON.stringify(req.query || {}) %>,
    safePivotUiRows: 1200,
    maxClientRenderRows: 5000,
    defaultLimit: 2000
  };
</script>

<div class="card-body analytics-hero">
  <div class="d-flex flex-column flex-xl-row justify-content-between gap-2">
    <div>
      <h4 class="analytics-title mb-1">Ripoti za Uchambuzi (Pivot Analytics)</h4>
      <p class="analytics-subtitle mb-0">Workspace ya pivot inayoendeshwa moja kwa moja ndani ya jedwali la uchambuzi.</p>
    </div>
    <div class="analytics-meta d-flex flex-wrap gap-2">
      <span class="meta-chip">Records: <strong id="metaRecords">0</strong></span>
      <span class="meta-chip">Limit: <strong id="metaLimit">-</strong></span>
      <span class="meta-chip">Last Refresh: <strong id="metaRefreshed">-</strong></span>
      <span class="meta-chip">Backend: <strong id="metaBackendMs">-</strong></span>
    </div>
  </div>
</div>

<div class="card-body pt-0">
  <div class="compact-summary-line" id="compactSummaryLine">Jumla: 0 | Verified: 0 | Not Verified: 0</div>
  <div id="pivotStatus" class="alert d-none mt-3" role="alert"></div>

  <section class="pivot-surface mt-3">
    <div class="surface-title-row mb-2">
      <h6 class="surface-title mb-0">Matokeo ya Pivot Report</h6>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="btnReloadPivotData">Refresh Data</button>
    </div>
    <p class="pivot-config-summary mb-2" id="pivotConfigSummary">Rows: Mkoa | Columns: Umiliki | Aggregator: Count | Renderer: Table</p>

    <div id="pivotLoading" class="pivot-loading d-none">
      <span class="spinner-border text-primary" role="status" aria-hidden="true"></span>
      <span>Inapakia data...</span>
    </div>

    <div id="pivotEmptyState" class="pivot-empty d-none">Hakuna data kwa vigezo vilivyopo.</div>

    <div id="pivotUiContainer" class="pivot-ui-container"></div>
  </section>

  <section class="dataset-preview-wrap mt-4">
    <div class="surface-title-row mb-2">
      <h6 class="surface-title mb-0">Sample Raw Dataset (Secondary)</h6>
      <div class="d-flex align-items-center gap-2">
        <span class="text-muted small" id="flatDatasetCaption">-</span>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnToggleSampleData">Onyesha Sample Data</button>
      </div>
    </div>

    <div id="sampleDataCollapse" class="d-none">
      <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle mb-0" id="flatDatasetPreviewTable">
          <thead class="table-light"></thead>
          <tbody>
            <tr><td class="text-muted">Inasubiri data...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</div>

<%- include('../../layouts/partials/footer.ejs' , {
     card_title :  '' ,
     pagination_script : false,
    }) %>

<%- include('../../includes/locations' , {
  'location' : null
}) %>

<script src="https://cdn.jsdelivr.net/npm/jquery-ui-dist/jquery-ui.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/pivottable@2.23.0/dist/pivot.min.js"></script>

<!-- Optional chart renderers for in-pivot chart switching -->
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/pivottable@2.23.0/dist/plotly_renderers.min.js"></script>

<script src="/design/assets/js/pages/usajili-pivot-analytics.js"></script>

</body>
</html>
