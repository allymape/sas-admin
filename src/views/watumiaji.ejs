<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/watumiaji_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    const escapeAttr = (value) => String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");

    const dedupeItems = (items = []) => Array.from(new Set(items.filter(Boolean)));

    const normalizeBase64Padding = (raw = "") => {
        const clean = String(raw || "").replace(/\s+/g, "").replace(/^['"]|['"]$/g, "");
        const mod = clean.length % 4;
        if (mod === 2) return `${clean}==`;
        if (mod === 3) return `${clean}=`;
        if (mod === 1) return clean.slice(0, -1);
        return clean;
    };

    const guessImageMimeFromBase64 = (b64 = "") => {
        const value = normalizeBase64Padding(b64);
        if (value.startsWith("iVBOR")) return "image/png";
        if (value.startsWith("/9j/")) return "image/jpeg";
        if (value.startsWith("R0lGOD")) return "image/gif";
        if (value.startsWith("UklGR")) return "image/webp";
        if (value.startsWith("PHN2Zy")) return "image/svg+xml";
        if (value.startsWith("Qk")) return "image/bmp";
        return "image/png";
    };

    const bytesToBase64 = (bytes = []) => {
        try {
            let binary = "";
            const chunkSize = 0x8000;
            for (let i = 0; i < bytes.length; i += chunkSize) {
                const chunk = bytes.slice(i, i + chunkSize);
                binary += String.fromCharCode(...chunk);
            }
            return btoa(binary);
        } catch (error) {
            return "";
        }
    };

    const parseBufferPayload = (rawValue) => {
        try {
            const value = typeof rawValue === "string" ? JSON.parse(rawValue) : rawValue;
            if (!value || typeof value !== "object") return "";
            if (!Array.isArray(value.data)) return "";
            const bytes = value.data
                .map((item) => Number(item))
                .filter((num) => Number.isInteger(num) && num >= 0 && num <= 255);
            if (!bytes.length) return "";
            return bytesToBase64(bytes);
        } catch (error) {
            return "";
        }
    };

    const isLikelyHexBlob = (value = "") => {
        const clean = String(value || "").trim().replace(/^0x/i, "");
        return clean.length > 40 && clean.length % 2 === 0 && /^[0-9a-fA-F]+$/.test(clean);
    };

    const hexToBase64 = (hex = "") => {
        const clean = String(hex || "").trim().replace(/^0x/i, "");
        if (!clean || clean.length % 2 !== 0) return "";
        const bytes = [];
        for (let i = 0; i < clean.length; i += 2) {
            bytes.push(parseInt(clean.slice(i, i + 2), 16));
        }
        return bytesToBase64(bytes);
    };

    const looksLikeBase64 = (value = "") => {
        const clean = normalizeBase64Padding(value);
        return clean.length >= 32 && /^[A-Za-z0-9+/]+={0,2}$/.test(clean);
    };

    const looksLikeImagePath = (value = "") => {
        const normalized = String(value || "").trim().replace(/\\/g, "/");
        if (!normalized) return false;
        if (normalized.startsWith("http://") || normalized.startsWith("https://")) return true;
        if (normalized.startsWith("/")) return true;
        return /(\.png|\.jpg|\.jpeg|\.gif|\.webp|\.svg)(\?.*)?$/i.test(normalized) || normalized.includes("/");
    };

    const resolveSignatureSources = (rawValue) => {
        const pathCandidates = [];
        const imageCandidates = [];

        const value = String(rawValue ?? "").trim();
        if (!value || /^null$/i.test(value) || /^undefined$/i.test(value)) {
            return [];
        }

        if (value.startsWith("data:image/")) {
            return [value];
        }

        if (value.startsWith("data:") && value.includes(";base64,")) {
            const base64Part = normalizeBase64Padding(value.split(";base64,").pop() || "");
            if (base64Part) {
                const mime = guessImageMimeFromBase64(base64Part);
                imageCandidates.push(`data:${mime};base64,${base64Part}`);
            }
        }

        if (value.startsWith("http://") || value.startsWith("https://") || value.startsWith("/")) {
            pathCandidates.push(value);
            if (value.startsWith("/")) {
                pathCandidates.push(encodeURI(value));
            }
        }

        if (looksLikeImagePath(value) && !value.startsWith("data:")) {
            const normalized = value.replace(/\\/g, "/").replace(/^\.?\//, "");
            pathCandidates.push(`/${normalized}`);
            pathCandidates.push(encodeURI(`/${normalized}`));
            pathCandidates.push(value);
        }

        const bufferBase64 = parseBufferPayload(rawValue);
        if (bufferBase64) {
            const mime = guessImageMimeFromBase64(bufferBase64);
            imageCandidates.push(`data:${mime};base64,${normalizeBase64Padding(bufferBase64)}`);
        }

        if (isLikelyHexBlob(value)) {
            const hexBase64 = hexToBase64(value);
            if (hexBase64) {
                const mime = guessImageMimeFromBase64(hexBase64);
                imageCandidates.push(`data:${mime};base64,${normalizeBase64Padding(hexBase64)}`);
            }
        }

        if (looksLikeBase64(value)) {
            const clean = normalizeBase64Padding(value);
            const mime = guessImageMimeFromBase64(clean);
            imageCandidates.push(`data:${mime};base64,${clean}`);
        }

        return dedupeItems([...pathCandidates, ...imageCandidates]);
    };

    const normalizeSignatureTitle = (value) => {
        const title = String(value || "").trim();
        if (!title || title.toLowerCase() === "null") return "";
        return title.toUpperCase();
    };

    const showSignatureEmptyState = (message = "Hakuna sahihi iliyopatikana kwa mtumiaji huyu.") => {
        $("#signature-preview-loading").addClass("d-none");
        $("#signature-preview-shell").addClass("d-none");
        $("#signature-preview-name").text("-");
        $("#signature-preview-title").text("-");
        $("#signature-preview-image").attr("src", "").addClass("d-none");
        $("#signature-preview-empty").removeClass("d-none").text(message);
    };

    function viewUserSignature(button) {
        const rowData = JSON.parse(button.getAttribute("data-row") || "{}");
        const userId = Number(rowData.userId || rowData.id || 0);
        const userName = String(rowData.name || "Mtumiaji");

        if (!userId) {
            alertMessage("Haujafanikiwa", "Kitambulisho cha mtumiaji hakikupatikana.", "warning");
            return;
        }

        $("#signature-preview-name").text(userName);
        $("#signature-preview-title").text("-");
        $("#signature-preview-empty").addClass("d-none").text("Hakuna sahihi iliyopatikana kwa mtumiaji huyu.");
        $("#signature-preview-shell").addClass("d-none");
        $("#signature-preview-image").attr("src", "").addClass("d-none");
        $("#signature-preview-loading").removeClass("d-none");
        modal("signaturePreviewModal", true);

        ajaxRequest(`/UserSignature/${userId}`, "GET", (response) => {
            const statusCode = Number(response?.statusCode || 306);
            if (statusCode !== 300 || !response?.data?.signature) {
                showSignatureEmptyState(response?.message || "Hakuna sahihi iliyopatikana kwa mtumiaji huyu.");
                return;
            }

            const sources = resolveSignatureSources(response.data.signature);
            if (!sources.length) {
                showSignatureEmptyState();
                return;
            }

            const previewName = String(response?.data?.name || userName).trim() || userName;
            const previewTitle = normalizeSignatureTitle(response?.data?.cheo);

            $("#signature-preview-name").text(previewName);
            $("#signature-preview-title").text(previewTitle || "-");
            $("#signature-preview-empty").addClass("d-none");
            $("#signature-preview-shell").removeClass("d-none");

            const $img = $("#signature-preview-image");
            let sourceIndex = 0;
            const loadSource = () => {
                if (sourceIndex >= sources.length) {
                    showSignatureEmptyState("Sahihi imepatikana lakini imeshindikana kuoneshwa.");
                    return;
                }
                const src = sources[sourceIndex];
                sourceIndex += 1;

                $img.off("error load");
                $img.one("error", loadSource);
                $img.one("load", function () {
                    $("#signature-preview-loading").addClass("d-none");
                    $("#signature-preview-empty").addClass("d-none");
                    $img.removeClass("d-none");
                });
                $img.attr("src", src).removeClass("d-none");
            };

            loadSource();
        });
    }

    $(document).ready(function() {
        const canUseAdminFilters = <%= canUseAdminFilters ? "true" : "false" %>;
        const tableFilters = [
            { name: "inactive", value: <%= inactiveMode ? "true" : "false" %> }
        ];
        if (canUseAdminFilters) {
            tableFilters.push({ name: "unit_id", value: "" });
        }

        const upsertFilter = (name, value) => {
            const index = tableFilters.findIndex((item) => item.name === name);
            if (index >= 0) {
                tableFilters[index].value = value;
                return;
            }
            tableFilters.push({ name, value });
        };

        const loadUnitsFilter = () => {
            const $unitFilter = $("#user-unit-filter");
            if (!$unitFilter.length) return;

            ajaxRequest("/UserUnitsFilter", "GET", (response) => {
                if (Number(response?.statusCode || 306) !== 300) {
                    return;
                }

                const units = Array.isArray(response?.data) ? response.data : [];
                $unitFilter.find("option:not([value=''])").remove();
                units.forEach((unit) => {
                    const id = Number(unit?.id || 0);
                    const name = String(unit?.name || "").trim();
                    if (!id || !name) return;
                    $unitFilter.append(new Option(name, String(id)));
                });

                if ($.fn.select2) {
                    $unitFilter.select2({
                        width: "100%",
                        placeholder: "All Units",
                        allowClear: true,
                    });
                }
            });
        };

        const formatCompactDateTime = (dateStr) => {
            if (!dateStr) return "-";
            const dateObj = new Date(dateStr);
            if (Number.isNaN(dateObj.getTime())) return "-";
            return dateObj.toLocaleString("en-GB", {
                timeZone: "Africa/Dar_es_Salaam",
                day: "2-digit",
                month: "short",
                year: "numeric",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false
            });
        };
       
        tableData('datatable' , '/UserList' , 'POST',
            [
                    { data: null, render : (data , type , row , meta) => {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    } },
                    {
                        data: "name",
                        name: "name",
                        render: (data) => {
                            const name = String(data || '').trim();
                            const initials = name
                                .split(' ')
                                .filter(Boolean)
                                .slice(0, 2)
                                .map((part) => part[0])
                                .join('') || 'U';
                            return `<div class="user-name"><span class="user-avatar">${initials}</span><span class="cell-truncate name" title="${escapeAttr(name || '-')}">${name || '-'}</span></div>`;
                        }
                    },
                    { data: "phone_no", name: "phone_no", render: (data) => data ? `<span class="text-muted cell-truncate" title="${escapeAttr(data)}">${data}</span>` : '-' },
                    { data: "email", name: "email", render: (data) => data ? `<span class="text-muted cell-truncate email" title="${escapeAttr(data)}">${data}</span>` : '-' },
                    { data: "role_name", name: "role_name", render: (data) => `<span class="badge bg-info-subtle text-info">${data || '-'}</span>` },
                    { data: "level_name", name: "level_name", render: (data) => `<span class="cell-truncate" title="${escapeAttr(data || '-')}">${data || '-'}</span>` },
                    { data: "section_name", name: "section_name" , render : (data , type , row) => {
                              const officeText = row.lga_name
                                ? `<span class='myTooltip' style='cursor:pointer' data-bs-toggle=tooltip title='Kanda ya ${
                                    row.zone_name
                                    }'>
                                <span class="cell-truncate office" title="${escapeAttr(row.section_name + " " + row.lga_name)}">${row.section_name + " " + row.lga_name}</span>
                                </span>`
                                : row.zone_name
                                ? `<span class='myTooltip' style='cursor:pointer' data-bs-toggle=tooltip title='Kanda ya ${
                                    row.zone_name
                                    }'>
                                <span class="cell-truncate office" title="${escapeAttr(row.section_name + " " + row.zone_name)}">${row.section_name + " " + row.zone_name}</span>
                                </span>`
                                : `<span class="cell-truncate office" title="${escapeAttr(row.section_name + " HQ")}">${row.section_name + " HQ"}</span>`;
                              return officeText;
                    }},
                    {data: 'last_login' , name: 'last_login' , render: (data , type , row) => {
                        return data ? `<span class="text-muted cell-truncate" title="${escapeAttr(formatCompactDateTime(data))}">${formatCompactDateTime(data)}</span>` : `<span class="text-muted">-</span>`
                    }},
                    {data: 'has_signature' , name: 'has_signature' , render: (data , type , row) => {
                        if (Number(data || 0) <= 0) {
                            return `<span class="text-muted">-</span>`;
                        }
                        const escapedRow = JSON.stringify(row)
                            .replace(/"/g, "&quot;")
                            .replace(/'/g, "&#39;");
                        return `<button type="button"
                                    class="btn btn-soft-info action-btn"
                                    title="Angalia Saini"
                                    data-bs-toggle="tooltip"
                                    data-row='${escapedRow}'
                                    onclick="viewUserSignature(this); return false;">
                                    <i class="las la-signature la-lg"></i>
                                </button>`;
                    }},
                    {
                        data : 'is_password_changed' , name : 'is_password_changed' , render : (data , type , row) => {
                            return data ? `<span class="badge bg-success-subtle text-success">Ndiyo</span>`
                                        : `<span class="badge bg-danger-subtle text-danger">Hapana</span>`
                        },
                        class : 'text-center'
                    },
                    { data: "user_status", name: "user_status" ,  render: (data , type , row) => {
                        return data ? `<span class="badge bg-success-subtle text-success" title="Active" data-bs-toggle="tooltip">Active</span>` : `<span class="badge bg-danger-subtle text-danger" title="In-active" data-bs-toggle="tooltip">Inactive</span>`;
                        },
                        class : 'text-center'
                    },
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                          const elements = [
                                            {
                                                show : row.user_status,
                                                type : 'link',
                                                class : 'btn btn-soft-primary action-btn me-1',
                                                icon : 'ri-pencil-line',
                                                function : 'editUser',
                                                btnText : '',
                                                moreAttributes : "title='Badili' data-bs-toggle='tooltip'"
                                            },
                                            {
                                                show : true,
                                                type : 'button',
                                                class : `btn btn-soft-${row.user_status ? 'danger' : 'success'} action-btn me-1`,
                                                icon : `${row.user_status ? 'ri-user-unfollow-line' : 'ri-user-follow-line'}`,
                                                function : 'activateDeactivateUser',
                                                btnText : '',
                                                moreAttributes : `title='${row.user_status ? 'Deactivate' : 'Activate'}' data-bs-toggle='tooltip'`
                                            },
                                            {
                                                show : row.user_status,
                                                type : 'button',
                                                class : `btn btn-soft-warning action-btn me-1`,
                                                icon : `ri-lock-unlock-line`,
                                                function : 'ResetPassword',
                                                btnText : '',
                                                moreAttributes : "title = 'Reset Password' data-bs-toggle='tooltip'"
                                            }
                                        ]
                           if(row.userId !== row.login_user_id)
                               return actionButtons(row , elements);
                            else
                                return '';
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    class : 'text-center'
                    },
            ],
            tableFilters
        );

        const usersTable = $('#datatable').DataTable();
        if (canUseAdminFilters) {
            loadUnitsFilter();
            $("#user-unit-filter").on("change", function () {
                upsertFilter("unit_id", String($(this).val() || ""));
                usersTable.ajax.reload();
            });
            $("#btn-clear-user-filters").on("click", function () {
                const $unitFilter = $("#user-unit-filter");
                if ($unitFilter.length) {
                    $unitFilter.val(null).trigger("change");
                }
            });
        }

        usersTable.on('xhr.dt', function (e, settings, json) {
            const total = Number((json && json.recordsTotal) || 0);
            const rows = json && Array.isArray(json.data) ? json.data : [];
            const shown = rows.length;
            $('#users-total-count').text(total.toLocaleString());
            $('#users-page-count').text(shown.toLocaleString());
        });
    });
</script>
