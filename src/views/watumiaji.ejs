<% var card_title = 'Watumiaji waliopo' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Watumiaji',
    page_title : 'Orodha ya Watumiaji',
    card_title : card_title,
    styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]
}) %>
<style>
    #datatable.table-readable th,
    #datatable.table-readable td {
        font-size: 0.82rem;
        vertical-align: middle;
        padding: 0.5rem 0.45rem;
    }

    #datatable.table-readable {
        width: 100% !important;
        table-layout: fixed;
    }

    #datatable.table-readable th {
        white-space: nowrap;
    }

    #datatable .user-name {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        min-width: 0;
    }

    #datatable .user-avatar {
        width: 27px;
        height: 27px;
        border-radius: 50%;
        background: #0ab39c;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        flex: 0 0 27px;
    }

    #datatable .cell-truncate {
        display: inline-block;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        vertical-align: bottom;
    }

    #datatable .cell-truncate.email {
        max-width: 160px;
    }

    #datatable .cell-truncate.office {
        max-width: 145px;
    }

    #datatable .cell-truncate.name {
        max-width: 160px;
        font-weight: 600;
    }

    #datatable .action-btn {
        width: 30px;
        height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        padding: 0;
    }

    #datatable td:last-child,
    #datatable th:last-child {
        white-space: nowrap;
    }

    .users-filter-btn.active {
        pointer-events: none;
    }

    .users-summary .card {
        border: 1px solid rgba(17, 24, 39, 0.08);
    }

    .users-table-wrap {
        overflow-x: hidden;
    }

    .signature-preview-shell {
        width: 100%;
        min-height: 330px;
        border-radius: 0.75rem;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.25rem;
    }

    .signature-preview-stack {
        width: 100%;
        text-align: center;
        color: #021c27;
    }

    .signature-preview-image-wrap {
        min-height: 165px;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        margin-bottom: 0.65rem;
    }

    .signature-preview-image {
        width: 150px;
        max-width: 150px;
        max-height: 140px;
        height: auto;
        object-fit: contain;
    }

    .signature-preview-name {
        font-size: 12px;
        line-height: 1.4;
        font-weight: 500;
        margin: 0 0 0.25rem;
        color: #021c27;
    }

    .signature-preview-title {
        font-size: 12px;
        line-height: 1.4;
        letter-spacing: 0.03em;
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 0.18em;
        text-decoration-thickness: 0.07em;
        text-transform: uppercase;
        margin: 0;
        color: #021c27;
    }

    @media (max-width: 1400px) {
        #datatable th:nth-child(10),
        #datatable td:nth-child(10) {
            display: none;
        }
    }

    @media (max-width: 1280px) {
        #datatable th:nth-child(8),
        #datatable td:nth-child(8),
        #datatable th:nth-child(6),
        #datatable td:nth-child(6) {
            display: none;
        }

        #datatable .cell-truncate.email {
            max-width: 120px;
        }
    }

    @media (max-width: 768px) {
        .signature-preview-shell {
            min-height: 280px;
            padding: 1rem;
        }

        .signature-preview-image-wrap {
            min-height: 135px;
        }

        .signature-preview-image {
            width: 150px;
            max-width: 150px;
            max-height: 110px;
        }

        .signature-preview-name {
            font-size: 12px;
        }

        .signature-preview-title {
            font-size: 12px;
        }
    }
</style>
<div class="card-body">
    <%
        const inactiveMode = req.query.inactive == 'true';
        const canUseAdminFilters = Boolean(isAdminFilterAllowed);
    %>
    <div id="customerList">
        <div class="row g-3 mb-4 users-summary">
            <div class="col-md-4">
                <div class="card mb-0">
                    <div class="card-body">
                        <p class="text-muted mb-1">Jumla ya Watumiaji</p>
                        <h3 class="mb-0" id="users-total-count">0</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mb-0">
                    <div class="card-body">
                        <p class="text-muted mb-1">Zinazoonekana</p>
                        <h3 class="mb-0 text-primary" id="users-page-count">0</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mb-0">
                    <div class="card-body">
                        <p class="text-muted mb-1">Mode</p>
                        <h5 class="mb-0 <%= inactiveMode ? 'text-danger' : 'text-success' %>">
                            <span id="users-status-label"><%= inactiveMode ? 'Inactive Users' : 'Active Users' %></span>
                        </h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3 align-items-end">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-2 align-items-end">
                    <button type="button" class="btn btn-info add-btn" id="btn-create-user" >
                        <i class="ri-add-line align-bottom me-1"></i> Sajili Mtumiaji
                    </button>
                    <a href="/Watumiaji"
                       class="btn users-filter-btn <%= !inactiveMode ? 'btn-success active' : 'btn-outline-success' %>">
                        <i class="ri-team-fill me-1"></i> Active Users
                    </a>
                    <a href="/Watumiaji?inactive=true"
                       class="btn users-filter-btn <%= inactiveMode ? 'btn-danger active' : 'btn-outline-danger' %>">
                        <i class="ri-user-unfollow-line me-1"></i> Inactive Users
                    </a>

                    <% if (canUseAdminFilters) { %>
                        <div class="ms-sm-auto d-flex flex-wrap gap-2 align-items-end">
                            <div style="min-width: 240px;">
                                <label for="user-unit-filter" class="form-label mb-1">Filter by Unit</label>
                                <select id="user-unit-filter" class="form-select">
                                    <option value="">All Units</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-light" id="btn-clear-user-filters">
                                <i class="ri-filter-off-line me-1"></i> Clear Filters
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
            <!-- <div class="col-sm">
                <div class="d-flex justify-content-sm-end">
                    <div class="search-box ms-2">
                        <input type="text" class="form-control search" placeholder="Tafuta...">
                        <i class="ri-search-line search-icon"></i>
                    </div>
                </div>
            </div> -->
        </div>

        <div class="col-md-12">
            <div class="table-responsive mt-3 mb-1 users-table-wrap">
            <table class="table table-hover align-middle table-striped table-readable" id="datatable" style="width: 100%">
                <thead class="table-light">
                    <tr>
                        <th>Na.</th>
                        <th>Jina Kamili</th>
                        <th>Simu</th>
                        <th>Email</th>
                        <th>Jukumu</th>
                        <th>Cheo</th>
                        <th>Ofisi</th>
                        <th>Kuingia</th>
                        <th>Sign</th>
                        <th>Nywila</th>
                        <th>Hai</th>
                        <th class="sort text-center" width="11%" >Action</th>
                    </tr>
                </thead>
                <tbody class="list form-check-all">
                </tbody>
            </table>
        </div>
        </div>

        <!-- Pagination and page length -->
        <!-- <%- include('paginations/ajax_pagination.ejs'); %> -->
        <!-- End pagination and page length -->


    </div>
</div><!-- end card -->

