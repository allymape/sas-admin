<div class="email-wrapper d-lg-flex gap-1 mx-n4 mt-n4 p-1 <%= isMyApplications ? 'my-applications-theme' : 'all-applications-theme' %>">
  <div class="email-menu-sidebar">
    <div class="p-4 d-flex flex-column h-100">
      <div class="mx-n4 px-4 email-menu-sidebar-scroll" data-simplebar>
        <div class="mail-list mt-3">
          <a href="<%= routeBase %>?page=1&per_page=<%= pagination.per_page %>" class="<%= !activeCategoryId ? 'active' : '' %>">
            <i class="ri-inbox-archive-line text-primary me-3 align-middle fw-medium"></i>
            <span
              class="mail-list-link"
              data-bs-toggle="tooltip"
              data-bs-custom-class="custom-black-tooltip"
              data-bs-title="Yote"
            >Yote</span>
            <% if (Number(allCount) > 0) { %>
            <span class="badge bg-danger text-white ms-auto"><span class="<%= isMyApplications && activeWorkTab === 'pending' ? 'blink-number' : '' %>"><%= formatCount(allCount) %></span></span>
            <% } %>
          </a>
          <% categories.forEach((category) => { %>
            <a
              href="<%= routeBase %>?<%= buildQuery(1, category.id, activeStatusId, activeWorkTab) %>"
              class="<%= Number(category.id) === Number(activeCategoryId) ? 'active' : '' %>"
            >
              <i class="<%= getCategoryIcon(category.label) %> <%= getCategoryIconColor(category.label) %> me-3 align-middle fw-medium"></i>
              <span
                class="mail-list-link"
                data-bs-toggle="tooltip"
                data-bs-custom-class="custom-black-tooltip"
                data-bs-title="<%= category.label %>"
              ><%= category.label %></span>
              <% if (Number(category.total) > 0) { %>
              <span class="badge bg-soft-danger text-danger ms-auto"><%= formatCount(category.total) %></span>
              <% } %>
            </a>
          <% }) %>
        </div>

      </div>
    </div>
  </div>

  <div class="email-content">
    <div class="p-4 pb-0">
      <div class="border-bottom border-bottom-dashed">
        <div class="row mt-n2 mb-3 mb-sm-0">
          <div class="col col-sm-auto order-1 d-block d-lg-none">
            <button type="button" class="btn btn-soft-success btn-icon btn-sm fs-16 email-menu-btn">
              <i class="ri-menu-2-fill align-bottom"></i>
            </button>
          </div>
          <div class="col-sm order-3 order-sm-2">
            <div class="hstack gap-sm-1 align-items-center flex-wrap email-topbar-link">
              <div class="applications-per-page">
                <form method="GET" action="<%= routeBase %>">
                  <input type="hidden" name="page" value="1">
                  <% if (activeCategoryId) { %>
                  <input type="hidden" name="application_category_id" value="<%= activeCategoryId %>">
                  <% } %>
                  <% if (isMyApplications) { %>
                  <input type="hidden" name="work_tab" value="<%= activeWorkTab %>">
                  <% } else if (activeStatusId === 0 || activeStatusId) { %>
                  <input type="hidden" name="is_approved" value="<%= activeStatusId %>">
                  <% } %>
                  <% if (activeSearch) { %>
                  <input type="hidden" name="search" value="<%= activeSearch %>">
                  <% } %>
                  <select id="applications-per-page" name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    <% perPageOptions.forEach((size) => { %>
                      <option value="<%= size %>" <%= Number(pagination.per_page) === size ? 'selected' : '' %>><%= size %></option>
                    <% }) %>
                  </select>
                </form>
              </div>
            </div>
          </div>
          <div class="col-auto order-2 order-sm-3">
            <div class="d-flex gap-sm-1 email-topbar-link">
              <a href="<%= routeBase %>?<%= buildQuery(pagination.current_page) %>" class="btn btn-ghost-secondary btn-icon shadow-none btn-sm fs-16"><i class="ri-refresh-line align-bottom"></i></a>
              <a
                href="<%= routeBase %>?<%= buildQuery(Math.max(1, pagination.current_page - 1)) %>"
                class="btn btn-ghost-secondary btn-icon shadow-none btn-sm fs-16 <%= pagination.current_page <= 1 ? 'disabled' : '' %>"
                aria-label="Previous page"
              >
                <i class="ri-arrow-left-s-line align-bottom"></i>
              </a>
              <a
                href="<%= routeBase %>?<%= buildQuery(Math.min(pagination.last_page, pagination.current_page + 1)) %>"
                class="btn btn-ghost-secondary btn-icon shadow-none btn-sm fs-16 <%= pagination.current_page >= pagination.last_page ? 'disabled' : '' %>"
                aria-label="Next page"
              >
                <i class="ri-arrow-right-s-line align-bottom"></i>
              </a>
            </div>
          </div>
        </div>

        <div class="row align-items-end mt-3">
          <div class="col">
            <div id="mail-filter-navlist">
              <ul class="nav nav-tabs nav-tabs-custom gap-1 text-center border-bottom-0" role="tablist">
                <% if (isMyApplications) { %>
                  <% workFilters.forEach((filter) => { %>
                    <li class="nav-item">
                      <a
                        href="<%= routeBase %>?<%= buildQuery(1, activeCategoryId, null, filter.id) %>"
                        class="nav-link fw-semibold <%= activeWorkTab === filter.id ? 'active' : '' %>"
                      >
                        <i class="<%= filter.icon %> align-bottom d-inline-block"></i>
                        <span class="ms-1 d-none d-sm-inline-block"><%= filter.label %></span>
                      </a>
                    </li>
                  <% }) %>
                <% } else { %>
                  <% statusFilters.forEach((filter) => { %>
                    <li class="nav-item">
                      <a
                        href="<%= routeBase %>?<%= buildQuery(1, activeCategoryId, filter.id) %>"
                        class="nav-link fw-semibold <%= isActiveStatus(filter.id) ? 'active' : '' %>"
                      >
                        <i class="<%= filter.icon %> align-bottom d-inline-block"></i>
                        <span class="ms-1 d-none d-sm-inline-block"><%= filter.label %></span>
                      </a>
                    </li>
                  <% }) %>
                <% } %>
              </ul>
            </div>
          </div>
          <div class="col-auto">
            <div class="applications-toolbar-meta mb-2">
              <div class="text-muted"><%= pageRangeText %></div>
            </div>
          </div>
        </div>
      </div>

      <% if (!success) { %>
        <div class="alert alert-warning mt-3">Failed to load applications.</div>
      <% } %>

      <div class="message-list-content mx-n4 px-4 message-list-scroll applications-no-icons <%= showAttendAction ? 'with-attend-action' : '' %> <%= !showStaffColumn ? 'without-staff-column' : '' %> <%= isSubmittedTab ? 'submitted-tab' : '' %>" data-simplebar>
        <div class="list-header-grid">
          <span class="category-col">Aina ya Ombi</span>
          <span class="tracking-col">Namba ya ombi</span>
          <span class="school-name-col">Jina la Shule</span>
          <span class="school-type-col">Aina ya Shule</span>
          <span class="ownership-col">Umiliki</span>
          <% if (showStaffColumn) { %><span class="staff-col"><%= staffColumnHeader %></span><% } %>
          <span class="status-col">Hali</span>
          <span class="created-col">Muda</span>
          <% if (showAttendAction) { %><span class="action-col">Hatua</span><% } %>
        </div>
        <ul class="message-list">
          <% if (applications.length === 0) { %>
            <li>
              <div class="col-mail col-mail-2 text-center text-danger py-2">No applications found.</div>
            </li>
          <% } %>

          <% applications.forEach((item, index) => { %>
            <% const status = toStatusMeta(item.is_approved); %>
            <% const canTakeAction = (isMyApplications && activeWorkTab === "pending")
              ? true
              : canTakeActionForItem(item); %>
            <li class="<%= shouldHighlightUnread(item) ? 'unread' : '' %>">
              <div class="col-mail col-mail-1"></div>
              <div class="col-mail col-mail-2">
                <div class="subject">
                  <span class="subject-col category-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.application_category?.app_name || '-' %>"><%= item.application_category?.app_name || "-" %></span>
                  <span class="subject-col tracking-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.tracking_number || '-' %>"><%= item.tracking_number || "-" %></span>
                  <span class="subject-col school-name-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.establishing_school?.school_name || '-' %>"><%= item.establishing_school?.school_name || "-" %></span>
                  <span class="subject-col school-type-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.establishing_school?.school_type || '-' %>"><%= item.establishing_school?.school_type || "-" %></span>
                  <span class="subject-col ownership-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.establishing_school?.registry_type?.registry || '-' %>"><%= item.establishing_school?.registry_type?.registry || "-" %></span>
                  <% if (showStaffColumn) { %>
                    <% if (showApplicantColumn) { %>
                      <span class="subject-col staff-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.applicant?.name || '' %>">
                        <span class="applicant-name"><%= item.applicant?.name || "" %></span>
                      </span>
                    <% } else { %>
                      <span class="subject-col staff-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.assigned_staff?.cheo || '' %>">
                        <%= item.assigned_staff?.cheo || "" %>
                      </span>
                    <% } %>
                  <% } %>
                  <span class="subject-col status-col">
                    <span
                      class="<%= status.badgeClass %>"
                      data-bs-toggle="tooltip"
                      data-bs-custom-class="custom-black-tooltip"
                      data-bs-title="<%= status.text %>"
                      aria-label="<%= status.text %>"
                    ><i class="<%= status.icon %>"></i></span>
                  </span>
                  <span class="subject-col created-col" data-bs-toggle="tooltip" data-bs-custom-class="custom-black-tooltip" data-bs-title="<%= item.created_at ? dateFormat(item.created_at, 'DD MMM YYYY, HH:mm') : '-' %>">
                    <%= item.created_at ? dateFormat(item.created_at, "DD MMM YYYY, HH:mm") : "-" %>
                  </span>
                  <% if (showAttendAction) { %>
                    <span class="subject-col action-col">
                      <% if (item.tracking_number) { %>
                        <a
                          href="/my-applications/<%= encodeURIComponent(item.tracking_number) %>/attend#overview-info"
                          class="btn btn-sm attend-btn <%= canTakeAction ? '' : 'attend-view-btn' %>"
                        ><i class="<%= canTakeAction ? 'ri-arrow-right-up-line' : 'ri-eye-line' %> align-bottom"></i><%= canTakeAction ? 'Fungua' : 'Tazama' %></a>
                      <% } else { %>
                        -
                      <% } %>
                    </span>
                  <% } %>
                </div>
              </div>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.bootstrap && bootstrap.Tooltip) {
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        bootstrap.Tooltip.getOrCreateInstance(el);
      });
    }

    const topSearchForm = document.querySelector("#page-topbar .app-search");
    const topSearchInput = document.getElementById("search-options");
    if (topSearchForm && topSearchInput) {
      topSearchInput.value = <%- JSON.stringify(activeSearch) %>;
      topSearchForm.addEventListener("submit", function (e) {
        e.preventDefault();
        e.stopImmediatePropagation();

        const searchValue = (topSearchInput.value || "").trim();
        const params = new URLSearchParams();
        params.set("page", "1");
        params.set("per_page", "<%= pagination.per_page %>");

        <% if (activeCategoryId) { %>
        params.set("application_category_id", "<%= activeCategoryId %>");
        <% } %>

        <% if (isMyApplications) { %>
        params.set("work_tab", "<%= activeWorkTab %>");
        <% } else if (activeStatusId === 0 || activeStatusId) { %>
        params.set("is_approved", "<%= activeStatusId %>");
        <% } %>

        if (searchValue) params.set("search", searchValue);
        window.location.href = "<%= routeBase %>?" + params.toString();
      }, true);
    }
  });
</script>

<%- include('../layouts/partials/footer.ejs' , {
  card_title : ''
}) %>
