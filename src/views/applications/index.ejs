<%- include('../layouts/partials/header.ejs' , {
  title : 'Applications',
  page_title : pageTitle || 'Maombi Yote',
  card_title : ''
}) %>

<%
  const toStatusMeta = (statusId) => {
    const id = Number(statusId);
    if (id === 2) return { icon: "ri-check-line", text: "Limekubaliwa", badgeClass: "badge bg-success" };
    if (id === 3) return { icon: "ri-close-line", text: "Limekataliwa", badgeClass: "badge bg-danger" };
    if (id === 4) return { icon: "ri-reply-line", text: "Limerudishwa kwa Mwombaji", badgeClass: "badge bg-warning text-dark" };
    if (id === 1) return { icon: "ri-loader-4-line", text: "Linafanyiwa kazi", badgeClass: "badge bg-info" };
    return { icon: "ri-upload-cloud-2-line", text: "Limewasilishwa", badgeClass: "badge bg-secondary" };
  };
  const getCategoryIcon = (label) => {
    const name = String(label || "").toLowerCase();
    if (name.includes("kuanzisha shule")) return "ri-building-4-line";
    if (name.includes("uthibitisho wa umiliki na meneja wa shule")) return "ri-shield-check-line";
    if (name.includes("kusajili shule")) return "ri-file-list-3-line";
    if (name.includes("kuongeza mikondo")) return "ri-git-merge-line";
    if (name.includes("kubadili aina ya usajili")) return "ri-file-edit-line";
    if (name.includes("kubadili mmiliki wa shule")) return "ri-user-shared-line";
    if (name.includes("kubadili meneja wa shule")) return "ri-user-settings-line";
    if (name.includes("kubadili jina la shule")) return "ri-edit-2-line";
    if (name.includes("kuhamisha shule")) return "ri-route-line";
    if (name.includes("kufuta usajili wa shule")) return "ri-delete-bin-line";
    if (name.includes("kuongeza tahasusi")) return "ri-book-open-line";
    if (name.includes("kuongeza dahalia")) return "ri-home-4-line";
    if (name.includes("kuongeza bweni")) return "ri-hotel-bed-line";
    return "ri-price-tag-3-fill";
  };
  const getCategoryIconColor = (label) => {
    const name = String(label || "").toLowerCase();
    if (name.includes("kuanzisha shule")) return "text-primary";
    if (name.includes("uthibitisho wa umiliki na meneja wa shule")) return "text-info";
    if (name.includes("kusajili shule")) return "text-success";
    if (name.includes("kuongeza mikondo")) return "text-warning";
    if (name.includes("kubadili aina ya usajili")) return "text-secondary";
    if (name.includes("kubadili mmiliki wa shule")) return "text-danger";
    if (name.includes("kubadili meneja wa shule")) return "text-dark";
    if (name.includes("kubadili jina la shule")) return "text-primary";
    if (name.includes("kuhamisha shule")) return "text-info";
    if (name.includes("kufuta usajili wa shule")) return "text-danger";
    if (name.includes("kuongeza tahasusi")) return "text-success";
    if (name.includes("kuongeza dahalia")) return "text-warning";
    if (name.includes("kuongeza bweni")) return "text-secondary";
    return "text-muted";
  };
  const categories = Array.isArray(categorySummary) ? categorySummary : [];
  const formatCount = (value) => {
    const num = Number(value);
    if (!Number.isFinite(num)) return "0";
    return num.toLocaleString("en-US");
  };
  const statusFilters = [
    { id: null, label: "Yote", icon: "ri-filter-3-line" },
    { id: 0, label: "Yaliyowasilishwa", icon: "ri-upload-cloud-2-line" },
    { id: 1, label: "Yanayochakatwa", icon: "ri-loader-4-line" },
    { id: 2, label: "Yaliyokubaliwa", icon: "ri-check-line" },
    { id: 3, label: "Yaliyokataliwa", icon: "ri-close-line" },
    { id: 4, label: "Yaliyorudishwa", icon: "ri-reply-line" },
  ];
  const workFilters = [
    { id: "pending", label: "Maombi Yanayosubiri", icon: "ri-time-line" },
    { id: "handled", label: "Maombi Yaliyoshughulikiwa", icon: "ri-checkbox-circle-line" },
  ];
  const allCount = categories.length
    ? categories.reduce((sum, category) => sum + (Number(category.total) || 0), 0)
    : pagination.total;
  const activeCategoryId = selectedCategoryId || null;
  const activeStatusId = selectedStatusId === 0 || selectedStatusId ? Number(selectedStatusId) : null;
  const currentWorkTab = (typeof selectedWorkTab !== "undefined" && selectedWorkTab !== null)
    ? selectedWorkTab
    : "";
  const activeWorkTab = (currentWorkTab === "handled" || currentWorkTab === "pending")
    ? currentWorkTab
    : "pending";
  const activeSearch = String(searchTerm || "").trim();
  const routeBase = routeBasePath || "/applications";
  const isMyApplications = routeBase === "/my-applications";
  const showAttendAction = true;
  const showStaffColumn = !(isMyApplications && activeWorkTab === "pending");
  const showApplicantColumn = !isMyApplications;
  const staffColumnHeader = isMyApplications ? "Afisa" : "Mwombaji";
  const isSubmittedTab = !isMyApplications && Number(activeStatusId) === 0;
  const loggedInStaffId = Number(req?.user?.staff_id || req?.user?.id);
  const allowUnreadHighlight = isMyApplications && activeWorkTab !== "handled";
  const canTakeActionForItem = (item) => {
    if (typeof item?.can_attend === "boolean") {
      return item.can_attend;
    }

    const approvalStatus = Number(item?.is_approved);
    const assignedStaffId = Number(
      item?.staff_id ||
      item?.assigned_staff?.id ||
      item?.current_staff?.id
    );
    const workflow = item?.workflow || {};
    const allowedActions = Array.isArray(workflow?.allowed_actions)
      ? workflow.allowed_actions
      : [];
    const isCurrentAssigneeByWorkflow = Boolean(workflow?.is_current_assignee);
    const isAssignedToLoggedInStaff = Number.isFinite(loggedInStaffId)
      && Number.isFinite(assignedStaffId)
      && loggedInStaffId === assignedStaffId;

    return [0, 1].includes(approvalStatus)
      && (isCurrentAssigneeByWorkflow || allowedActions.length > 0 || isAssignedToLoggedInStaff);
  };
  const shouldHighlightUnread = (item) => {
    const approvalStatus = Number(item?.is_approved);
    const assignedStaffId = Number(item?.assigned_staff?.id || item?.staff_id);
    const isPendingLike = [0, 1].includes(approvalStatus);

    if (isMyApplications) {
      return activeWorkTab !== "handled" && isPendingLike;
    }

    const isUnreadTab = activeStatusId === null || [0, 1].includes(Number(activeStatusId));
    return isUnreadTab
      && isPendingLike
      && Number.isFinite(loggedInStaffId)
      && Number.isFinite(assignedStaffId)
      && loggedInStaffId === assignedStaffId;
  };
  const buildQuery = (
    page,
    categoryId = activeCategoryId,
    statusId = activeStatusId,
    workTab = activeWorkTab
  ) => {
    const query = [`page=${page}`, `per_page=${pagination.per_page}`];
    if (categoryId) query.push(`application_category_id=${categoryId}`);
    if (isMyApplications) {
      query.push(`work_tab=${workTab}`);
    } else if (statusId === 0 || statusId) {
      query.push(`is_approved=${statusId}`);
    }
    if (activeSearch) query.push(`search=${encodeURIComponent(activeSearch)}`);
    return query.join("&");
  };
  const isActiveStatus = (id) => {
    if (id === null || id === undefined) return activeStatusId === null;
    if (activeStatusId === null || activeStatusId === undefined) return false;
    return Number(id) === Number(activeStatusId);
  };
  const pageStart = applications.length ? ((pagination.current_page - 1) * pagination.per_page) + 1 : 0;
  const pageEnd = applications.length ? ((pagination.current_page - 1) * pagination.per_page) + applications.length : 0;
  const pageRangeText = `${formatCount(pageStart)}-${formatCount(pageEnd)} of ${formatCount(pagination.total)}`;
  const perPageOptions = [10, 15, 20, 50, 100];
%>

