<%- include('../layouts/partials/header.ejs' , {
  title : 'Attend Application',
  page_title : pageTitle || `OMBI LA ${String(application?.application_category?.app_name || "-").toUpperCase()}`,
  card_title : ''
}) %>

<%
  const delegatedFromName = String(req?.user?.delegated_from_user_name || "").trim();
  const delegatedFromId = Number(req?.user?.handover_by || 0);
  const delegatedUntilAt = req?.user?.delegated_until_at || null;
  const hasIncomingHandover = Boolean(req?.user?.has_active_incoming_handover);
  const delegatedOwnerLabel = delegatedFromName || (delegatedFromId > 0 ? `USER #${delegatedFromId}` : "another staff member");
  const delegatedUntilLabel = delegatedUntilAt ? dateFormat(delegatedUntilAt, "DD/MM/YYYY HH:mm") : "";
%>

<% if (hasIncomingHandover) { %>
<div class="alert alert-warning d-flex align-items-center gap-2">
  <i class="ri-user-shared-line"></i>
  <span>You are acting on behalf of <b><%= delegatedOwnerLabel %></b><%= delegatedUntilLabel ? ` until ${delegatedUntilLabel}` : "" %>.</span>
</div>
<% } %>

<%
  const app = application || {};
  const school = app.establishing_school || {};
  const category = app.application_category || {};
  const applicant = app.applicant || {};
  const comments = (Array.isArray(app.comments) ? app.comments : [])
    .slice()
    .sort((left, right) => {
      const leftIdParsed = Number.parseInt(left?.id, 10);
      const rightIdParsed = Number.parseInt(right?.id, 10);
      const leftId = Number.isFinite(leftIdParsed) ? leftIdParsed : 0;
      const rightId = Number.isFinite(rightIdParsed) ? rightIdParsed : 0;
      if (rightId !== leftId) return rightId - leftId;

      const leftDate = left?.created_at ? new Date(left.created_at).getTime() : 0;
      const rightDate = right?.created_at ? new Date(right.created_at).getTime() : 0;
      return rightDate - leftDate;
    });
  const attachments = Array.isArray(app.attachments) ? app.attachments : [];
  const commentAttachmentTypes = Array.isArray(locals.commentAttachmentTypes) ? locals.commentAttachmentTypes : [];
  const locationHierarchy = school.location_hierarchy || {};
  const schoolRegistration = school.school_registration || {};
  const contactPerson = school.contact_person || {};
  const instituteInfo = contactPerson.institute_info || {};
  const personalInfo = contactPerson.personal_info || {};
  const workflow = app.workflow || {};
  const canTakeActionNow = typeof canTakeAction === "boolean" ? canTakeAction : false;
  const workflowActions = canTakeActionNow && Array.isArray(workflow.allowed_actions) ? workflow.allowed_actions : [];
  const workflowActionLabels = workflow.action_labels && typeof workflow.action_labels === "object"
    ? workflow.action_labels
    : {};
  const assignableStaff = canTakeActionNow && Array.isArray(workflow.assignable_staff) ? workflow.assignable_staff : [];
  const assignableStaffOptions = assignableStaff
    .map((staff) => ({
      id: Number.parseInt(staff?.id, 10),
      name: String(staff?.name || "").trim().toUpperCase(),
      role_name: String(staff?.role_name || "").trim(),
    }))
    .filter((staff) => Number.isFinite(staff.id) && staff.id > 0 && staff.name)
    .reduce((acc, staff) => {
      if (!acc.some((item) => item.id === staff.id)) acc.push(staff);
      return acc;
    }, [])
    .sort((left, right) => left.name.localeCompare(right.name));

  const actionLabel = (action) => {
    const dbLabel = String(workflowActionLabels?.[action] || "").trim();
    if (dbLabel) return dbLabel;
    if (action === "Review") return "Submit";
    if (action === "Assign") return "Assign";
    if (action === "Forward") return "Forward";
    if (action === "Approve") return "Approve";
    if (action === "Reject") return "Reject";
    if (action === "Return") return "Send Back";
    if (action === "Return_back") return "Return to Applicant";
    return action;
  };

  const actionTone = (action) => {
    if (action === "Review") return "primary";
    if (action === "Assign") return "info";
    if (action === "Forward") return "success";
    if (action === "Approve") return "success";
    if (action === "Reject") return "danger";
    if (action === "Return") return "warning";
    if (action === "Return_back") return "warning";
    return "secondary";
  };

  const actionNeedsTarget = (action) => ["Assign", "Return"].includes(action);
  const currentUserPermissions = Array.isArray(req?.user?.userPermissions) ? req.user.userPermissions : [];
  const hasAssignStaffPermission = currentUserPermissions.some((permission) => {
    const key = String(permission || "").trim().toLowerCase();
    return key === "assign-staff" || key === "assigned-staff";
  });
  const toBooleanFlag = (value) => {
    if (typeof value === "boolean") return value;
    const normalized = String(value ?? "").trim().toLowerCase();
    return normalized === "1" || normalized === "true" || normalized === "yes";
  };
  const workflowStepsForActions = Array.isArray(app.workflow_steps) ? app.workflow_steps : [];
  const currentProcessForActions = app.current_process || {};
  const currentWorkflowUnitForActions = currentProcessForActions?.current_workflow_unit || {};
  const currentProcessWorkflowIdForActions = Number(currentProcessForActions?.workflow_id || 0);
  const startFromCurrentWorkflowUnit = toBooleanFlag(currentWorkflowUnitForActions?.is_start);
  const finalFromCurrentWorkflowUnit = toBooleanFlag(currentWorkflowUnitForActions?.is_final);
  const canApproveInCurrentWorkflowUnit = toBooleanFlag(currentWorkflowUnitForActions?.can_approve);
  const isCurrentWorkflowStartStep = startFromCurrentWorkflowUnit || workflowStepsForActions.some(
    (step) =>
      Number(step?.workflow_id || 0) === currentProcessWorkflowIdForActions
      && toBooleanFlag(step?.is_start),
  );
  const isCurrentWorkflowFinalStep = finalFromCurrentWorkflowUnit || workflowStepsForActions.some(
    (step) =>
      Number(step?.workflow_id || 0) === currentProcessWorkflowIdForActions
      && toBooleanFlag(step?.is_final),
  );
  const hideReturnToPreviousStaffAction = hasAssignStaffPermission && isCurrentWorkflowStartStep;
  const hideReturnBackToApplicantAction = hasAssignStaffPermission && (
    isCurrentWorkflowStartStep
    || (finalFromCurrentWorkflowUnit && canApproveInCurrentWorkflowUnit)
  );
  const alignReturnToPreviousStepRight = hasAssignStaffPermission
    && finalFromCurrentWorkflowUnit
    && canApproveInCurrentWorkflowUnit;
  const hideForwardAction = hasAssignStaffPermission && isCurrentWorkflowFinalStep;
  const hideApproveRejectActions = hasAssignStaffPermission && !canApproveInCurrentWorkflowUnit;
  const workflowActionButtons = !canTakeActionNow
    ? []
    : (workflowActions.length
      ? workflowActions
      : (hasAssignStaffPermission
        ? ["Assign", "Forward", "Approve", "Reject", "Return", "Return_back"]
        : ["Review"]));
  const shouldHideWorkflowAction = (action) => {
    if (hideReturnToPreviousStaffAction && action === "Return") return true;
    if (hideReturnBackToApplicantAction && action === "Return_back") return true;
    if (hideForwardAction && action === "Forward") return true;
    if (hideApproveRejectActions && (action === "Approve" || action === "Reject")) return true;
    return false;
  };
  const createdAt = app.created_at ? dateFormat(app.created_at, "DD/MM/YYYY HH:mm:ss") : "-";
  const updatedAt = app.updated_at ? dateFormat(app.updated_at, "DD/MM/YYYY HH:mm:ss") : "-";
  const approvedAtDisplay = app.approved_at ? dateFormat(app.approved_at, "DD/MM/YYYY HH:mm:ss") : "";
  const isDevelopment = typeof process !== "undefined" && String(process.env.NODE_ENV || "").toLowerCase() === "local";

  const toStatusLabel = (status) => {
    const id = Number(status);
    if (id === 2) return "LILILOTHIBITISHWA";
    if (id === 3) return "LILILOKATALIWA";
    if (id === 4) return "LILILORUDISHWA";
    if (id === 1) return "LINALOFANYIWA KAZI";
    return "LILILOWASILISHWA";
  };

  const statusLabel = toStatusLabel(app.is_approved);
  const approvalStatus = Number(app.is_approved ?? 0);
  const applicationCategoryId = Number(app.application_category_id || category.id || 0);
  const categoryNameRaw = String(category.app_name || "").trim();
  const categoryNameLower = categoryNameRaw.toLowerCase();
  const isChangeTypeApplication = applicationCategoryId > 4;

  const statusChipMeta = (status) => {
    const id = Number(status);
    if (id === 2) return { tone: "success", icon: "ri-checkbox-circle-fill" };
    if (id === 3) return { tone: "danger", icon: "ri-close-circle-fill" };
    if (id === 4) return { tone: "warning", icon: "ri-arrow-go-back-fill" };
    if (id === 1) return { tone: "primary", icon: "ri-loader-4-line" };
    return { tone: "secondary", icon: "ri-send-plane-2-fill" };
  };
  const chipMeta = statusChipMeta(app.is_approved);

  const toText = (value) => {
    if (value === null || value === undefined || value === "") return "-";
    if (typeof value === "boolean") return value ? "Ndiyo" : "Hapana";
    return String(value);
  };

  const toAttachmentViewerPath = (attachmentPath) => {
    const raw = String(attachmentPath || "").trim();
    if (!raw) return "";
    const normalized = raw.replace(/^\/+/, "");
    return `/View-Attachment/${encodeURI(normalized)}`;
  };

  const attachmentFileName = (attachmentPath) => {
    const raw = String(attachmentPath || "").trim();
    if (!raw) return "Attachment";
    const clean = raw.split("?")[0];
    const parts = clean.split("/");
    return decodeURIComponent(parts[parts.length - 1] || "Attachment");
  };

  const fileExtFromName = (filename) => {
    const clean = String(filename || "").trim();
    if (!clean || !clean.includes(".")) return "";
    return clean.split(".").pop().toLowerCase();
  };

  const readableAttachmentLabel = (typeName, attachmentPath, index = 0, total = 1) => {
    const baseName = String(typeName || "Attachment").trim() || "Attachment";
    const rawName = attachmentFileName(attachmentPath);
    const ext = fileExtFromName(rawName) || "pdf";
    const suffix = Number(total || 0) > 1 ? ` (${Number(index || 0) + 1})` : "";
    return `${baseName}${suffix}.${ext}`;
  };
  const toAcceptAttr = (fileFormat) =>
    String(fileFormat || "")
      .split(",")
      .map((item) => item.trim())
      .filter(Boolean)
      .map((item) => (item.startsWith(".") ? item : `.${item}`))
      .join(",");
  const toFileSizeMbLabel = (rawSize) => {
    const size = Number(rawSize || 0);
    if (!Number.isFinite(size) || size <= 0) return "";

    // In this project some attachment types store max size directly in MB (e.g. 2),
    // while others may be stored as raw bytes. Handle both safely.
    const mbValue = size <= 50 ? size : (size / (1024 * 1024));
    const rounded = mbValue >= 10 ? Math.round(mbValue) : Math.round(mbValue * 10) / 10;
    return `${Number.isInteger(rounded) ? rounded : rounded.toFixed(1)} MB`;
  };

  const hasDisplayValue = (value) => {
    if (value === null || value === undefined) return false;
    const normalized = String(value).trim();
    if (normalized === "") return false;
    const lowered = normalized.toLowerCase();
    return !["-", "--", "null", "undefined", "n/a", "na", "none"].includes(lowered);
  };

  const hasSchoolContactValue = (value) => {
    if (value === null || value === undefined) return false;
    const normalized = String(value).trim();
    if (normalized === "") return false;
    const lowered = normalized.toLowerCase();
    return !["-", "--", "null", "undefined", "n/a", "na", "none", "nill"].includes(lowered);
  };

  const firstObject = (...candidates) => {
    for (const candidate of candidates) {
      if (candidate && typeof candidate === "object" && !Array.isArray(candidate)) return candidate;
      if (Array.isArray(candidate) && candidate.length > 0 && candidate[0] && typeof candidate[0] === "object") return candidate[0];
    }
    return {};
  };

  const pickFirstValue = (source, keys = []) => {
    const obj = source && typeof source === "object" ? source : {};
    for (const key of keys) {
      const value = obj[key];
      if (hasDisplayValue(value)) return String(value).trim();
    }
    return "";
  };

  const requestedInfoRows = (() => {
    if (!isChangeTypeApplication) return [];

    const formerSchoolInfo = firstObject(
      app.former_school_info,
      app.former_school_infos,
      app.formerSchoolInfo,
      app.formerSchoolInfos
    );
    const formerOwnerInfo = firstObject(
      app.former_owner,
      app.former_owners,
      app.formerOwner,
      app.formerOwners
    );
    const formerManagerInfo = firstObject(
      app.former_manager,
      app.former_managers,
      app.formerManager,
      app.formerManagers
    );
    const formerCombinationInfo = firstObject(
      app.former_school_combination,
      app.former_school_combinations,
      app.formerSchoolCombination,
      app.formerSchoolCombinations
    );

    const rows = [];
    const pushRow = (label, value) => {
      if (hasDisplayValue(value)) rows.push({ label, value: String(value).trim() });
    };

    pushRow("Aina ya Mabadiliko", categoryNameRaw);

    if (categoryNameLower.includes("jina")) {
      pushRow("Jina Jipya Linalopendekezwa", pickFirstValue(formerSchoolInfo, ["new_school_name", "school_name_new", "proposed_school_name", "new_name", "school_name"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerSchoolInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerSchoolInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else if (categoryNameLower.includes("mmiliki")) {
      pushRow("Mmiliki Mpya", pickFirstValue(formerOwnerInfo, ["new_owner_name", "owner_name", "full_name", "name"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerOwnerInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerOwnerInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else if (categoryNameLower.includes("meneja")) {
      pushRow("Meneja Mpya", pickFirstValue(formerManagerInfo, ["new_manager_name", "manager_name", "full_name", "name"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerManagerInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerManagerInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else if (categoryNameLower.includes("hamisha")) {
      pushRow("Mahali Panapolengwa", pickFirstValue(formerSchoolInfo, ["new_location_name", "new_location", "destination_location", "target_location"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerSchoolInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerSchoolInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else if (categoryNameLower.includes("usajili")) {
      pushRow("Aina Mpya ya Usajili", pickFirstValue(formerSchoolInfo, ["new_registration_type_name", "registration_type_name", "new_registration_type", "registration_type"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerSchoolInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerSchoolInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else if (categoryNameLower.includes("mkondo") || categoryNameLower.includes("tahasusi")) {
      pushRow("Mabadiliko Yanayopendekezwa", pickFirstValue(formerCombinationInfo, ["new_combination_name", "combination_name", "new_specialization", "specialization_name"]));
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerCombinationInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerCombinationInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    } else {
      pushRow("Sababu ya Mabadiliko", pickFirstValue(formerSchoolInfo, ["reason", "change_reason", "description", "comments"]));
      pushRow("Tarehe Inayolengwa", pickFirstValue(formerSchoolInfo, ["target_date", "effective_date", "date_of_change", "proposed_date"]));
    }

    return rows;
  })();

  const contactPersonPersonalName = [
    personalInfo.first_name,
    personalInfo.middle_name,
    personalInfo.last_name,
    personalInfo.full_name,
  ]
    .map((value) => String(value || "").trim())
    .filter((value, index, arr) => hasDisplayValue(value) && arr.findIndex((item) => item.toUpperCase() === value.toUpperCase()) === index)
    .join(" ");

  const applicantDisplayName =
    contactPerson.display_name ||
    contactPerson.title ||
    contactPersonPersonalName ||
    instituteInfo.institute_name ||
    instituteInfo.name ||
    applicant.name ||
    "-";
  const applicantEmailDisplay = String(contactPerson.email || applicant.email || "").trim();
  const applicantPhoneDisplay = String(
    contactPerson.phone ||
    personalInfo.phone_number ||
    instituteInfo.phone_number ||
    applicant.phone ||
    ""
  ).trim();
  const applicantPoBoxDisplay = String(contactPerson.box || "").trim();
  const applicantLgaDisplay = String(
    contactPerson.lga_box_location_name ||
    contactPerson.lga_district?.name ||
    contactPerson.lga_box_location ||
    ""
  ).trim();
  const applicantAddressDisplay = String(contactPerson.address || "").trim();
  const applicantStreetDisplay = String(contactPerson.street_id || "").trim();
  const applicantTypeDisplay = (() => {
    const applicantableType = String(contactPerson.applicantable_type || "").toLowerCase();
    if (applicantableType.includes("institute")) return "Taasisi";
    if (applicantableType.includes("personal")) return "Binafsi";
    if (hasDisplayValue(instituteInfo.institute_name || instituteInfo.name)) return "Taasisi";
    if (hasDisplayValue(personalInfo.full_name || personalInfo.first_name || personalInfo.last_name)) return "Binafsi";
    return "";
  })();
  const isInstitutionApplicant = applicantTypeDisplay === "Taasisi";
  const applicantPrimaryLabel = isInstitutionApplicant ? "Jina la Taasisi" : "Jina";
  const institutionRegistrationDisplay = String(instituteInfo.registration_number || "").trim();
  const institutionCategoryDisplay = String(instituteInfo.category || "").trim();

  const uniqueDisplayList = (values = []) => {
    const seen = new Set();
    return values
      .map((value) => String(value).trim())
      .filter((value) => hasDisplayValue(value))
      .filter((value) => {
        const key = value.toUpperCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
  };

  const cleanCommentText = (value) => {
    if (value === null || value === undefined) return "-";
    const text = String(value)
      .replace(/<br\s*\/?>/gi, "\n")
      .replace(/<\/?p[^>]*>/gi, "")
      .replace(/<[^>]+>/g, "")
      .replace(/&nbsp;/gi, " ")
      .trim();
    return text || "-";
  };

  const commentDepartmentKey = (comment) => {
    if (!comment) return "-";
    return String(
      comment.receiver_department?.name ||
      comment.receiver_unit?.name ||
      comment.receiver?.name ||
      comment.user_to ||
      "-"
    ).trim();
  };

  const normalizeCommentTitle = (value) => {
    const title = String(value || "")
      .replace(/[()]/g, "")
      .trim()
      .toUpperCase();
    return title;
  };

  const commentSenderTitle = (comment) => {
    if (!comment || typeof comment !== "object") return "";
    const rawTitle = normalizeCommentTitle(
      comment.sender_title ||
      comment.title ||
      comment.rank_name ||
      comment.cheo ||
      comment.sender?.title ||
      comment.sender?.rank_name ||
      comment.sender?.role_name ||
      ""
    );
    const firstSegment = String(rawTitle || "").split("-")[0];
    return normalizeCommentTitle(firstSegment);
  };

  const commentSenderDisplayName = (comment) => {
    const baseName = String(
      comment?.sender?.name ||
      (`USER #${comment?.user_from || "-"}`)
    ).trim();
    const title = commentSenderTitle(comment);
    const location = String(comment?.location_label || "").trim();
    if (title && location) return `${baseName} (${title} - ${location})`;
    if (title) return `${baseName} (${title})`;
    if (location) return `${baseName} (${location})`;
    return baseName;
  };

  const schoolCombinations = Array.isArray(schoolRegistration.school_combinations)
    ? schoolRegistration.school_combinations
    : [];
  const michepuoList = uniqueDisplayList(
    schoolCombinations.map((item) => item?.combination?.school_specialization?.specialization),
  );
  const combinationList = schoolCombinations
    .map((item) => item?.combination?.combination)
    .filter((value) => hasDisplayValue(value));
  const michepuoValue = michepuoList.length
    ? michepuoList.join(", ")
    : school.school_specialization?.specialization;
  const tahasusiValue = combinationList.length
    ? combinationList.join(", ")
    : school.school_specialization?.specialization;
  const elimuNgaziDisplay = hasDisplayValue(school.certificate_type?.level)
    ? `${school.certificate_type.level}${hasDisplayValue(school.certificate_type?.certificate) ? ` (${school.certificate_type.certificate})` : ""}`
    : (hasDisplayValue(school.certificate_type?.certificate) ? `(${school.certificate_type.certificate})` : "-");
  const mikondoDisplay = hasDisplayValue(school.stream) ? String(school.stream).trim() : "-";
  const lughaYaKufundishiaDisplay = hasDisplayValue(school.language?.language)
    ? String(school.language.language).trim()
    : "-";

  const fileNumberQuickValue =
    school.file_number ||
    school.school_file_number ||
    schoolRegistration.file_number ||
    schoolRegistration.school_file_number ||
    schoolRegistration.file_no ||
    "";
  const fileNumberDisplay = hasDisplayValue(fileNumberQuickValue)
    ? String(fileNumberQuickValue).trim()
    : "";

  const registrationNumberQuickValue =
    schoolRegistration.registration_number ||
    school.registration_number ||
    school.registration_no ||
    app.registration_number ||
    "";
  const registrationNumberDisplay = hasDisplayValue(registrationNumberQuickValue)
    ? String(registrationNumberQuickValue).trim()
    : "";
  const isApprovedRegistrationApplication = applicationCategoryId === 4 && Number(app.is_approved || 0) === 2;
  const shouldShowRegistrationNumber = (isChangeTypeApplication || isApprovedRegistrationApplication) && hasDisplayValue(registrationNumberDisplay);
  const schoolCategoryQuickValue =
    school.school_category?.category_name ||
    school.school_category?.category ||
    school.school_category?.name ||
    school.school_type?.category ||
    school.school_type?.name ||
    "";
  const schoolCategoryDisplay = hasDisplayValue(schoolCategoryQuickValue)
    ? String(schoolCategoryQuickValue).trim()
    : "";
  const latitudeDisplay = String(school.latitude || "").trim();
  const longitudeDisplay = String(school.longitude || "").trim();
  const hasCoordinates = hasDisplayValue(latitudeDisplay) && hasDisplayValue(longitudeDisplay);
  const googleMapsLink = hasCoordinates
    ? `https://www.google.com/maps?q=${encodeURIComponent(`${latitudeDisplay},${longitudeDisplay}`)}`
    : "";
  const extraSchoolFields = [
    { label: "Simu ya Shule", value: school.school_phone },
    { label: "Barua Pepe ya Shule", value: school.school_email },
    { label: "S. L. P ya Shule", value: school.po_box },
    { label: "Anwani ya Shule", value: school.school_address },
    { label: "Tovuti ya Shule", value: school.website },
    { label: "Eneo la Shule", value: school.area },
    { label: "Kozi na Masomo", value: school.lessons_and_courses },
    { label: "Uwiano Mwalimu/Mwanafunzi", value: school.teacher_student_ratio_recommendation },
    { label: "Namba ya Udhibiti", value: school.control_number },
    { label: "Namba ya Faili", value: school.file_number },
    { label: "Folio", value: school.school_folio },
    { label: "Folio ya Upeo", value: school.max_folio },
    { label: "Uwezo wa Wanafunzi Wakiume", value: school.male_capacity },
    { label: "Uwezo wa Wanafunzi Wakike", value: school.female_capacity },
    { label: "Latitude", value: latitudeDisplay },
    { label: "Longitude", value: longitudeDisplay },
    { label: "Ramani (Google Maps)", value: "Fungua Ramani", href: googleMapsLink },
  ].filter((field) => {
    if (Object.prototype.hasOwnProperty.call(field, "href")) {
      return hasDisplayValue(field?.href);
    }
    return hasDisplayValue(field?.value);
  });
  const extraSchoolRows = [];
  for (let i = 0; i < extraSchoolFields.length; i += 2) {
    extraSchoolRows.push(extraSchoolFields.slice(i, i + 2));
  }

  const sidebarQuickRows = [
    { label: "Namba ya Ombi", value: app.tracking_number || "-" },
    { label: "Jina la Shule", value: toText(school.school_name) },
    { label: "Mwombaji", value: applicantDisplayName || "-" },
    ...(fileNumberDisplay
      ? [{ label: "Namba ya Jalada", value: fileNumberDisplay }]
      : []),
    ...(schoolCategoryDisplay
      ? [{ label: "Aina ya Shule", value: schoolCategoryDisplay }]
      : []),
    ...(shouldShowRegistrationNumber
      ? [{ label: "Namba ya Usajili", value: registrationNumberDisplay }]
      : []),
  ];

  const statusWorkflowSteps = [
    { key: 0, label: "Imewasilishwa" },
    { key: 1, label: "Inachakatwa" },
    { key: 2, label: "Imethibitishwa" },
    { key: 3, label: "Imekataliwa" },
    { key: 4, label: "Imerudishwa" },
  ];

  const statusStepClass = (stepKey) => {
    if (approvalStatus === 2) {
      if (stepKey === 0 || stepKey === 1) return "done";
      if (stepKey === 2) return "current";
      return "todo";
    }
    if (approvalStatus === 3) {
      if (stepKey === 0 || stepKey === 1) return "done";
      if (stepKey === 3) return "current";
      return "todo";
    }
    if (approvalStatus === 4) {
      if (stepKey === 0 || stepKey === 1) return "done";
      if (stepKey === 4) return "current";
      return "todo";
    }
    if (approvalStatus === 1) {
      if (stepKey === 0) return "done";
      if (stepKey === 1) return "current";
      return "todo";
    }
    if (stepKey === 0) return "current";
    return "todo";
  };

  const statusStepIcon = (stepKey, stepState) => {
    if (stepKey === 2) return "ri-checkbox-circle-fill";
    if (stepKey === 3) return stepState === "todo" ? "ri-close-circle-line" : "ri-close-circle-fill";
    if (stepKey === 4) return stepState === "todo" ? "ri-arrow-go-back-line" : "ri-arrow-go-back-fill";
    if (stepState === "done") return "ri-checkbox-circle-fill";
    if (stepState === "current") return "ri-loader-4-line";
    return "ri-checkbox-blank-circle-line";
  };

  const statusStepToneClass = (stepKey) => {
    if (stepKey === 1) return "tone-primary";
    if (stepKey === 2) return "tone-success";
    if (stepKey === 3) return "tone-danger";
    if (stepKey === 4) return "tone-warning";
    return "tone-neutral";
  };

  const workflowSteps = (Array.isArray(app.workflow_steps) ? app.workflow_steps : [])
    .slice()
    .sort((left, right) => Number(left?._order || 0) - Number(right?._order || 0));
  const currentProcess = app.current_process || {};
  const currentProcessWorkflowId = Number(currentProcess?.workflow_id || 0);

  const normalizeProcessStatus = (value) => String(value || "").trim().toLowerCase();
  const currentStepFromWorkflow = workflowSteps.find(
    (step) => Number(step?.workflow_id || 0) === currentProcessWorkflowId,
  );
  const currentWorkflowOrder = Number(currentStepFromWorkflow?._order || currentProcess?.step_order || 0);

  const workflowStepState = (step, index) => {
    const stepWorkflowId = Number(step?.workflow_id || 0);
    const stepOrder = Number(step?._order || index + 1);
    const processStatus = normalizeProcessStatus(step?.process_status);

    if (currentProcessWorkflowId && stepWorkflowId === currentProcessWorkflowId) return "current";
    if (processStatus && processStatus !== "pending") return "done";
    if (currentWorkflowOrder && stepOrder < currentWorkflowOrder) return "done";
    if (processStatus === "pending") return "queue";
    return "todo";
  };

  const workflowStepStateLabel = (state) => {
    if (state === "done") return "Imekamilika";
    if (state === "current") return "Hatua ya Sasa";
    if (state === "queue") return "Inasubiri";
    return "Haijaanza";
  };

  const workflowStepStateIcon = (state) => {
    if (state === "done") return "ri-checkbox-circle-fill";
    if (state === "current") return "ri-loader-4-line";
    if (state === "queue") return "ri-time-line";
    return "ri-checkbox-blank-circle-line";
  };

  const workflowStepBadgeClass = (state) => {
    if (state === "done") return "bg-success-subtle text-success";
    if (state === "current") return "bg-primary-subtle text-primary";
    if (state === "queue") return "bg-warning-subtle text-warning";
    return "bg-light text-muted";
  };

  const normalizeCommentAction = (value) => {
    const action = String(value || "").trim().toLowerCase();
    if (!action) return "";
    if (action === "assign") return "Assign";
    if (action === "review" || action === "submit") return "Review";
    if (action === "forward") return "Forward";
    if (action === "approve") return "Approve";
    if (action === "reject") return "Reject";
    if (action === "return") return "Return";
    if (action === "return_back" || action === "return back") return "Return_back";
    return "";
  };

  const commentActionPastLabel = (comment) => {
    const action = normalizeCommentAction(comment?.action);
    if (!action) return "";
    if (action === "Assign") return "Assigned";
    if (action === "Review") return "Reviewed";
    if (action === "Forward") return "Forwarded";
    if (action === "Approve") return "Approved";
    if (action === "Reject") return "Rejected";
    if (action === "Return") return "Returned";
    if (action === "Return_back") return "Returned to Applicant";
    return action;
  };

  const commentActionTimelineIcon = (comment) => {
    const action = normalizeCommentAction(comment?.action);
    if (action === "Assign") return "ri-user-add-line";
    if (action === "Review") return "ri-send-plane-line";
    if (action === "Forward") return "ri-arrow-right-up-line";
    if (action === "Approve") return "ri-checkbox-circle-line";
    if (action === "Reject") return "ri-close-circle-line";
    if (action === "Return") return "ri-arrow-go-back-line";
    if (action === "Return_back") return "ri-reply-line";
    return "ri-message-3-fill";
  };

  const toStaffId = (value) => {
    const parsed = Number.parseInt(value, 10);
    return Number.isFinite(parsed) ? parsed : null;
  };

  const sortCommentsDesc = (list) => {
    return (Array.isArray(list) ? list : [])
      .slice()
      .sort((left, right) => {
        const leftIdParsed = Number.parseInt(left?.id, 10);
        const rightIdParsed = Number.parseInt(right?.id, 10);
        const leftId = Number.isFinite(leftIdParsed) ? leftIdParsed : 0;
        const rightId = Number.isFinite(rightIdParsed) ? rightIdParsed : 0;
        if (rightId !== leftId) return rightId - leftId;

        const leftDate = left?.created_at ? new Date(left.created_at).getTime() : 0;
        const rightDate = right?.created_at ? new Date(right.created_at).getTime() : 0;
        return rightDate - leftDate;
      });
  };

  const commentFlow = comments.map((comment, index) => {
    const key = commentDepartmentKey(comment);
    const nextKey = index < comments.length - 1 ? commentDepartmentKey(comments[index + 1]) : null;
    const actionLabel = commentActionPastLabel(comment);
    return {
      comment,
      key,
      actionLabel,
      timelineIcon: commentActionTimelineIcon(comment),
      isTransition: index === comments.length - 1 || key !== nextKey,
      sequence: comments.length - index,
    };
  });
