    align-items: center;
    gap: 0.35rem;
    margin-top: 0.18rem;
    min-height: 20px;
    flex-wrap: wrap;
  }

  .attachment-row .uploaded-label {
    font-size: 0.67rem;
    color: var(--attend-text-muted);
    margin: 0;
  }

  .attachment-row .uploaded-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid #d5e3f4;
    border-radius: 999px;
    padding: 0.14rem 0.5rem;
    font-size: 0.67rem;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .attachment-list-compact {
    display: flex;
    flex-direction: column;
    gap: 0.38rem;
    max-height: 330px;
    overflow: auto;
    padding-right: 2px;
  }

  .attachment-row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }

  .attachment-status-badge {
    border-radius: 999px;
    padding: 0.13rem 0.42rem;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.1px;
    white-space: nowrap;
  }

  .attachment-status-badge.is-uploaded {
    color: #116b41;
    background: #dcf8ea;
    border: 1px solid #bdeed6;
  }

  .attachment-status-badge.is-pending {
    color: #7a5b00;
    background: #fff6dd;
    border: 1px solid #ffe7a3;
  }

  #attachment-preview-modal {
    z-index: 1085 !important;
  }

  body.preview-modal-open .modal-backdrop.show {
    z-index: 1080 !important;
  }

  #attachment-preview-modal .modal-dialog {
    z-index: 1086;
  }

  .workflow-track-card {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
    margin-bottom: 14px;
  }

  .workflow-track-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .workflow-track-head .section-title {
    margin-bottom: 0;
  }

  .workflow-current-chip {
    border: 1px solid var(--attend-border);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 700;
    color: var(--attend-value-color);
    background: var(--attend-secondary-soft);
    white-space: nowrap;
  }

  .workflow-vertical-timeline {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wf-step {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 12px;
  }

  .wf-step-lane {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wf-line {
    width: 0;
    border-left: 2px dashed #d4deec;
    flex: 1;
    min-height: 10px;
  }

  .wf-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    border: 1px solid #b7c9e5;
    background: #e4ebf7;
    color: #54627a;
  }

  .wf-step.done .wf-dot {
    background: #198754;
    color: #fff;
    border-color: #198754;
  }

  .wf-step.current .wf-dot {
    background: #0d6efd;
    color: #fff;
    border-color: #0d6efd;
  }

  .wf-step.queue .wf-dot {
    background: #f59f00;
    color: #fff;
    border-color: #f59f00;
  }

  .wf-step-body {
    padding: 2px 0 8px;
    border-bottom: 1px dashed #d9e3f2;
  }

  .wf-step-inline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 10px;
  }

  .wf-step-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .wf-step-order {
    font-size: 12px;
    font-weight: 700;
    color: var(--attend-value-color);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .wf-step-unit {
    font-size: 13px;
    font-weight: 700;
    color: var(--vz-body-color);
    margin-bottom: 0;
  }

  .wf-step-inline .badge {
    flex: 0 0 auto;
  }

  .wf-step-inline .wf-step-meta-item {
    font-size: 11px;
    color: var(--attend-text-muted);
    white-space: nowrap;
  }

  .wf-step-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-size: 11px;
    color: var(--attend-text-muted);
    margin-bottom: 6px;
  }

  .wf-step-note {
    font-style: italic;
    color: #64748b;
    font-size: 12px;
    margin: 0;
  }

  .wf-step-comments {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .wf-step-comment-item {
    padding-left: 0;
    border-left: none !important;
  }

  .wf-step-comment-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 11px;
    color: var(--attend-text-muted);
    margin-bottom: 2px;
  }

  .wf-step-comment-action {
    display: inline-flex;
    align-items: center;
    padding: 1px 8px;
    border-radius: 999px;
    border: 1px solid #bfe7ce;
    background: #e8f4ee;
    color: #0b5e3b;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .wf-step-comment-body {
    font-size: 13px;
    color: var(--vz-body-color);
    white-space: pre-line;
  }

  .comment-flow-item {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 0;
    align-items: stretch;
  }

  .comment-flow-lane {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .comment-flow-connector {
    width: 0;
    border-left: 2px dashed #cfd8e6;
  }

  .comment-flow-connector.top,
  .comment-flow-connector.bottom {
    flex: 1;
    min-height: 10px;
  }

  .comment-flow-connector.full {
    flex: 1;
    min-height: 100%;
  }

  .comment-flow-node {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid var(--attend-border);
    background: #2f7fe5;
    color: #fff;
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .comment-flow-node.placeholder {
    background: #d7deea;
    color: #d7deea;
    border-color: #d7deea;
  }

  .comment-card {
    --comment-meta-indent: 2.6rem;
    border: 1px solid #cfd8e6;
    border-left: none !important;
    border-radius: 0;
    background: var(--attend-surface);
    padding: 10px 12px;
    box-shadow: 0 2px 8px rgba(31, 79, 159, 0.07);
    margin-left: -8px;
  }

  .comment-card::before {
    display: none;
  }

  .comment-meta-main {
    font-size: 14px;
    font-weight: 700;
    color: var(--vz-body-color);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .comment-sender-name {
    min-width: 0;
    flex: 1 1 auto;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .comment-meta-date {
    flex: 0 0 auto;
    font-size: 11px;
    font-weight: 600;
    line-height: 1.15;
    color: var(--attend-text-muted);
    white-space: nowrap;
  }

  .comment-meta-tail {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex: 0 0 auto;
    min-width: 0;
  }

  .comment-seq {
    font-size: 11px;
    line-height: 1;
    font-weight: 800;
    color: #1d4f99;
    border: 1px solid var(--attend-border);
    border-radius: 999px;
    padding: 0.22rem 0.36rem;
    background: var(--attend-secondary-soft);
    flex: 0 0 auto;
  }

  .comment-meta-sub {
    font-size: 12px;
    font-weight: 600;
    color: var(--attend-text-muted);
    margin-top: 2px;
    padding-left: var(--comment-meta-indent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .comment-action-separator {
    color: #8a97ab;
    margin: 0 4px 0 2px;
  }

  .comment-action-inline {
    display: inline-flex;
    align-items: center;
    padding: 1px 8px;
    border-radius: 999px;
    border: 1px solid #d6dbe5;
    background: #f4f7fc;
    color: #41506a;
    font-weight: 600;
    font-size: 11px;
    line-height: 1.15;
    letter-spacing: 0.1px;
  }

  .comment-action-inline.comment-action--primary {
    border-color: #b9d0fb;
    background: #eaf1ff;
    color: #0d4ea4;
  }

  .comment-action-inline.comment-action--info {
    border-color: #bfe6f4;
    background: #eaf9ff;
    color: #0b6b88;
  }

  .comment-action-inline.comment-action--success {
    border-color: #bfe7ce;
    background: #e8f4ee;
    color: #0b5e3b;
  }

  .comment-action-inline.comment-action--warning {
    border-color: #efd89e;
    background: #fff8e5;
    color: #8b5d00;
  }

  .comment-action-inline.comment-action--danger {
    border-color: #f0b9bf;
    background: #ffecef;
    color: #a52737;
  }

  .comment-action-inline.comment-action--secondary {
    border-color: #d6dbe5;
    background: #f4f7fc;
    color: #41506a;
  }

  .comment-action-main {
    margin-right: 2px;
  }

  .comment-divider {
    border-bottom: 1px solid #e9edf3;
    margin: 8px 0;
  }

  .comment-body {
    color: #2e3646;
    font-size: 14px;
    line-height: 1.5;
    text-align: justify;
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .comment-flow-item {
      grid-template-columns: 24px minmax(0, 1fr);
    }
  }
</style>

<% if (!success || !application) { %>
  <div class="card">
    <div class="card-body">
      <div class="alert alert-danger mb-0">Imeshindikana kupata taarifa za ombi hili.</div>
    </div>
  </div>
<% } else { %>
  <div class="row">
    <div class="col-xxl-3">
      <div class="card mb-3 attend-extra-card attend-time-card">
        <div class="card-body">
          <div class="table-card">
            <table class="table mb-0 attend-summary-table">
              <tbody>
                <tr class="time-highlight-row">
                  <td class="fw-medium">Muda wa Ombi</td>
                  <td class="ellipsis-tooltip"><%= toText(createdAt) %></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card mb-3 attend-summary-card">
        <div class="card-header">
          <h6 class="attend-summary-title">TAARIFA ZA MSINGI</h6>
        </div>
        <div class="card-body">
          <div class="table-card">
            <table class="table mb-0 attend-summary-table">
              <tbody>
                <% sidebarQuickRows.forEach((row) => { %>
                  <tr>
                    <td class="fw-medium"><%= row.label %></td>
                    <td class="ellipsis-tooltip"><%= row.value %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% if (isChangeTypeApplication && requestedInfoRows.length > 0) { %>
        <div class="card mb-3 attend-extra-card attend-demo-card">
          <div class="card-header">
            <h6 class="attend-demo-title">TAARIFA ZINAZOOMBEWA</h6>
          </div>
          <div class="card-body">
            <table class="table mb-0 attend-summary-table">
              <tbody>
                <% requestedInfoRows.forEach((row) => { %>
                  <tr>
                    <td class="fw-medium"><%= row.label %></td>
                    <td class="ellipsis-tooltip"><%= row.value %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

      <% if (approvedAtDisplay) { %>
        <div class="card attend-extra-card attend-time-card attend-approved-time-card">
          <div class="card-body">
            <div class="table-card">
              <table class="table mb-0 attend-summary-table">
                <tbody>
                  <tr class="approved-time-highlight-row">
                    <td class="fw-medium">Tarehe ya Kuthibitishwa</td>
                    <td class="ellipsis-tooltip always-tooltip" title="<%= approvedAtDisplay %>"><%= approvedAtDisplay %></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <div class="col-xxl-9">
      <div class="card attend-main-card mt-2">
        <div class="card-header">
          <div class="attend-page-head">
            <div>
              <div class="mb-2">
                <a href="/my-applications?work_tab=pending" class="btn btn-sm btn-outline-primary">
                  <i class="ri-arrow-left-line align-middle me-1"></i>Rudi Maombi Yangu
                </a>
              </div>
              <h4 class="attend-page-title">OMBI LA <%= toText(category.app_name) %></h4>
              <p class="attend-page-subtitle">
                <span class="ellipsis-tooltip always-tooltip" title="Namba ya Ombi"><%= toText(app.tracking_number) %></span>
                <span>-</span>
                <span class="ellipsis-tooltip always-tooltip" title="Shule"><%= toText(school.school_name) %> <%= toText(school.school_type?.category) %></span>
                <span>-</span>
                <span class="ellipsis-tooltip always-tooltip" title="Mkoa"><%= toText(locationHierarchy.region?.name) %></span>
                <span>-</span>
                <span class="ellipsis-tooltip always-tooltip" title="Wilaya"><%= toText(locationHierarchy.district?.name) %></span>
                <span>-</span>
                <span class="ellipsis-tooltip always-tooltip" title="Kata"><%= toText(locationHierarchy.ward?.name) %></span>
                <span>-</span>
                <span class="ellipsis-tooltip always-tooltip" title="Mtaa"><%= toText(locationHierarchy.street?.name) %></span>
              </p>
            </div>
            <span class="attend-status-chip status-<%= chipMeta.tone %>">
              <i class="<%= chipMeta.icon %>"></i>
              <span><%= statusLabel %></span>
            </span>
          </div>
          <ul class="status-workflow-inline">
            <% statusWorkflowSteps.forEach((step, index) => { %>
              <% const stepState = statusStepClass(step.key); %>
              <li class="<%= stepState %> <%= statusStepToneClass(step.key) %>">
                <span class="status-icon">
                  <i class="<%= statusStepIcon(step.key, stepState) %>"></i>
                </span>
                <span><%= step.label %></span>
              </li>
              <% if (index < statusWorkflowSteps.length - 1) { %>
                <li aria-hidden="true" class="status-sep"></li>
              <% } %>
            <% }) %>
          </ul>
          <ul class="nav nav-pills nav-justified mb-3 attend-tabs flex-wrap" role="tablist">
            <li class="nav-item">
              <a class="nav-link active ellipsis-tooltip" data-bs-toggle="tab" href="#overview-info" role="tab">Taarifa za Shule</a>
            </li>
            <li class="nav-item">
              <a class="nav-link ellipsis-tooltip" data-bs-toggle="tab" href="#applicant-info" role="tab">Mwombaji</a>
            </li>
            <li class="nav-item">
              <a class="nav-link ellipsis-tooltip" data-bs-toggle="tab" href="#attachments-info" role="tab">Viambatisho</a>
            </li>
            <li class="nav-item">
              <a class="nav-link ellipsis-tooltip" data-bs-toggle="tab" href="#comments-info" role="tab">Maoni</a>
            </li>
            <% if (isDevelopment) { %>
              <li class="nav-item">
                <a class="nav-link ellipsis-tooltip" data-bs-toggle="tab" href="#raw-endpoint-info" role="tab">Raw</a>
              </li>
            <% } %>
          </ul>
        </div>
        <div class="card-body">
          <div class="tab-content">
            <div class="tab-pane active" id="overview-info" role="tabpanel">
              <div class="section-card">
                <h6 class="section-title">Taarifa za Shule</h6>
                <table class="table mb-0 split-table">
                  <tbody>
                    <tr>
                      <td>Jina la Shule</td><td class="ellipsis-tooltip"><%= toText(school.school_name) %></td>
                      <td>Aina ya Shule</td><td class="ellipsis-tooltip"><%= toText(school.school_type?.category) %></td>
                    </tr>
                    <tr>
                      <td>Ngazi ya Elimu</td><td class="ellipsis-tooltip"><%= elimuNgaziDisplay %></td>
                      <td>Umiliki</td><td class="ellipsis-tooltip"><%= toText(school.registry_type?.registry) %></td>
                    </tr>
                    <% if (registrationNumberDisplay) { %>
                      <tr>
                        <td>Namba ya Usajili</td><td class="ellipsis-tooltip"><%= registrationNumberDisplay %></td>
                        <td>Mwombaji</td><td class="ellipsis-tooltip"><%= toText(applicantDisplayName) %></td>
                      </tr>
                    <% } else { %>
                      <tr>
                        <td>Mwombaji</td><td class="ellipsis-tooltip" colspan="3"><%= toText(applicantDisplayName) %></td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <div class="section-card">
                <h6 class="section-title">Eneo la Shule</h6>
                <table class="table mb-0 split-table">
                  <tbody>
                    <tr>
                      <td>Mkoa</td><td class="ellipsis-tooltip"><%= toText(locationHierarchy.region?.name) %></td>
                      <td>Halmashauri</td><td class="ellipsis-tooltip"><%= toText(locationHierarchy.district?.name) %></td>
                    </tr>
                    <tr>
                      <td>Kata</td><td class="ellipsis-tooltip"><%= toText(locationHierarchy.ward?.name) %></td>
                      <td>Mtaa</td><td class="ellipsis-tooltip"><%= toText(locationHierarchy.street?.name) %></td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div class="section-card">
                <h6 class="section-title">Taarifa za Elimu</h6>
                <table class="table mb-0 split-table">
                  <tbody>
                    <tr>
                      <td>Lugha ya Kufundishia</td><td class="ellipsis-tooltip"><%= toText(lughaYaKufundishiaDisplay) %></td>
                      <td>Mikondo</td><td class="ellipsis-tooltip"><%= toText(mikondoDisplay) %></td>
                    </tr>
                    <% if (hasDisplayValue(michepuoValue) || hasDisplayValue(tahasusiValue)) { %>
                      <tr>
                        <td>Michepuo</td><td class="ellipsis-tooltip"><%= toText(michepuoValue) %></td>
                        <td>Tahasusi</td><td class="ellipsis-tooltip"><%= toText(tahasusiValue) %></td>
                      </tr>
                    <% } %>
                    <tr>
                      <td>Wanafunzi</td><td class="ellipsis-tooltip"><%= toText(school.number_of_students) %></td>
                      <td>Walimu</td><td class="ellipsis-tooltip"><%= toText(school.number_of_teachers) %></td>
                    </tr>
                    <tr>
                      <td>Hosteli</td><td class="ellipsis-tooltip"><%= toText(school.is_hostel) %></td>
                      <td>Mahitaji Maalum</td><td class="ellipsis-tooltip"><%= toText(school.is_for_disabled) %></td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <% if (extraSchoolRows.length) { %>
                <div class="section-card">
                  <h6 class="section-title">Taarifa za Ziada za Shule</h6>
                  <table class="table mb-0 split-table">
                    <tbody>
                      <% extraSchoolRows.forEach((pair) => { %>
                        <tr>
                          <td><%= pair?.[0]?.label || "" %></td>
                          <td class="ellipsis-tooltip">
                            <% if (pair?.[0]?.href) { %>
                              <a href="<%= pair[0].href %>" target="_blank" rel="noopener noreferrer"> <%= toText(pair?.[0]?.value) %> </a>
                            <% } else { %>
                              <%= toText(pair?.[0]?.value) %>
                            <% } %>
                          </td>
                          <% if (pair?.[1]) { %>
                            <td><%= pair[1].label %></td>
                            <td class="ellipsis-tooltip">
                              <% if (pair?.[1]?.href) { %>
                                <a href="<%= pair[1].href %>" target="_blank" rel="noopener noreferrer"> <%= toText(pair[1].value) %> </a>
                              <% } else { %>
                                <%= toText(pair[1].value) %>
                              <% } %>
                            </td>
                          <% } else { %>
                            <td></td><td></td>
                          <% } %>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

            <div class="tab-pane" id="applicant-info" role="tabpanel">
              <div class="section-card">
                <h6 class="section-title">Taarifa za Mwombaji</h6>
                <table class="table mb-0 split-table">
                  <tbody>
                    <tr>
                      <td><%= applicantPrimaryLabel %></td><td class="ellipsis-tooltip"><%= toText(applicantDisplayName) %></td>
                      <td>Aina ya Mwombaji</td><td class="ellipsis-tooltip"><%= toText(applicantTypeDisplay) %></td>
                    </tr>
                    <% if (isInstitutionApplicant && (hasDisplayValue(institutionRegistrationDisplay) || hasDisplayValue(institutionCategoryDisplay))) { %>
                      <tr>
                        <td>Namba ya Usajili wa Taasisi</td><td class="ellipsis-tooltip"><%= toText(institutionRegistrationDisplay) %></td>
                        <td>Aina ya Taasisi</td><td class="ellipsis-tooltip"><%= toText(institutionCategoryDisplay) %></td>
                      </tr>
                    <% } %>
                    <% if (hasDisplayValue(applicantEmailDisplay) || hasDisplayValue(applicantPhoneDisplay)) { %>
                      <tr>
                        <td>Barua Pepe</td><td class="ellipsis-tooltip"><%= toText(applicantEmailDisplay) %></td>
                        <td>Simu</td><td class="ellipsis-tooltip"><%= toText(applicantPhoneDisplay) %></td>
                      </tr>
                    <% } %>
                    <% if (hasDisplayValue(applicantPoBoxDisplay) || hasDisplayValue(applicantLgaDisplay)) { %>
                      <tr>
                        <td>S. L. P</td><td class="ellipsis-tooltip"><%= toText(applicantPoBoxDisplay) %></td>
                        <td>Halmashauri ya S. L. P</td><td class="ellipsis-tooltip"><%= toText(applicantLgaDisplay) %></td>
                      </tr>
                    <% } %>
                    <% if (hasDisplayValue(applicantAddressDisplay) || hasDisplayValue(applicantStreetDisplay)) { %>
                      <tr>
                        <td>Anwani</td><td class="ellipsis-tooltip"><%= toText(applicantAddressDisplay) %></td>
                        <td>Mtaa</td><td class="ellipsis-tooltip"><%= toText(applicantStreetDisplay) %></td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane" id="attachments-info" role="tabpanel">
              <% if (!attachments.length) { %>
                <div class="alert alert-light mb-0">Hakuna viambatisho vilivyorekodiwa kwa tracking hii.</div>
              <% } %>
              <% if (attachments.length) { %>
                <div class="table-responsive table-card">
                  <table class="table align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th>#</th>
                        <th>AINA YA KIAMBATISHO</th>
                        <th>TAREHE YA KUPAKIWA</th>
                        <th class="attachments-file-col">KIAMBATA</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% attachments.forEach((att, idx) => { %>
                        <% const attachmentPath = String(att?.attachment_path || "").trim(); %>
                        <% const attachmentViewerPath = toAttachmentViewerPath(attachmentPath); %>
                        <tr>
                          <td><%= idx + 1 %></td>
                          <td><%= toText(att.attachment_type?.attachment_name).toUpperCase() %></td>
                          <td><%= toText(att.created_at ? dateFormat(att.created_at, "DD/MM/YYYY HH:mm:ss") : null) %></td>
                          <td class="attachments-file-col">
                            <% if (attachmentViewerPath) { %>
                              <button
                                type="button"
                                class="btn btn-sm btn-outline-primary js-open-attachment-modal"
                                data-file-url="<%= attachmentViewerPath %>"
                                data-file-name="<%= attachmentFileName(attachmentPath) %>"
                              >
                                Soma Kiambatisho
                              </button>
                            <% } else { %>
                              <span>-</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
            <div class="modal fade" id="attachment-preview-modal" tabindex="-1" aria-labelledby="attachment-preview-title" aria-hidden="true">
              <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="attachment-preview-title">Attachment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body" id="attachment-preview-body"></div>
                </div>
              </div>
            </div>

            <div class="tab-pane" id="comments-info" role="tabpanel">
              <div class="workflow-launch">
                <% if (canTakeActionNow) { %>
                  <button
                    type="button"
                    class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#workflow-action-modal"
                  >
                    <i class="ri-message-2-line align-middle me-1"></i>Andika Maoni
                  </button>
                <% } %>
                <button
                  type="button"
                  class="btn btn-outline-primary workflow-toggle-btn"
                  id="toggle-workflow-steps-btn"
                  data-bs-toggle="collapse"
                  data-bs-target="#workflow-track-collapse"
                  aria-expanded="false"
                  aria-controls="workflow-track-collapse"
                >
                  <i id="toggle-workflow-steps-icon" class="ri-eye-off-line align-middle me-1"></i>
                  <span id="toggle-workflow-steps-label">Onesha Workflow</span>
                </button>
              </div>
              <div class="collapse" id="workflow-track-collapse">
                <div class="workflow-track-card">
                  <% if (currentProcessWorkflowId) { %>
                    <div class="workflow-track-head justify-content-end">
                      <span class="workflow-current-chip">
                        Hatua ya sasa: <%= toText(currentWorkflowOrder || currentProcess.step_order) %>
                      </span>
                    </div>
                  <% } %>
                  <% if (!workflowSteps.length) { %>
                    <div class="alert alert-light mb-0">Hakuna hatua za workflow kwa aina hii ya ombi.</div>
                  <% } else { %>
                    <div class="workflow-vertical-timeline">
                      <% workflowSteps.forEach((step, index) => { %>
                        <% const stepState = workflowStepState(step, index); %>
                        <% const stepOrder = Number(step?._order || (index + 1)); %>
                        <% const stepAssigned = step?.assigned_to ? `STAFF #${step.assigned_to}` : ""; %>
                        <% const stepDate = step?.process_updated_at || step?.process_created_at; %>
                        <div class="wf-step <%= stepState %>">
                          <div class="wf-step-lane">
                            <% if (index > 0) { %><span class="wf-line"></span><% } %>
                            <span class="wf-dot"><i class="<%= workflowStepStateIcon(stepState) %>"></i></span>
                            <% if (index < workflowSteps.length - 1) { %><span class="wf-line"></span><% } %>
                          </div>
                          <div class="wf-step-body">
                            <div class="wf-step-inline">
                              <span class="wf-step-order">Hatua <%= stepOrder %></span>
                              <span class="badge <%= workflowStepBadgeClass(stepState) %>"><%= workflowStepStateLabel(stepState) %></span>
                              <span class="wf-step-unit"><%= toText(step?.unit_name || step?.role_name || ("UNIT #" + toText(step?.unit_id))) %></span>
                              <span class="wf-step-meta-item">Status: <%= toText(step?.process_status || "Waiting") %></span>
                              <% if (stepAssigned) { %>
                                <span class="wf-step-meta-item">Assigned: <%= stepAssigned %></span>
                              <% } %>
                              <span class="wf-step-meta-item">Tarehe: <%= stepDate ? dateFormat(stepDate, "DD/MM/YYYY HH:mm:ss") : "-" %></span>
                            </div>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              </div>
              <% if (canTakeActionNow && !workflowActions.length) { %>
                <div class="alert alert-warning">Hakuna hatua ya workflow unayoruhusiwa kufanya kwa sasa kwenye ombi hili.</div>
              <% } %>
              <% if (!comments.length) { %>
                <div class="alert alert-light mb-0">Hakuna maoni yaliyowekwa kwa sasa.</div>
              <% } %>
              <div class="comment-timeline">
                <% commentFlow.forEach((entry, index) => { %>
                  <% const comment = entry.comment; %>
                  <% const mainCommentAction = commentActionPastLabel(comment); %>
                  <% const mainCommentActionTone = actionTone(normalizeCommentAction(comment?.action)); %>
                  <% const commentReceiverName = String(comment?.receiver?.name || "").trim(); %>
                  <div class="comment-flow-item">
                    <div class="comment-flow-lane">
                      <% if (entry.isTransition) { %>
                        <% if (index > 0) { %>
                          <span class="comment-flow-connector top"></span>
                        <% } %>
                        <span
                          class="comment-flow-node ellipsis-tooltip"
                          title="<%= entry.actionLabel ? `${entry.key} - ${entry.actionLabel}` : entry.key %>"
                        >
                          <i class="<%= entry.timelineIcon %>"></i>
                        </span>
                        <% if (index < commentFlow.length - 1) { %>
                          <span class="comment-flow-connector bottom"></span>
                        <% } %>
                      <% } else { %>
                        <span class="comment-flow-connector full"></span>
                      <% } %>
                    </div>
                    <div class="comment-card">
                      <div class="comment-meta-main">
                        <span class="comment-seq">M.<%= entry.sequence %></span>
                        <span class="ellipsis-tooltip comment-sender-name"><%= commentSenderDisplayName(comment) %></span>
                        <span class="comment-meta-tail">
                          <% if (mainCommentAction) { %>
                            <span class="comment-action-inline comment-action-main comment-action--<%= mainCommentActionTone %>"><%= mainCommentAction %></span>
                          <% } %>
                          <span class="comment-meta-date"><%= comment.created_at ? dateFormat(comment.created_at , 'ddd DD/MM/YYYY HH:mm:ss') : "-" %></span>
                        </span>
                      </div>
                      <% if (commentReceiverName) { %>
                        <div class="comment-meta-sub">
                          Kwa: <%= commentReceiverName %>
                        </div>
                      <% } %>
                      <div class="comment-divider"></div>
                      <div class="comment-body"><%= cleanCommentText(comment.coments || comment.comment || comment.content) %></div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>

            <% if (isDevelopment) { %>
              <div class="tab-pane" id="raw-endpoint-info" role="tabpanel">
                <pre class="bg-light border rounded p-3 mb-0" style="max-height: 560px; overflow: auto;"><%= JSON.stringify(app, null, 2) %></pre>
              </div>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>

  <% if (canTakeActionNow) { %>
    <div
      class="modal fade"
      id="workflow-action-modal"
      tabindex="-1"
      data-bs-backdrop="static"
      data-bs-keyboard="false"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header bg-light">
            <div>
              <h5 class="modal-title mb-1">Andika Maoni</h5>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="comment-compose-card mb-0">
              <form id="workflow-action-form" method="post" action="/my-applications/<%= encodeURIComponent(app.tracking_number) %>/workflow">
                <input type="hidden" name="action" id="workflow-action-input" value="">
                <% if (hasAssignStaffPermission) { %>
                  <div class="mb-3 workflow-select-wrap is-visible" id="workflow-target-wrap">
                    <label class="form-label fw-semibold">Chagua Afisa</label>
                    <select
                      class="form-select js-workflow-target-select"
                      name="target_staff_id"
                      id="workflow-target-staff"
                    >
                      <option value="">Chagua Afisa</option>
                      <% assignableStaffOptions.forEach((staff) => { %>
                        <option value="<%= staff.id %>"><%= staff.name %> - <%= toText(staff.role_name) %></option>
                      <% }) %>
                    </select>
                    <% if (!assignableStaffOptions.length) { %>
                      <small class="text-muted fst-italic">Hakuna officer wa ku-assign kwa sasa.</small>
                    <% } %>
                  </div>
                <% } %>
                <div class="mb-3 workflow-rich-editor" id="workflow-rich-editor-wrap">
                  <div class="ck-editor-reverse">
                    <div id="workflow-comment-editor"></div>
                  </div>
                  <textarea
                    class="form-control comment-compose-input d-none"
                    name="content"
                    id="workflow-comment-content"
                    rows="5"
                    placeholder="Andika maoni hapa..."
                    required
                  ></textarea>
                </div>
                <% if (commentAttachmentTypes.length) { %>
                  <div class="mb-3">
                    <input type="hidden" name="attachment_payload_json" id="workflow-attachments-payload" value="[]">
                    <div class="attachment-list-compact">
                      <% commentAttachmentTypes.forEach((attachmentType) => { %>
                        <% const existingTypeAttachments = attachments.filter((item) => Number(item?.attachment_type_id || item?.attachment_type?.id || 0) === Number(attachmentType.id)); %>
                        <% const attachmentSizeMb = toFileSizeMbLabel(attachmentType.file_size); %>
                        <div
                          class="border rounded p-2 attachment-row"
                          data-application-id="<%= String(app.id || '') %>"
                          data-tracking-number="<%= String(app.tracking_number || '') %>"
                          data-attachment-type-id="<%= String(attachmentType.id || '') %>"
                        >
                          <div class="attachment-row-head">
                            <div>
                              <div class="attachment-title"><%= toText(attachmentType.attachment_name) %></div>
                              <div class="attachment-meta">
                                <% if (attachmentType.file_format) { %><%= String(attachmentType.file_format).toUpperCase() %><% } %>
                                <% if (attachmentType.file_format && attachmentSizeMb) { %> · <% } %>
                                <% if (attachmentSizeMb) { %><%= attachmentSizeMb %><% } %>
                              </div>
                            </div>
                            <span class="attachment-status-badge <%= existingTypeAttachments.length ? 'is-uploaded' : 'is-pending' %>">
                              <%= existingTypeAttachments.length ? 'Imepakiwa' : 'Haijapakiwa' %>
                            </span>
                          </div>
                          <div class="d-flex gap-2 align-items-start">
                            <input
                              type="file"
                              class="form-control js-workflow-attachment-input comment-attachment-input"
                              data-attachment-type-id="<%= attachmentType.id %>"
                              data-application-id="<%= String(app.id || '') %>"
                              data-tracking-number="<%= String(app.tracking_number || '') %>"
                              data-attachment-type-name="<%= toText(attachmentType.attachment_name) %>"
                              data-max-size-mb="<%= Number(attachmentType.file_size || 0) %>"
                              data-allowed-ext="<%= String(attachmentType.file_format || '') %>"
                              data-required="<%= attachmentType.is_required ? '1' : '0' %>"
                              accept="<%= toAcceptAttr(attachmentType.file_format) %>"
                            >
                            <button
                              type="button"
                              class="btn btn-primary text-nowrap js-upload-attachment-btn btn-upload btn-upload-attachment"
                              data-upload-for-type="<%= attachmentType.id %>"
                              disabled
                            >
                              Pandisha File
                            </button>
                          </div>
                          <small class="text-muted d-block mt-1 js-upload-status"></small>
                          <% if (existingTypeAttachments.length) { %>
                            <div class="uploaded-inline">
                              <small class="uploaded-label">Vilivyopakiwa:</small>
                              <div class="d-flex flex-wrap gap-1 js-uploaded-files">
                                <% existingTypeAttachments.forEach((att, attIndex) => { %>
                                  <% const existingPath = toAttachmentViewerPath(att?.attachment_path); %>
                                  <% const displayLabel = readableAttachmentLabel(attachmentType?.attachment_name, att?.attachment_path, attIndex, existingTypeAttachments.length); %>
                                  <% if (existingPath) { %>
                                    <a
                                      href="<%= existingPath %>"
                                      class="uploaded-chip js-open-attachment-modal text-decoration-none"
                                      data-file-url="<%= existingPath %>"
                                      data-file-name="<%= displayLabel %>"
                                      title="<%= displayLabel %>"
                                    >
                                      <i class="ri-file-list-3-line"></i> <%= displayLabel %>
                                    </a>
                                  <% } %>
                                <% }) %>
                              </div>
                            </div>
                          <% } %>
                          <% if (!existingTypeAttachments.length) { %>
                            <div class="uploaded-inline">
                              <small class="uploaded-label">Vilivyopakiwa:</small>
                              <div class="d-flex flex-wrap gap-1 js-uploaded-files"></div>
                            </div>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
                <div class="workflow-action-grid">
                  <% workflowActionButtons.forEach((action) => { %>
                    <% if (shouldHideWorkflowAction(action)) return; %>
                    <% const isAssignAction = action === "Assign"; %>
                    <button
                      type="button"
                      class="btn btn-<%= actionTone(action) %> workflow-action-btn <%= isAssignAction ? 'workflow-assign-btn d-none' : 'workflow-non-assign-btn' %> <%= (alignReturnToPreviousStepRight ? action === 'Return' : action === 'Return_back') ? 'workflow-return-right' : '' %>"
                      data-workflow-action="<%= action %>"
                      data-needs-target="<%= actionNeedsTarget(action) ? '1' : '0' %>"
                    >
                      <%= actionLabel(action) %>
                    </button>
                  <% }) %>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>
<% } %>

<script>
  (function () {
    const tabStorageKey = `attend-active-tab:${window.location.pathname}`;
    const workflowForm = document.getElementById("workflow-action-form");
    const workflowActionInput = document.getElementById("workflow-action-input");
    const workflowTargetWrap = document.getElementById("workflow-target-wrap");
    const workflowTargetSelect = document.getElementById("workflow-target-staff");
    const workflowActionModal = document.getElementById("workflow-action-modal");
    const hasAssignStaffPermission = <%= (canTakeActionNow && hasAssignStaffPermission) ? "true" : "false" %>;
    const workflowAssignButtons = Array.from(document.querySelectorAll(".workflow-assign-btn"));
    const workflowNonAssignButtons = Array.from(document.querySelectorAll(".workflow-non-assign-btn"));
    const workflowCommentEditorElement = document.getElementById("workflow-comment-editor");
    const workflowCommentContentInput = document.getElementById("workflow-comment-content");
    const workflowRichEditorWrap = document.getElementById("workflow-rich-editor-wrap");
    const workflowAttachmentInputs = Array.from(document.querySelectorAll(".js-workflow-attachment-input"));
    const workflowAttachmentPayloadInput = document.getElementById("workflow-attachments-payload");
    const workflowTrackCollapse = document.getElementById("workflow-track-collapse");
    const workflowTrackToggleLabel = document.getElementById("toggle-workflow-steps-label");
    const workflowTrackToggleIcon = document.getElementById("toggle-workflow-steps-icon");
    const attendTrackingNumber = "<%= encodeURIComponent(String(app.tracking_number || '')) %>";
    const attendApplicationId = "<%= String(app.id || app.tracking_number || '') %>";
    let workflowCommentEditorInstance = null;

    const toPlainText = (html) => String(html || "")
      .replace(/<[^>]+>/g, " ")
      .replace(/&nbsp;/gi, " ")
      .replace(/\s+/g, " ")
      .trim();

    const currentWorkflowCommentContent = () => {
      if (workflowCommentEditorInstance) return workflowCommentEditorInstance.getData();
      return workflowCommentContentInput?.value || "";
    };

    const syncWorkflowCommentContent = () => {
      if (!workflowCommentContentInput) return;
      workflowCommentContentInput.value = currentWorkflowCommentContent();
    };

    const clearWorkflowCommentValidation = () => {
      workflowCommentContentInput?.classList.remove("is-invalid");
      workflowRichEditorWrap?.classList.remove("is-invalid");
    };

    const showWorkflowValidationAlert = (message) => {
      const msg = String(message || "").trim();
      if (!msg) return;

      if (window.Swal && typeof window.Swal.fire === "function") {
        window.Swal.fire({
          title: "Tahadhari",
          text: msg,
          icon: "warning",
          confirmButtonText: "Sawa",
          confirmButtonClass: "btn btn-primary w-xs",
          buttonsStyling: false,
        });
        return;
      }

      if (typeof alertMessage === "function") {
        alertMessage("Tahadhari", msg, "warning", () => {});
        return;
      }

      window.alert(msg);
    };

    const showWorkflowCommentRequiredAlert = () => {
      showWorkflowValidationAlert("Tafadhali andika maoni kwanza.");
    };

    const showWorkflowTargetRequiredAlert = () => {
      showWorkflowValidationAlert("Tafadhali chagua Afisa wa kumpelekea.");
    };

    const showWorkflowAttachmentValidationAlert = (message) => {
      showWorkflowValidationAlert(message || "Tafadhali hakiki viambatisho vyako.");
    };

    const markWorkflowCommentInvalid = () => {
      workflowCommentContentInput?.classList.add("is-invalid");
      workflowRichEditorWrap?.classList.add("is-invalid");
      if (workflowCommentEditorInstance) {
        workflowCommentEditorInstance.editing.view.focus();
      } else {
        workflowCommentContentInput?.focus();
      }
    };

    const fileToDataUrl = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ""));
        reader.onerror = () => reject(new Error("Failed to read file"));
        reader.readAsDataURL(file);
      });

    const normalizeAllowedExtensions = (value) =>
      String(value || "")
        .split(",")
        .map((part) => part.trim().replace(/^\./, "").toLowerCase())
        .filter(Boolean);

    const setAttachmentInputState = (input, stateText, tone = "muted", disabled = false) => {
      const card = input?.closest(".border.rounded");
      const statusEl = card ? card.querySelector(".js-upload-status") : null;
      if (statusEl) {
        statusEl.className = `d-block mt-1 js-upload-status text-${tone}`;
        statusEl.textContent = stateText || "";
      }
      if (input) input.disabled = Boolean(disabled);
    };

    const syncAttachmentUploadedStatusBadge = (input, isUploaded) => {
      const row = input?.closest(".attachment-row");
      const badge = row ? row.querySelector(".attachment-status-badge") : null;
      if (!badge) return;
      badge.textContent = isUploaded ? "Imepakiwa" : "Haijapakiwa";
      badge.classList.toggle("is-uploaded", Boolean(isUploaded));
      badge.classList.toggle("is-pending", !isUploaded);
    };

    const isImageExt = (ext) => ["jpg", "jpeg", "png", "gif", "webp", "bmp"].includes(String(ext || "").toLowerCase());

    const buildReadableUploadedLabel = (attachmentTypeName, fileName, index = 1) => {
      const typeLabel = String(attachmentTypeName || "Attachment").trim() || "Attachment";
      const cleanName = String(fileName || "").trim();
      const ext = cleanName.includes(".")
        ? cleanName.split(".").pop().toLowerCase()
        : "pdf";
      const suffix = Number(index || 1) > 1 ? ` (${Number(index)})` : "";
      return `${typeLabel}${suffix}.${ext}`;
    };

    const appendUploadedFilePreview = (input, fileName, fileDataUrl = "") => {
      const card = input?.closest(".border.rounded");
      const list = card ? card.querySelector(".js-uploaded-files") : null;
      if (!list) return;

      const attachmentTypeName = String(input?.dataset?.attachmentTypeName || "Attachment").trim();
      const existingCount = list.querySelectorAll(".uploaded-chip").length;
      const safeName = buildReadableUploadedLabel(attachmentTypeName, fileName, existingCount + 1);
      const ext = safeName.includes(".") ? safeName.split(".").pop().toLowerCase() : "";

      list.innerHTML = "";

      if (fileDataUrl && (ext === "pdf" || isImageExt(ext))) {
        const link = document.createElement("a");
        link.href = "#";
        link.className = "uploaded-chip js-open-attachment-modal text-decoration-none";
        link.setAttribute("data-file-url", fileDataUrl);
        link.setAttribute("data-file-name", safeName);
        link.innerHTML = `<i class="ri-file-list-3-line"></i> ${safeName}`;
        list.appendChild(link);
        syncAttachmentUploadedStatusBadge(input, true);
        return;
      }

      const chip = document.createElement("span");
      chip.className = "uploaded-chip";
      chip.innerHTML = `<i class="ri-file-line"></i> ${safeName}`;
      list.appendChild(chip);
      syncAttachmentUploadedStatusBadge(input, true);
    };

    const setUploadButtonState = (input, loading = false) => {
      const row = input?.closest(".attachment-row");
      const button = row ? row.querySelector(".btn-upload") : null;
      if (!button) return;
      button.disabled = loading || !input?.files?.length;
      if (loading) {
        if (!button.dataset.originalLabel) button.dataset.originalLabel = button.textContent || "Pandisha File";
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Inapakia...';
      } else if (button.dataset.originalLabel) {
        button.textContent = button.dataset.originalLabel;
      } else {
        button.textContent = "Pandisha File";
      }
    };

    const syncUploadButtonFromInput = (input) => {
      if (!input) return;
      const file = input.files && input.files[0] ? input.files[0] : null;
      const row = input.closest(".attachment-row");
      const button = row ? row.querySelector(".btn-upload") : null;
      input.classList.remove("is-invalid");
      if (button) button.disabled = !file;
      setAttachmentInputState(input, "", "muted", false);
      console.log("File selected:", file);
    };

    const bindNativeAttachmentInputEvents = () => {
      const inputs = Array.from(document.querySelectorAll(".comment-attachment-input"));
      inputs.forEach((input) => {
        if (input.dataset.boundUploadChange === "1") return;
        input.dataset.boundUploadChange = "1";
        input.addEventListener("change", () => syncUploadButtonFromInput(input));
        input.addEventListener("input", () => syncUploadButtonFromInput(input));
      });
    };

    const bindNativeUploadButtonEvents = () => {
      const buttons = Array.from(document.querySelectorAll(".btn-upload-attachment"));
      buttons.forEach((button) => {
        if (button.dataset.boundUploadClick === "1") return;
        button.dataset.boundUploadClick = "1";
        button.addEventListener("click", (event) => {
          event.preventDefault();
          console.log("Pandisha File clicked (native)");
          const row = button.closest(".attachment-row");
          const input = row ? row.querySelector(".comment-attachment-input") : null;
          if (!input) return;
          uploadCommentAttachment(input);
        });
      });
    };

    const uploadCommentAttachment = async (input) => {
      if (!input) return;
      if (input.dataset.uploading === "1") return;
      console.log("Pandisha File clicked");
      const file = input.files && input.files[0] ? input.files[0] : null;
      console.log("Selected file:", file);
      const row = input.closest(".attachment-row");
      const attachmentTypeId = Number(
        input.dataset.attachmentTypeId
        || 0,
      );
      const trackingNumber = String(
        input.dataset.trackingNumber
        || ""
      ).trim();
      const applicationId = String(
        input.dataset.applicationId
        || ""
      ).trim();
      const fallbackTrackingNumber = String(
        row?.dataset?.trackingNumber
        || decodeURIComponent(attendTrackingNumber)
        || "",
      ).trim();
      const fallbackApplicationId = String(row?.dataset?.applicationId || attendApplicationId || "").trim();
      const resolvedTrackingNumber = trackingNumber || fallbackTrackingNumber;
      const resolvedApplicationId = applicationId || fallbackApplicationId;
      const attachmentTypeName = String(input.dataset.attachmentTypeName || "Attachment").trim();
      const maxSizeMb = Number(input.dataset.maxSizeMb || 0);
      const maxBytes = maxSizeMb > 0 ? maxSizeMb * 1024 * 1024 : 0;
      const allowedExt = normalizeAllowedExtensions(input.dataset.allowedExt || "");

      input.classList.remove("is-invalid");
      if (!file) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, "Tafadhali chagua file kwanza.", "danger");
        return;
      }
      if (!resolvedApplicationId || !resolvedTrackingNumber || !attachmentTypeId) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, "Application/attachment type haijakamilika.", "danger");
        return;
      }

      const ext = String(file.name || "").split(".").pop().toLowerCase();
      if (allowedExt.length && !allowedExt.includes(ext)) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, `${attachmentTypeName}: format hairuhusiwi.`, "danger");
        return;
      }
      if (maxBytes > 0 && Number(file.size || 0) > maxBytes) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, `${attachmentTypeName}: Ukubwa wa faili umezidi kiwango cha ${maxSizeMb} MB.`, "danger");
        return;
      }

      let dataUrl = "";
      try {
        dataUrl = await fileToDataUrl(file);
      } catch (error) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, `${attachmentTypeName}: imeshindikana kusoma faili.`, "danger");
        return;
      }

      if (!dataUrl.startsWith("data:")) {
        input.classList.add("is-invalid");
        setAttachmentInputState(input, `${attachmentTypeName}: faili si sahihi.`, "danger");
        return;
      }

      setAttachmentInputState(input, "Inapakia...", "primary", true);
      setUploadButtonState(input, true);
      input.dataset.uploading = "1";

      if (typeof window.jQuery === "undefined") {
        setAttachmentInputState(input, "Error: jQuery haijapatikana.", "danger", false);
        return;
      }

      const formData = new FormData();
      formData.append("trackerId", resolvedTrackingNumber);
      formData.append("tracking_number", resolvedTrackingNumber);
      formData.append("application_id", resolvedApplicationId);
      formData.append("attachment", String(attachmentTypeId));
      formData.append("attachment_type_id", String(attachmentTypeId));
      formData.append("file", file);
      formData.append("kiambatisho_data_url", dataUrl);
      formData.append("file_name", String(file.name || ""));
      for (const pair of formData.entries()) {
        console.log(pair[0], pair[1]);
      }
      console.log("Payload:", {
        trackerId: resolvedTrackingNumber,
        tracking_number: resolvedTrackingNumber,
        application_id: resolvedApplicationId,
        attachment_type_id: attachmentTypeId,
        file_name: String(file.name || ""),
        byte_size: Number(file.size || 0),
      });

      window.jQuery.ajax({
        url: "/TumaAttachment",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        xhr: function () {
          const xhr = new window.XMLHttpRequest();
          xhr.upload.addEventListener("progress", function (e) {
            if (e.lengthComputable) {
              const percent = Math.round((e.loaded / e.total) * 100);
              setAttachmentInputState(input, `Inapakia... ${percent}%`, "primary", true);
            }
          });
          return xhr;
        },
      })
        .done((response) => {
          const ok = Boolean(response?.success) || Number(response?.statusCode) === 300;
          if (!ok) {
            input.classList.add("is-invalid");
            setAttachmentInputState(
              input,
              String(response?.message || "Imeshindikana kupakia. Jaribu tena."),
              "danger",
              false,
            );
            return;
          }

          setAttachmentInputState(input, "File imepandishwa kikamilifu.", "success", false);
          appendUploadedFilePreview(input, file.name, dataUrl);
        })
        .fail((xhr) => {
          const message =
            String(xhr?.responseJSON?.message || "").trim()
            || String(xhr?.responseText || "").trim()
            || "Imeshindikana kupakia faili. Tafadhali jaribu tena.";
          input.classList.add("is-invalid");
          setAttachmentInputState(input, message, "danger", false);
        })
        .always(() => {
          input.dataset.uploading = "0";
          input.disabled = false;
          input.value = "";
          const row = input?.closest(".attachment-row");
          const button = row ? row.querySelector(".btn-upload") : null;
          if (button) button.disabled = true;
          setUploadButtonState(input, false);
        });
    };

    const initWorkflowCommentEditor = () => {
      if (!workflowCommentEditorElement) return;
      if (workflowCommentEditorInstance) return;
      if (typeof window.ClassicEditor === "undefined") return;

      window.ClassicEditor.create(workflowCommentEditorElement, {
        placeholder: "Andika maoni hapa...",
      })
        .then((editor) => {
          workflowCommentEditorInstance = editor;
          editor.ui.view.editable.element.style.minHeight = "200px";
          syncWorkflowCommentContent();
          clearWorkflowCommentValidation();
          editor.model.document.on("change:data", () => {
            syncWorkflowCommentContent();
            if (toPlainText(editor.getData())) {
              clearWorkflowCommentValidation();
            }
          });
        })
        .catch((error) => {
          console.error(error);
          if (workflowCommentContentInput) {
            workflowCommentContentInput.classList.remove("d-none");
          }
        });
    };

    const initWorkflowTargetSearch = () => {
      if (!workflowTargetSelect || workflowTargetSelect.disabled) return;
      if (typeof window.jQuery === "undefined") return;
      if (typeof window.jQuery.fn.select2 !== "function") return;

      const $target = window.jQuery(workflowTargetSelect);
      if ($target.data("select2")) {
        $target.select2("destroy");
      }

      $target.select2({
        width: "100%",
        placeholder: "Chagua Afisa",
        allowClear: true,
        minimumResultsForSearch: 0,
        dropdownParent: workflowActionModal ? window.jQuery(workflowActionModal) : window.jQuery("body"),
        matcher: (params, data) => {
          const term = String(params?.term || "").trim().toLowerCase();
          if (!term) return data;
          const haystack = String(data?.text || "")
            .replace(/\s+/g, " ")
            .trim()
            .toLowerCase();
          return haystack.includes(term) ? data : null;
        },
      });

      // Select2 can emit jQuery events without always triggering native listeners reliably.
      $target.off(".workflowAssignVisibility");
      $target.on("change.workflowAssignVisibility", () => {
        syncAssignButtonVisibility();
      });
      $target.on("select2:select.workflowAssignVisibility", () => {
        syncAssignButtonVisibility();
      });
      $target.on("select2:clear.workflowAssignVisibility", () => {
        syncAssignButtonVisibility();
      });
    };

    const syncAssignButtonVisibility = () => {
      if (!hasAssignStaffPermission) {
        workflowAssignButtons.forEach((button) => {
          button.classList.add("d-none");
        });
        workflowNonAssignButtons.forEach((button) => {
          button.classList.remove("d-none");
        });
        return;
      }

      const hasTargetStaff = Boolean(workflowTargetSelect && workflowTargetSelect.value);
      workflowAssignButtons.forEach((button) => {
        button.classList.toggle("d-none", !hasTargetStaff);
      });
      workflowNonAssignButtons.forEach((button) => {
        button.classList.toggle("d-none", hasTargetStaff);
      });
    };

    const syncWorkflowTrackToggleLabel = () => {
      if (!workflowTrackCollapse || !workflowTrackToggleLabel) return;
      const isExpanded = workflowTrackCollapse.classList.contains("show");
      workflowTrackToggleLabel.textContent = isExpanded ? "Ficha Workflow" : "Onesha Workflow";
      if (workflowTrackToggleIcon) {
        workflowTrackToggleIcon.classList.toggle("ri-eye-line", isExpanded);
        workflowTrackToggleIcon.classList.toggle("ri-eye-off-line", !isExpanded);
      }
    };

    const activateAttendTab = (tabId) => {
      if (!tabId || !window.bootstrap || !window.bootstrap.Tab) return;

      const tabTrigger = document.querySelector(`.attend-tabs [data-bs-toggle="tab"][href="${tabId}"]`);
      if (!tabTrigger) return;

      window.bootstrap.Tab.getOrCreateInstance(tabTrigger).show();
    };

    const resolveInitialTab = () => {
      const currentHash = window.location.hash;
      if (currentHash && document.querySelector(`.tab-content ${currentHash}`)) {
        return currentHash;
      }

      const savedTab = window.localStorage.getItem(tabStorageKey);
      if (savedTab && document.querySelector(`.tab-content ${savedTab}`)) {
        return savedTab;
      }

      return null;
    };

    const applyEllipsisTooltips = () => {
      const nodes = document.querySelectorAll(".ellipsis-tooltip");
      nodes.forEach((node) => {
        const existingToggle = node.getAttribute("data-bs-toggle");
        const isTabLink =
          node.classList.contains("nav-link") ||
          node.getAttribute("role") === "tab" ||
          existingToggle === "tab";
        if (isTabLink) return;

        const text = (node.textContent || "").trim();
        const alwaysTooltip = node.classList.contains("always-tooltip");
        const isTruncated = node.scrollWidth > node.clientWidth;

        if ((alwaysTooltip || isTruncated) && text) {
          if (!node.getAttribute("title")) {
            node.setAttribute("title", text);
          }
          node.setAttribute("data-bs-toggle", "tooltip");
          node.setAttribute("data-bs-placement", "top");
          if (window.bootstrap && window.bootstrap.Tooltip) {
            if (!window.bootstrap.Tooltip.getInstance(node)) {
              new window.bootstrap.Tooltip(node);
            }
          }
        } else {
          if (window.bootstrap && window.bootstrap.Tooltip) {
            const tooltip = window.bootstrap.Tooltip.getInstance(node);
            if (tooltip) tooltip.dispose();
          }
          if (!alwaysTooltip) {
            node.removeAttribute("title");
          }
          if (node.getAttribute("data-bs-toggle") === "tooltip") {
            node.removeAttribute("data-bs-toggle");
          }
          node.removeAttribute("data-bs-placement");
        }
      });
    };

    if (workflowForm && workflowActionInput) {
      const hasSweetAlert = () => Boolean(window.Swal && typeof window.Swal.fire === "function");
      const workflowActionElements = Array.from(document.querySelectorAll("[data-workflow-action]"));
      let workflowSubmitInProgress = false;
      const workflowActionTone = (action) => {
        if (action === "Review") return "primary";
        if (action === "Assign") return "info";
        if (action === "Forward") return "success";
        if (action === "Approve") return "success";
        if (action === "Reject") return "danger";
        if (action === "Return") return "warning";
        if (action === "Return_back") return "warning";
        return "secondary";
      };

      const buildWorkflowActionConfirmation = (action, needsTarget) => {
        const actionLabel = String(action || "").trim();
        const selectedText = String(
          workflowTargetSelect?.options?.[workflowTargetSelect.selectedIndex]?.text || ""
        ).trim();

        if ((actionLabel === "Assign" || needsTarget) && selectedText) {
          return `Una uhakika ungependa kutuma ombi hili kwenda kwa ${selectedText}? Bonyeza Ndio, Kuendelea au Hapana kurudi.`;
        }

        return `Una uhakika ungependa kuendelea na kitendo hiki? Bonyeza Ndio, Kuendelea au Hapana kurudi.`;
      };

      const confirmWorkflowAction = async (action, needsTarget) => {
        const message = buildWorkflowActionConfirmation(action, needsTarget);
        if (!hasSweetAlert()) {
          return window.confirm(message);
        }

        const tone = workflowActionTone(action);

        const result = await window.Swal.fire({
          title: "Thibitisha Kitendo",
          text: message,
          icon: "question",
          showCancelButton: true,
          confirmButtonText: "Ndio, Endelea",
          cancelButtonText: "Hapana",
          confirmButtonClass: `btn btn-${tone} w-xs me-2`,
          cancelButtonClass: "btn btn-light w-xs",
          buttonsStyling: false,
        });

        return Boolean(result?.isConfirmed);
      };

      const setWorkflowSubmittingState = (isSubmitting, activeButton = null) => {
        workflowActionElements.forEach((button) => {
          button.disabled = isSubmitting;
          button.classList.toggle("disabled", isSubmitting);
        });

        if (activeButton && isSubmitting) {
          if (!activeButton.dataset.originalHtml) {
            activeButton.dataset.originalHtml = activeButton.innerHTML;
          }
          activeButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Inatuma...';
        }

        if (!isSubmitting) {
          workflowActionElements.forEach((button) => {
            if (button.dataset.originalHtml) {
              button.innerHTML = button.dataset.originalHtml;
              delete button.dataset.originalHtml;
            }
          });
        }
      };

      const showSubmittingAlert = (action) => {
        if (!hasSweetAlert()) return;
        window.Swal.fire({
          title: "Inatuma...",
          text: `Kitendo (${String(action || "").trim()}) kinaendelea. Tafadhali subiri.`,
          icon: "info",
          allowOutsideClick: false,
          allowEscapeKey: false,
          showConfirmButton: false,
          didOpen: () => {
            window.Swal.showLoading();
          },
        });
      };

      workflowActionElements.forEach((button) => {
        button.addEventListener("click", async () => {
          if (workflowSubmitInProgress) return;

          const action = button.getAttribute("data-workflow-action") || "";
          const needsTarget = button.getAttribute("data-needs-target") === "1";

          workflowActionInput.value = action;
          syncWorkflowCommentContent();

          if (needsTarget && (!workflowTargetSelect || !workflowTargetSelect.value)) {
            if (workflowTargetSelect) {
              workflowTargetSelect.classList.add("is-invalid");
              workflowTargetSelect.focus();
            }
            showWorkflowTargetRequiredAlert();
            return;
          }

          if (!toPlainText(currentWorkflowCommentContent())) {
            markWorkflowCommentInvalid();
            showWorkflowCommentRequiredAlert();
            return;
          }

          if (workflowAttachmentPayloadInput) {
            workflowAttachmentPayloadInput.value = "[]";
          }

          const confirmed = await confirmWorkflowAction(action, needsTarget);
          if (!confirmed) {
            return;
          }

          workflowSubmitInProgress = true;
          setWorkflowSubmittingState(true, button);
          showSubmittingAlert(action);
          workflowForm.submit();
        });
      });

      if (workflowTargetSelect) {
        workflowTargetSelect.addEventListener("change", () => {
          if (workflowTargetWrap?.classList.contains("is-visible")) {
            workflowTargetSelect.classList.remove("is-invalid");
          }
          syncAssignButtonVisibility();
        });
      }

      if (workflowCommentContentInput) {
        workflowCommentContentInput.addEventListener("input", () => {
          if (toPlainText(workflowCommentContentInput.value)) {
            clearWorkflowCommentValidation();
          }
        });
      }
    }

    if (workflowActionModal) {
      workflowActionModal.addEventListener("shown.bs.modal", () => {
        initWorkflowTargetSearch();
        initWorkflowCommentEditor();
        syncAssignButtonVisibility();
        bindNativeAttachmentInputEvents();
        bindNativeUploadButtonEvents();
        setTimeout(syncAssignButtonVisibility, 0);
      });
    }

    if (typeof window.jQuery !== "undefined") {
      window.jQuery(document).on("change", ".comment-attachment-input", function () {
        syncUploadButtonFromInput(this);
      });

      window.jQuery(document).on("click", ".btn-upload-attachment", function (e) {
        e.preventDefault();
        console.log("Pandisha File clicked (jQuery)");
        const button = this;
        const row = button?.closest(".attachment-row");
        const input = row ? row.querySelector(".comment-attachment-input") : null;
        if (!input) return;
        uploadCommentAttachment(input);
      });
    }

    if (workflowTrackCollapse) {
      workflowTrackCollapse.addEventListener("shown.bs.collapse", syncWorkflowTrackToggleLabel);
      workflowTrackCollapse.addEventListener("hidden.bs.collapse", syncWorkflowTrackToggleLabel);
    }

    window.addEventListener("load", () => {
      activateAttendTab(resolveInitialTab());
      applyEllipsisTooltips();
      initWorkflowCommentEditor();
      syncAssignButtonVisibility();
      bindNativeAttachmentInputEvents();
      bindNativeUploadButtonEvents();
      syncWorkflowTrackToggleLabel();
    });
    window.addEventListener("resize", applyEllipsisTooltips);
    document.addEventListener("shown.bs.tab", (event) => {
      const activeTabId = event.target?.getAttribute("href");
      if (activeTabId && activeTabId.startsWith("#")) {
        window.localStorage.setItem(tabStorageKey, activeTabId);
        if (window.location.hash !== activeTabId) {
          window.history.replaceState(null, "", activeTabId);
        }
      }
      applyEllipsisTooltips();
    });
  })();
</script>
<script>
  (function () {
    const modalElement = document.getElementById("attachment-preview-modal");
    const workflowModalElement = document.getElementById("workflow-action-modal");
    const titleEl = document.getElementById("attachment-preview-title");
    const bodyEl = document.getElementById("attachment-preview-body");
    if (!modalElement || !titleEl || !bodyEl) return;
    const imageExts = ["jpg", "jpeg", "png", "gif", "webp", "bmp", "svg"];

    const escapeHtml = (text) =>
      String(text || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const getExt = (filename) => {
      const clean = String(filename || "").split("?")[0].toLowerCase();
      const parts = clean.split(".");
      return parts.length > 1 ? parts.pop() : "";
    };

    const openAttachmentPreview = (url, filename) => {
      const safeUrl = String(url || "").trim();
      const safeName = String(filename || "Attachment").trim() || "Attachment";
      const ext = getExt(safeName);

      titleEl.textContent = safeName;

      if (ext === "pdf") {
        bodyEl.innerHTML =
          '<iframe src="' + escapeHtml(safeUrl) + '" title="PDF Preview" style="width:100%;height:70vh;border:0;"></iframe>';
      } else if (imageExts.includes(ext)) {
        bodyEl.innerHTML =
          '<div class="text-center"><img src="' + escapeHtml(safeUrl) + '" alt="' + escapeHtml(safeName) + '" class="img-fluid rounded" style="max-height:70vh;"></div>';
      } else {
        bodyEl.innerHTML =
          '<div class="alert alert-info mb-3">Preview haipatikani kwa aina hii ya faili.</div>' +
          '<div class="mb-2"><strong>File:</strong> ' + escapeHtml(safeName) + "</div>" +
          '<a class="btn btn-primary" href="' + escapeHtml(safeUrl) + '" download="' + escapeHtml(safeName) + '">Pakua Faili</a>';
      }

      if (window.bootstrap && typeof window.bootstrap.Modal === "function") {
        const modal = window.bootstrap.Modal.getOrCreateInstance(modalElement);
        document.body.classList.add("preview-modal-open");
        modal.show();
        return;
      }

      if (window.jQuery && typeof window.jQuery.fn.modal === "function") {
        window.jQuery(modalElement).modal("show");
      }
    };

    document.addEventListener("click", (event) => {
      const trigger = event.target.closest(".js-open-attachment-modal");
      if (!trigger) return;
      event.preventDefault();
      console.log("Attachment clicked");
      console.log("Attachment request path:", trigger.getAttribute("data-file-url"));
      openAttachmentPreview(
        trigger.getAttribute("data-file-url") || trigger.getAttribute("data-url"),
        trigger.getAttribute("data-file-name") || trigger.getAttribute("data-name")
      );
    });

    modalElement.addEventListener("shown.bs.modal", () => {
      document.body.classList.add("preview-modal-open");
      const backdrops = document.querySelectorAll(".modal-backdrop");
      if (backdrops.length) {
        backdrops[backdrops.length - 1].classList.add("attachment-preview-backdrop");
      }
    });

    modalElement.addEventListener("hidden.bs.modal", () => {
      document.body.classList.remove("preview-modal-open");
      bodyEl.innerHTML = "";
      if (workflowModalElement && workflowModalElement.classList.contains("show")) {
        workflowModalElement.focus();
      }
    });
  })();
</script>

