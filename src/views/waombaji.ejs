<% var card_title = 'Waombaji waliopo' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Waombaji',
    page_title : 'Orodha ya Waombaji',
    card_title : card_title,
    breadcrumb_main : 'Mipangilio',
     styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]

}) %>
<style>
    #datatable.table-readable th,
    #datatable.table-readable td {
        font-size: 0.95rem;
        vertical-align: middle;
    }

    #datatable .applicant-name {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 220px;
    }

    #datatable .applicant-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #405189;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        flex: 0 0 34px;
    }

    #datatable .action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        padding: 0;
    }

    .applicants-summary .card {
        border: 1px solid rgba(17, 24, 39, 0.08);
    }
</style>
<div class="card-body">
<div id="applicantsList">
    <div class="row g-3 mb-4 applicants-summary">
        <div class="col-md-4">
            <div class="card mb-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Jumla ya Waombaji</p>
                    <h3 class="mb-0" id="applicants-total-count">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Zinazoonekana</p>
                    <h3 class="mb-0 text-primary" id="applicants-page-count">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Maombi (Ukurasa)</p>
                    <h3 class="mb-0 text-success" id="applicants-apps-count">0</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="table-responsive mt-3 mb-1">
        <table class="table table-hover align-middle table-nowrap table-striped table-readable" id="datatable" style="width: 100%">
            <thead class="table-light">
                <tr>
                    <th>Na.</th>
                    <th>Mwombaji</th>
                    <th>Barua Pepe</th>
                    <th>Imetengenezwa</th>
                    <th>Imesasishwa</th>
                    <th>Jumla ya Maombi</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody class="list form-check-all">
            </tbody>
        </table>
        <div class="noresult" style="display: none">
            <div class="text-center">
                <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                <h5 class="mt-2">Sorry! No Result Found</h5>
                <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
            </div>
        </div>
    </div>
    </div>

</div>
</div><!-- end card -->
<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/waombaji_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    $(document).ready(function() {
        tableData('datatable' , '/ApplicantList' , 'POST',
            [
                    { data: null, render : (data , type , row , meta) => {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    } },
                    {
                        data: "name",
                        name: "name",
                        render: (data) => {
                            const name = String(data || '').trim();
                            const initials = name
                                .split(' ')
                                .filter(Boolean)
                                .slice(0, 2)
                                .map((part) => part[0])
                                .join('') || 'A';
                            return `<div class="applicant-name"><span class="applicant-avatar">${initials}</span><span class="fw-semibold">${name || '-'}</span></div>`;
                        }
                    },
                    { data: "email", name: "email", render: (data) => data ? `<span class="text-muted">${data}</span>` : '-' },
                    {data: 'created_at' , name: 'created_at' , render: (data , type , row) => {
                        return data ? `<span class="text-muted">${changeDateFormat(data)}</span>` : '-'
                    }},
                    {data: 'updated_at' , name: 'updated_at' , render: (data , type , row) => {
                        return data ? `<span class="text-muted">${changeDateFormat(data)}</span>` : '-'
                    }},
                    { data: "total_applications", name: "total_applications" ,  render: (data , type , row) => {
                        const total = Number(data || 0);
                        return `<span class="badge bg-${ total > 0 ? 'success' : 'warning'}-subtle text-${ total > 0 ? 'success' : 'warning'}">${total}</span>`
                        },
                    class : 'text-center'
                    },
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                          const elements = [
                                            {
                                                show : true,
                                                type : 'link',
                                                link : `/Mwombaji/${row.id}`,
                                                class : 'btn btn-soft-primary action-btn me-1',
                                                icon : 'ri-eye-line',
                                                function : '',
                                                btnText : '',
                                                moreAttributes : "title='Fungua' data-bs-toggle='tooltip'"
                                            }
                                        ]
                        return actionButtons(row , elements);
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    class : 'text-center'
                    },
            ],
        );

        const applicantsTable = $('#datatable').DataTable();
        applicantsTable.on('xhr.dt', function (e, settings, json) {
            const total = Number((json && json.recordsTotal) || 0);
            const rows = json && Array.isArray(json.data) ? json.data : [];
            const shown = rows.length;
            const pageApplications = rows.reduce((sum, item) => {
                return sum + Number(item && item.total_applications ? item.total_applications : 0);
            }, 0);

            $('#applicants-total-count').text(total.toLocaleString());
            $('#applicants-page-count').text(shown.toLocaleString());
            $('#applicants-apps-count').text(pageApplications.toLocaleString());
        });
    });
</script>
<!-- <script type="text/javascript" src="design/layouts/scripts/waombaji_scripts.js"></script> -->
</body>
</html>
