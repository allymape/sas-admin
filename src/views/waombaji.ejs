<% var card_title = 'Waombaji waliopo' %> 
<%- include('layouts/partials/header.ejs' , {
    title : 'Waombaji',
    page_title : 'Orodha ya Waombaji',
    card_title : card_title,
    breadcrumb_main : 'Mipangilio',
     styles : [
                { href: '/css/datatables/dataTables.dataTables.css' },
                { href: '/css/datatables/buttons.dataTables.css' }
            ]

}) %>
<style>
    #datatable {
        table-layout: fixed;
        width: 100% !important;
    }

    #datatable th,
    #datatable td {
        white-space: normal;
        word-break: break-word;
    }

    #datatable th:first-child,
    #datatable td:first-child {
        width: 56px;
    }

    #datatable th:last-child,
    #datatable td:last-child {
        width: 110px;
    }

    #datatable.table-readable th,
    #datatable.table-readable td {
        font-size: 0.95rem;
        vertical-align: middle;
    }

    #datatable .applicant-name {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
    }

    #datatable .applicant-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #405189;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        flex: 0 0 34px;
    }

    #datatable .action-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        padding: 0;
    }

    .applicants-summary .card {
        border: 1px solid rgba(17, 24, 39, 0.08);
    }
</style>
<div class="card-body">
<div id="applicantsList">
    <div class="row g-3 mb-3" id="registry-type-summary-cards">
        <div class="col-md-3">
            <div class="card mb-0 border border-primary-subtle">
                <div class="card-body">
                    <p class="text-muted mb-1">Mtu Binafsi</p>
                    <h4 class="mb-0 text-primary" id="registry-type-personal">0</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card mb-0 border border-success-subtle">
                <div class="card-body">
                    <p class="text-muted mb-1">Serikali/Halmashauri</p>
                    <h4 class="mb-0 text-success" id="registry-type-government">0</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card mb-0 border border-info-subtle">
                <div class="card-body">
                    <p class="text-muted mb-1">Taasisi/Kampuni/NGO</p>
                    <h4 class="mb-0 text-info" id="registry-type-institution">0</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card mb-0 border border-warning-subtle">
                <div class="card-body">
                    <p class="text-muted mb-1">Haijajaza Taarifa</p>
                    <h4 class="mb-0 text-warning" id="registry-type-unknown">0</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="table-responsive mt-3 mb-1">
        <table class="table table-hover align-middle table-striped table-readable" id="datatable" style="width: 100%">
            <thead class="table-light">
                <tr>
                    <th>Na.</th>
                    <th>Mwombaji</th>
                    <th>Barua Pepe</th>
                    <th>Imetengenezwa</th>
                    <th>Imesasishwa</th>
                    <th>Aina ya Usajili</th>
                    <th>Jumla ya Maombi</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody class="list form-check-all">
            </tbody>
        </table>
        <div class="noresult" style="display: none">
            <div class="text-center">
                <lord-icon src="https://cdn.lordicon.com/msoeawqm.json" trigger="loop" colors="primary:#121331,secondary:#08a88a" style="width:75px;height:75px"></lord-icon>
                <h5 class="mt-2">Sorry! No Result Found</h5>
                <p class="text-muted mb-0">We've searched more than 150+ Orders We did not find any orders for you search.</p>
            </div>
        </div>
    </div>
    </div>

</div>
</div><!-- end card -->
<%- include('layouts/partials/footer.ejs' , {
    card_title :  card_title,
    scripts : [
            {src : '/design/layouts/scripts/waombaji_scripts.js'},
            { src : '/js/datatables/dataTables.js'},
            { src : '/js/datatables/dataTables.buttons.js'},
            { src : '/js/datatables/buttons.dataTables.js'},
            { src : '/js/datatables/buttons.html5.min.js'},
            { src : '/js/datatables/jszip.min.js'},
            { src : '/js/datatables/pdfmake.min.js'},
            { src : '/js/datatables/vfs_fonts.js'},
            { src : '/js/datatables/buttons.print.min.js'},
          ]
    }) %>
<script>
    $(document).ready(function() {
        tableData('datatable' , '/ApplicantList' , 'POST',
            [
                    { data: null, render : (data , type , row , meta) => {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    } },
                    {
                        data: "name",
                        name: "name",
                        render: (data) => {
                            const name = String(data || '').trim();
                            const initials = name
                                .split(' ')
                                .filter(Boolean)
                                .slice(0, 2)
                                .map((part) => part[0])
                                .join('') || 'A';
                            return `<div class="applicant-name"><span class="applicant-avatar">${initials}</span><span class="fw-semibold">${name || '-'}</span></div>`;
                        }
                    },
                    { data: "email", name: "email", render: (data) => data ? `<span class="text-muted">${data}</span>` : '-' },
                    {data: 'created_at' , name: 'created_at' , render: (data , type , row) => {
                        return data ? `<span class="text-muted">${changeDateFormat(data)}</span>` : '-'
                    }},
                    {data: 'updated_at' , name: 'updated_at' , render: (data , type , row) => {
                        return data ? `<span class="text-muted">${changeDateFormat(data)}</span>` : '-'
                    }},
                    { data: "registry_type", name: "registry_type", render: (data, type, row) => {
                        const raw = String(data || 'UNKNOWN').trim();
                        const upper = raw.toUpperCase();
                        const id = Number(row?.registry_type_id || 0);

                        const toTitleCase = (txt) => {
                            const rawTxt = String(txt || '').trim();
                            if (!rawTxt) return '';

                            const titleWord = (w) => (w ? w[0].toUpperCase() + w.slice(1).toLowerCase() : '');
                            const titleWords = (s) => String(s || '').split(' ').filter(Boolean).map(titleWord).join(' ');
                            return rawTxt
                                .split('/')
                                .map((part) => titleWords(part))
                                .join('/');
                        };

                        const formatLabel = () => {
                            if (upper === 'UNKNOWN') return 'Haijajaza';
                            if (upper === 'MIXED') return 'Mixed';
                            const titled = toTitleCase(raw);
                            return titled.replace(/\bNgo\b/g, 'NGO');
                        };

                        const label = formatLabel();
                        const variant = upper === 'UNKNOWN'
                          ? 'secondary'
                          : (upper === 'MIXED'
                            ? 'warning'
                            : (id === 1 ? 'primary' : (id === 2 ? 'success' : (id === 3 ? 'info' : 'secondary'))));

                        return `<span class="badge bg-${variant}-subtle text-${variant}">${label}</span>`;
                    }, class: 'text-center' },
                    { data: "total_applications", name: "total_applications" ,  render: (data , type , row) => {
                        const total = Number(data || 0);
                        return `<span class="badge bg-${ total > 0 ? 'success' : 'warning'}-subtle text-${ total > 0 ? 'success' : 'warning'}">${total}</span>`
                        },
                    class : 'text-center'
                    },
                    {
                    data: null, // No data source for this column
                    render: function (data, type, row) {
                          const elements = [
                                            {
                                                show : true,
                                                type : 'link',
                                                link : `/Mwombaji/${row.id}`,
                                                class : 'btn btn-soft-primary action-btn me-1',
                                                icon : 'ri-eye-line',
                                                function : '',
                                                btnText : '',
                                                moreAttributes : "title='Fungua' data-bs-toggle='tooltip'"
                                            }
                                        ]
                        return actionButtons(row , elements);
                    },
                    orderable: false, // Disable sorting for the action buttons column
                    class : 'text-center'
                    },
            ],
        );

        const applicantsTable = $('#datatable').DataTable();
        applicantsTable.on('xhr.dt', function (e, settings, json) {
            const rows = json && Array.isArray(json.data) ? json.data : [];
            const pageApplications = rows.reduce((sum, item) => {
                return sum + Number(item && item.total_applications ? item.total_applications : 0);
            }, 0);
        });

        const renderRegistrySummary = (summary = []) => {
            const items = Array.isArray(summary) ? summary : [];
            const getCount = (matchFn) => {
                const found = items.find((it) => matchFn(String(it?.registry_type || '').trim().toUpperCase()));
                return Number(found?.total || 0) || 0;
            };

            const personal = getCount((label) => label.includes('MTU BINAFSI') || label === 'PERSONAL');
            const government = getCount((label) => label.includes('SERIKALI') || label.includes('HALMASHAURI') || label === 'GOVERNMENT');
            const institution = getCount((label) => label.includes('TAASISI') || label.includes('KAMPUNI') || label.includes('NGO') || label === 'INSTITUTION');
            const unknown = getCount((label) => label === 'UNKNOWN');

            $('#registry-type-personal').text(personal.toLocaleString());
            $('#registry-type-government').text(government.toLocaleString());
            $('#registry-type-institution').text(institution.toLocaleString());
            $('#registry-type-unknown').text(unknown.toLocaleString());
        };

        let summaryTimer = null;
        const fetchRegistrySummary = () => {
            const searchValue = String(applicantsTable.search() || '').trim();
            $.ajax({
                url: '/ApplicantRegistryTypeSummary',
                type: 'GET',
                data: { search_value: searchValue },
                success: function (resp) {
                    renderRegistrySummary(resp && resp.data ? resp.data : []);
                },
                error: function () {
                    renderRegistrySummary([]);
                }
            });
        };

        // initial
        fetchRegistrySummary();

        // refresh on search changes (debounced)
        applicantsTable.on('search.dt', function () {
            clearTimeout(summaryTimer);
            summaryTimer = setTimeout(fetchRegistrySummary, 450);
        });
    });
</script>
<!-- <script type="text/javascript" src="design/layouts/scripts/waombaji_scripts.js"></script> -->
</body>
</html>
