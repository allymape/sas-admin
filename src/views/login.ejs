    <script src="/design/assets/libs/sweetalert2/sweetalert2.min.js"></script>
    <script>
      (function () {
        const form = document.getElementById("login-form");
        const submitBtn = document.getElementById("login-submit-btn");
        const submitLabel = submitBtn ? submitBtn.querySelector(".btn-label") : null;
        const hint = document.getElementById("login-loading-hint");
        const password = document.getElementById("password");
        const capsLockHint = document.getElementById("caps-lock-hint");
        const passwordInvalidFeedback = document.getElementById("password-invalid-feedback");

        const secondsCounter = document.getElementById("login-seconds-counter");
        if (!form || !submitBtn || !submitLabel || !hint || !secondsCounter || !password || !capsLockHint || !passwordInvalidFeedback) return;

        const togglePasswordError = function () {
          const hasPassword = Boolean((password.value || "").trim());
          passwordInvalidFeedback.classList.toggle("d-none", hasPassword);
        };

        password.addEventListener("input", togglePasswordError);
        password.addEventListener("keyup", function (event) {
          capsLockHint.classList.toggle("d-none", !event.getModifierState("CapsLock"));
        });
        password.addEventListener("keydown", function (event) {
          capsLockHint.classList.toggle("d-none", !event.getModifierState("CapsLock"));
        });

        form.addEventListener("submit", function () {
          togglePasswordError();
          if (!form.checkValidity()) {
            form.classList.add("was-validated");
            return;
          }

          let seconds = 0;
          let counterInterval = null;

          submitBtn.disabled = true;
          submitBtn.setAttribute("aria-busy", "true");
          submitLabel.innerHTML =
            '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Inaingia...';
          hint.classList.remove("d-none");
          secondsCounter.textContent = "0";

          counterInterval = setInterval(function () {
            seconds += 1;
            secondsCounter.textContent = String(seconds);
          }, 1000);

          // If request is still in-flight, keep user informed without fake retry prompt.
          setTimeout(function () {
            if (document.hidden) return;
            hint.textContent = "Bado inachakata taarifa zako... tafadhali subiri.";
          }, 8000);
        });
      })();
    </script>
    <script>
      (function () {
        const flashMessages = {
          error: <%- JSON.stringify(error || []) %>,
          warning: <%- JSON.stringify(warning || []) %>,
          success: <%- JSON.stringify(success || []) %>,
        };

        const showToast = function (type, messages) {
          if (!Array.isArray(messages) || messages.length === 0) return;
          const toastStyle = {
            error: { background: "#dc3545", color: "#ffffff" },
            warning: { background: "#f59f00", color: "#111111" },
            success: { background: "#198754", color: "#ffffff" },
          };

          messages.forEach(function (message) {
            if (!message) return;
            if (window.Swal) {
              const style = toastStyle[type] || toastStyle.error;
              const toast = Swal.mixin({
                toast: true,
                position: "top-end",
                showConfirmButton: false,
                timer: 5000,
                timerProgressBar: true,
                background: style.background,
                color: style.color,
                didOpen: function (el) {
                  el.addEventListener("mouseenter", Swal.stopTimer);
                  el.addEventListener("mouseleave", Swal.resumeTimer);
                },
              });
              toast.fire({ icon: type, title: message });
            } else {
              alert(message);
            }
          });
        };

        showToast("error", flashMessages.error);
        showToast("warning", flashMessages.warning);
        showToast("success", flashMessages.success);
      })();
    </script>
