    <style>
      :root {
        --sas-green: #198754;
        --sas-ink: #1f2937;
      }

      body {
        min-height: 100vh;
        background:
          radial-gradient(1200px 500px at 15% -10%, rgba(25, 135, 84, 0.22), transparent 60%),
          radial-gradient(900px 420px at 90% 0%, rgba(13, 110, 253, 0.15), transparent 55%),
