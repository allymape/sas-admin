      }

      .auth-page-wrapper {
        position: relative;
      }

      .auth-one-bg .bg-overlay {
        background: linear-gradient(130deg, rgba(25, 135, 84, 0.85), rgba(15, 23, 42, 0.75));
      }

      .login-card {
        border: 0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.22);
        animation: card-enter 0.35s ease;
      }

      @keyframes card-enter {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .login-card .card-body {
        padding: 2rem 1.8rem;
      }

      .login-title {
        color: var(--sas-ink);
        letter-spacing: 0.3px;
        line-height: 1.4;
      }

      .login-subtitle {
        font-size: 0.88rem;
        color: #6b7280;
      }

      .login-input {
        border-radius: 10px;
        padding: 0.72rem 0.9rem;
        border: 1px solid #d8e2ee;
      }

      .login-input:focus {
        border-color: #6abf99;
        box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.12);
      }

      .login-submit {
        border-radius: 10px;
        padding: 0.74rem 1rem;
        font-weight: 600;
        letter-spacing: 0.2px;
      }

      .login-footer-note {
        font-size: 0.78rem;
        color: #94a3b8;
      }

      @media (max-width: 576px) {
        .login-card .card-body {
          padding: 1.45rem 1rem;
        }
      }
    </style>

</head>

